# === ПЛИТТЕКС ERP — Environment Variables ===

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=plittex_db

# Server
PORT=3000
NODE_ENV=development
# Разрешённые origin для CORS и Socket.io (через запятую). Пусто = только http://localhost:3000 и http://127.0.0.1:3000
# CORS_ORIGIN=https://erp.example.com,https://app.example.com
CORS_ORIGIN=

# JWT Secret (generate a strong random key)
JWT_SECRET=your_jwt_secret_here

# Sentry Monitoring (optional — leave empty to disable)
SENTRY_DSN=your_dsn_here

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dev Mode (set to 'true' to enable /api/dev routes)
DEV_MODE=false
