# === ПЛИТТЕКС ERP — Environment Variables ===

# PostgreSQL Database
DATABASE_URL=postgres://user:password@localhost:5432/plittex_db

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# JWT Secret (generate a strong random key)
JWT_SECRET=your_jwt_secret_here

# Sentry Monitoring (optional — leave empty to disable)
SENTRY_DSN=your_dsn_here

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dev Mode (set to 'true' to enable /api/dev routes)
DEV_MODE=false
