<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <title>Плиттекс ERP - Управление предприятием</title>
    <link rel="icon" href="data:,">

    <script src="/libs/chart.min.js"></script>
    <link rel="stylesheet" href="/libs/flatpickr.min.css">
    <link rel="stylesheet" href="/libs/tom-select.default.min.css">
    <script src="/libs/tom-select.complete.min.js"></script>
    <script src="/libs/flatpickr.min.js"></script>
    <script src="/libs/ru.min.js"></script>

    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <script src="/socket.io/socket.io.js"></script>

    <script>
        // Функция выхода (используется при ошибках 401)
        window.logout = function () {
            localStorage.clear();
            window.location.href = '/login.html';
        };
        // Алиас для кнопки выхода
        window.handleLogout = window.logout;

        // Редирект на логин, если нет токена (старый способ)
        const token = localStorage.getItem('token') || localStorage.getItem('jwtToken');
        if (!token) {
            window.location.href = '/login.html';
        } else {
            // Быстрая проверка на валидность JWT (базовый формат)
            if (token.split('.').length !== 3) {
                window.logout();
            }
        }
        // ПРИНУДИТЕЛЬНАЯ СВЕТЛАЯ ТЕМА ДЛЯ ДИАГНОСТИКИ
        document.documentElement.setAttribute('data-theme', 'light');
    </script>

</head>

<body>

    <div id="toast-container"></div>
    <div class="modal-overlay" id="app-modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="app-modal-title"></h2>
                <button class="btn-close" onclick="UI.closeModal()">&times;</button>
            </div>
            <div class="modal-body" id="app-modal-body"></div>
            <div class="modal-footer" id="app-modal-footer"></div>
        </div>
    </div>

    <div id="app-screen">
        <div class="sidebar">
            <div class="sidebar-header">ПЛИТТЕКС</div>
            <div class="nav-menu">
                <div class="nav-item active" onclick="switchModule('dashboard-mod', this)">📊 Дашборд</div>
                <div class="nav-item admin-only" id="nav-finance" onclick="switchModule('fin-mod', this)">💰 Финансы и
                    Касса</div>
                <div class="nav-item" onclick="switchModule('prod-mod', this)">🔨 Формовка (Производство)</div>
                <div class="nav-item" onclick="switchModule('stock-mod', this)">📦 Склады и Сушилка</div>
                <div class="nav-item" onclick="switchModule('purchase-mod', this)">🚚 Закупки (Склад №1)</div>
                <div class="nav-item" onclick="switchModule('sales-mod', this)">🛒 Продажи</div>
                <div class="nav-item" id="nav-salary" onclick="switchModule('salary-mod', this)">👷‍♂️ Кадры и Зарплата
                </div>
                <div class="nav-item admin-only" id="nav-ref" onclick="switchModule('ref-mod', this)">📁 Справочники
                </div>
                <div class="nav-item admin-only" id="nav-docs-reg"
                    onclick="switchModule('docs-registry-mod', this); loadDocsRegistry();">📄 Реестр документов</div>
                <div class="nav-item admin-only" id="nav-recipe" onclick="switchModule('recipe-mod', this)">🧪 Рецептуры
                </div>
                <div class="nav-item" onclick="switchModule('equipment-mod', this)">⚙️ Оборудование</div>
            </div>
        </div>

        <div class="main-wrapper">
            <div class="topbar">
                <div class="user-info" id="topbar-user">Пользователь: Загрузка...</div>
                <div style="display: flex; gap: 10px;">
                    <button class="btn btn-outline" id="theme-btn" onclick="toggleTheme()"
                        title="Сменить тему">🌙</button>
                    <button class="btn btn-red" onclick="handleLogout()">Выйти</button>
                </div>
            </div>

            <div class="content-area">
                <%- include('modules/dashboard') %>
                    <%- include('modules/production') %>
                        <%- include('modules/inventory') %>
                            <%- include('modules/purchase') %>
                                <%- include('modules/sales') %>
                                    <%- include('modules/finance') %>
                                        <%- include('modules/salary') %>
                                            <%- include('modules/references') %>
                                                <%- include('modules/docs_registry') %>
                                                    <%- include('modules/recipes') %>
                                                        <%- include('modules/equipment') %>
            </div>
        </div>
    </div>

    <button id="scroll-top-btn"
        onclick="document.querySelector('.content-area').scrollTo({top: 0, behavior: 'smooth'})">↑</button>

    <script src="/js/references.js"></script>
    <script src="/js/recipes.js"></script>
    <script src="/js/purchases.js"></script>
    <script src="/js/production.js"></script>
    <script src="/js/inventory.js"></script>
    <script src="/js/sales.js"></script>
    <script src="/js/finance.js"></script>
    <script src="/js/salary.js?v=<%= Date.now() %>"></script>
    <script src="/js/docs_registry.js"></script>
    <script src="/js/dashboard.js"></script>
    <script src="/js/equipment.js"></script>

    <script>
        const originalFetch = window.fetch;
        window.fetch = async function (resource, config = {}) {
            const url = (resource instanceof Request) ? resource.url : resource;
            const requestToken = localStorage.getItem('token') || localStorage.getItem('jwtToken');

            if (typeof url === 'string' && url.includes('/api') && !url.includes('/api/login')) {
                if (requestToken) {
                    if (resource instanceof Request) {
                        resource.headers.set('Authorization', `Bearer ${requestToken}`);
                    } else {
                        if (!config.headers) config.headers = {};
                        config.headers = { ...config.headers, 'Authorization': `Bearer ${requestToken}` };
                    }
                }
            }

            try {
                const response = await originalFetch(resource, config);
                // Проверка 401/403
                if ((response.status === 401 || response.status === 403) && typeof url === 'string' && url.includes('/api') && !url.includes('/api/login')) {
                    const latestToken = localStorage.getItem('token') || localStorage.getItem('jwtToken');
                    if (latestToken === requestToken) {
                        console.warn("Session expired on request:", url);
                        if (typeof window.logout === 'function') window.logout();
                        else { localStorage.clear(); window.location.href = '/login.html'; }
                    }
                    return Promise.reject(new Error('Auth required'));
                }
                return response;
            } catch (e) { throw e; }
        };

        window.switchModule = function (moduleId, navElement) {
            document.querySelectorAll('.modal-overlay').forEach(m => {
                m.classList.remove('active');
                m.style.display = 'none';
            });
            document.querySelectorAll('.module').forEach(mod => mod.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
            const target = document.getElementById(moduleId);
            if (target) {
                target.classList.add('active');
                if (navElement) navElement.classList.add('active');
            }
            try {
                if (moduleId === 'stock-mod' && typeof loadTable === 'function') loadTable();
                if (moduleId === 'sales-mod') (typeof initSales === 'function') ? initSales() : (typeof loadSalesData === 'function' && loadSalesData(false));
                if (moduleId === 'fin-mod') (typeof initFinance === 'function') ? initFinance() : (typeof loadFinanceData === 'function' && loadFinanceData());
                if (moduleId === 'purchase-mod' && typeof loadPurchaseMaterials === 'function') loadPurchaseMaterials();
                if (moduleId === 'salary-mod' && typeof initSalary === 'function') initSalary();
                if (moduleId === 'prod-mod' && typeof initProduction === 'function') initProduction();
                if (moduleId === 'recipe-mod' && typeof loadRecipeModuleData === 'function') loadRecipeModuleData();
                if (moduleId === 'ref-mod' && typeof loadReferences === 'function') loadReferences();
                if (moduleId === 'equipment-mod' && typeof loadEquipment === 'function') loadEquipment();
                if (moduleId === 'dashboard-mod' && typeof initDashboard === 'function') initDashboard();
            } catch (err) { console.error(err); }
        };

        // ==========================================================================
        // ГЛОБАЛЬНЫЙ ДИСПЕТЧЕР СУЩНОСТЕЙ (Сквозная навигация)
        // ==========================================================================
        window.app = window.app || {};

        window.app.openEntity = function(type, id) {
            if (!id) {
                console.warn(`[App Router] Попытка открыть сущность '${type}' без ID.`);
                return;
            }

            console.log(`[App Router] Открываю сущность: ${type}, ID: ${id}`);
            
            switch (type) {
                case 'client':
                    // Вызов из: finance.js, sales.js
                    if (typeof openCounterpartyProfile === 'function') {
                        // Идеальный вариант (полная карточка из finance.js)
                        openCounterpartyProfile(id);
                    } else if (typeof editClient === 'function') {
                        // Запасной вариант
                        editClient(id);
                    } else {
                        console.error('[App Router] Функция открытия профиля клиента (openCounterpartyProfile или editClient) не найдена на этой странице.');
                        UI.toast('Модуль карточки клиента не загружен', 'error');
                    }
                    break;
                case 'employee':
                    if (typeof editWorker === 'function') editWorker(id);
                    break;
                case 'nomenclature':
                    if (typeof editNomenclature === 'function') editNomenclature(id);
                    break;
                case 'document_order':
                    console.log('Открытие модалки заказа: ', id);
                    break;
                case 'document_invoice':
                    console.log('Открытие счета: ', id);
                    break;
                case 'tara':
                    console.log('Открытие аналитики по таре для поддона/клиента: ', id);
                    break;
                case 'equipment':
                    if (typeof editEquipment === 'function') editEquipment(id);
                    break;
                case 'recipe':
                    if (typeof editRecipe === 'function') editRecipe(id);
                    break;
                default:
                    console.error(`[App Router] Неизвестный тип сущности: ${type}`);
                    break;
            }
        };

        window.app.navigateCategory = function(categoryName) {
            console.log(`[App Router] Навигация по категории: ${categoryName}`);
            
            // Если модалки открыты, мягко их закрываем
            if (UI && typeof UI.closeModal === 'function') {
                document.querySelectorAll('.modal-overlay.active').forEach(m => UI.closeModal(m.id));
            }

            // Утилита для безопасного вызова после рендера DOM
            const openWithDelay = (fn, delay = 150) => setTimeout(fn, delay);

            switch (categoryName) {
                // --- ЗАРПЛАТА (Открываем аккордеон 'Выплаты') ---
                case 'Зарплата и Авансы':
                case 'Оплата труда':
                case 'Зарплата':
                case 'Премии':
                case 'Сдельная оплата':
                case 'Штрафы':
                    window.switchModule('salary-mod');
                    openWithDelay(() => {
                        const body = document.getElementById('acc-payouts');
                        const header = document.querySelector('[onclick*="acc-payouts"]');
                        if (typeof toggleAccordion === 'function' && body && !body.classList.contains('active')) {
                            toggleAccordion('acc-payouts', header);
                        }
                    });
                    break;

                // --- ПРОДАЖИ (Открываем таб 'Управление заказами') ---
                case 'Продажа продукции':
                case 'Реализация (Продажа)':
                case 'Продажи':
                case 'Реализация':
                case 'Доставка клиенту':
                case 'Транспортные услуги (клиентам)':
                    window.switchModule('sales-mod');
                    openWithDelay(() => {
                        const btn = document.querySelector('[onclick*="tab-active-orders"]');
                        if (typeof switchSalesTab === 'function' && btn) {
                            switchSalesTab('tab-active-orders', btn);
                        }
                    });
                    break;

                // --- ВОЗВРАТНАЯ ТАРА (Открываем фильтр 'Поддоны' в Оборудовании) ---
                case 'Покупка поддонов':
                case 'Возвратная тара':
                case 'Тара':
                case 'Поддоны':
                    window.switchModule('equipment-mod');
                    openWithDelay(() => {
                        const btn = document.getElementById('filter-eq-pallets');
                        if (typeof filterEquipment === 'function' && btn) {
                            filterEquipment('pallets', btn);
                        }
                    });
                    break;

                // --- ОБОРУДОВАНИЕ (Открываем фильтр 'Станки') ---
                case 'Оборудование':
                case 'Покупка оборудования':
                case 'Станки':
                case 'Запчасти':
                case 'Ремонт оборудования':
                case 'Инструмент':
                case 'Матрицы':
                    window.switchModule('equipment-mod');
                    openWithDelay(() => {
                        const buttons = document.querySelectorAll('button');
                        const btn = Array.from(buttons).find(b => b.getAttribute('onclick') && b.getAttribute('onclick').includes("filterEquipment('machine'"));
                        if (typeof filterEquipment === 'function' && btn) {
                            filterEquipment('machine', btn);
                        }
                    });
                    break;

                // --- ЗАКУПКИ / СЫРЬЕ ---
                case 'Закупка сырья':
                case 'Материалы':
                case 'Сырье':
                case 'Цемент':
                case 'Песок':
                case 'Щебень':
                case 'Пигмент':
                case 'Транспортные услуги (сырье)':
                case 'Доставка сырья':
                case 'Химия / Пластификатор':
                    window.switchModule('purchase-mod');
                    break;

                // --- ПРОЧИЕ КАТЕГОРИИ (Динамический Drill-down в Финансы) ---
                default:
                    window.switchModule('fin-mod');
                    openWithDelay(() => {
                        const searchInput = document.getElementById('finance-search');
                        if (searchInput) {
                            searchInput.value = categoryName;
                            if (typeof triggerFinanceSearch === 'function') {
                                triggerFinanceSearch();
                            } else if (typeof loadFinanceData === 'function') {
                                loadFinanceData();
                            }
                        }
                    });
                    break;
            }
        };

        const UI = {
            toast: (msg, type = 'success') => {
                const container = document.getElementById('toast-container');
                const toast = document.createElement('div');
                toast.className = `toast ${type}`;
                const icon = type === 'success' ? '✅' : type === 'error' ? '❌' : 'ℹ️';
                toast.innerHTML = `<span>${icon}</span> <div>${msg}</div>`;
                container.appendChild(toast);
                setTimeout(() => {
                    toast.style.animation = 'fadeOut 0.3s forwards';
                    setTimeout(() => toast.remove(), 300);
                }, 4000);
            },
            showModal: (title, htmlBody, buttonsHtml) => {
                document.getElementById('app-modal-title').innerHTML = title;
                document.getElementById('app-modal-body').innerHTML = htmlBody;
                document.getElementById('app-modal-footer').innerHTML = buttonsHtml;
                document.getElementById('app-modal').style.display = 'flex';
                document.getElementById('app-modal').classList.add('active');
            },
            closeModal: (id = 'app-modal') => {
                const targetModal = document.getElementById(id);
                if (targetModal) { targetModal.classList.remove('active'); targetModal.style.display = 'none'; }
            }
        };

        window.startApp = function (userName) {
            if (userName) document.getElementById('topbar-user').innerText = `👤 ${userName}`;
            const token = localStorage.getItem('token') || localStorage.getItem('jwtToken');
            if (token) {
                try {
                    const parts = token.split('.');
                    if (parts.length === 3) {
                        const payload = JSON.parse(atob(parts[1].replace(/-/g, '+').replace(/_/g, '/')));
                        const isAdmin = payload.role === 'admin';
                        document.querySelectorAll('.admin-only').forEach(el => el.style.display = isAdmin ? 'block' : 'none');
                    }
                } catch (e) { }
            }
            if (typeof UI !== 'undefined' && UI.closeModal) UI.closeModal();
            switchModule('dashboard-mod', document.querySelector('.nav-item.active'));
        };

        // Запуск при загрузке
        document.addEventListener('DOMContentLoaded', () => {
            const userStr = localStorage.getItem('user');
            if (userStr) {
                try {
                    const u = JSON.parse(userStr);
                    window.startApp(u.username);
                } catch (e) { window.startApp(); }
            } else {
                window.startApp();
            }
        });

        // Закрытие модального окна при клике на темный фон (overlay)
        document.addEventListener('click', (e) => {
            if (e.target.classList.contains('modal-overlay')) {
                e.target.classList.remove('active');
                e.target.style.display = 'none';
            }
        });

        // === ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ===
        window.getCssVar = (name) => getComputedStyle(document.documentElement).getPropertyValue(name).trim();
        window.getChartColors = function () {
            return [
                window.getCssVar('--chart-1'), window.getCssVar('--chart-2'), window.getCssVar('--chart-3'),
                window.getCssVar('--chart-4'), window.getCssVar('--chart-5'), window.getCssVar('--chart-6'), window.getCssVar('--chart-7')
            ];
        };

        window.toggleTheme = () => {
            const current = document.documentElement.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
            document.getElementById('theme-btn').innerText = next === 'dark' ? '☀️' : '🌙';
        };

        // Календари (Flatpickr)
        window.initDateRangePicker = function (inputId, onChangeCallback) {
            const el = document.getElementById(inputId);
            if (!el) return null;
            return flatpickr(el, {
                mode: "range", dateFormat: "Y-m-d", altInput: true, altFormat: "d.m.Y", locale: "ru",
                onChange: function (selectedDates, dateStr, instance) {
                    if (onChangeCallback) {
                        let start = '', end = '';
                        if (selectedDates.length === 1) start = end = instance.formatDate(selectedDates[0], "Y-m-d");
                        else if (selectedDates.length === 2) {
                            start = instance.formatDate(selectedDates[0], "Y-m-d");
                            end = instance.formatDate(selectedDates[1], "Y-m-d");
                        }
                        onChangeCallback(start, end);
                    }
                }
            });
        };

        window.initSingleDatePicker = function (inputId, onChangeCallback) {
            const el = document.getElementById(inputId);
            if (!el) return null;
            return flatpickr(el, {
                dateFormat: "Y-m-d", altInput: true, altFormat: "d.m.Y", locale: "ru",
                onChange: function (selectedDates, dateStr, instance) {
                    if (onChangeCallback && selectedDates.length === 1) {
                        onChangeCallback(instance.formatDate(selectedDates[0], "Y-m-d"));
                    }
                }
            });
        };

        window.setQuickDateRange = function (pickerInstance, type) {
            if (!pickerInstance) return;
            const today = new Date();
            let start = new Date(), end = new Date();
            switch (type) {
                case 'today': break;
                case 'week':
                    const day = today.getDay();
                    const diff = today.getDate() - day + (day === 0 ? -6 : 1);
                    start.setDate(diff); end = new Date(start);
                    end.setDate(start.getDate() + 6);
                    break;
                case 'month':
                    start = new Date(today.getFullYear(), today.getMonth(), 1);
                    end = new Date(today.getFullYear(), today.getMonth() + 1, 0);
                    break;
                case 'year':
                    start = new Date(today.getFullYear(), 0, 1);
                    end = new Date(today.getFullYear(), 11, 31);
                    break;
            }
            pickerInstance.setDate([start, end], true);
        };

        window.escapeHTML = function (str) {
            if (!str) return '';
            return String(str).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
        };

        let socket;
        try {
            socket = io();
            socket.on('inventory_updated', () => {
                if (document.getElementById('stock-mod').classList.contains('active')) typeof loadTable === 'function' && loadTable();
                if (document.getElementById('dashboard-mod').classList.contains('active')) typeof initDashboard === 'function' && initDashboard();
            });
        } catch (e) { console.warn("Socket.io registration failed:", e); }
    </script>

<% if (locals.devMode) { %>
    <div id="dev-toolbar" class="surface-alt border-top" style="position: fixed; bottom: 0; left: 0; width: 100%; padding: 10px 20px; z-index: 10000; display: flex; gap: 15px; align-items: center; justify-content: space-between; background: var(--surface);">
        <div style="display: flex; gap: 10px; align-items: center; color: var(--warning);">
            <span>🛠️ <strong>DEV PANEL</strong></span>
            <span class="text-muted" style="font-size: 12px; color: var(--text-muted);">Работает поверх «Нотариуса»</span>
        </div>
        <div style="display: flex; gap: 5px;">
            <button class="btn btn-warning btn-sm" onclick="openDevUnlockModal()">🔓 Разблокировать Заказ</button>
            <button class="btn btn-dev-danger btn-sm" onclick="devHardDeleteTransaction()">💥 Hard Delete Транзакции</button>
            <button class="btn btn-dev-danger btn-sm" onclick="devHardDeleteProduction()">🧹 Очистить Партию ЗП</button>
        </div>
    </div>
    <script>
        document.body.classList.add('dev-mode-active');
        
        async function openDevUnlockModal() {
            const orderId = prompt("Введите ID заказа для разблокировки:");
            if (!orderId) return;
            if (!confirm(`ВНИМАНИЕ! Вы принудительно снимаете режим "Нотариус" с заказа ${orderId}. Продолжить?`)) return;
            
            try {
                const res = await fetch(`/api/dev/unlock-order/${orderId}`, { method: 'POST' });
                const data = await res.json();
                if (res.ok) {
                    alert('Готово. ' + data.message);
                    if (typeof loadSalesData === 'function') loadSalesData(false);
                } else {
                    alert('Ошибка: ' + (data.error || 'Неизвестная ошибка'));
                }
            } catch (e) { alert('Ошибка сети: ' + e.message); }
        }

        async function devHardDeleteTransaction() {
            const txId = prompt("Введите ID транзакции для тотального удаления (Hard Delete):");
            if (!txId) return;
            if (!confirm(`ВНИМАНИЕ! Вы выполняете тотальное удаление данных (Hard Delete) напрямую из БД. Восстановление невозможно. Продолжить?`)) return;
            
            try {
                const res = await fetch(`/api/dev/transactions/${txId}`, { method: 'DELETE' });
                const data = await res.json();
                if (res.ok) {
                    alert('Готово. Данные вычищены, балансы пересчитаны.');
                    if (typeof loadFinanceData === 'function') loadFinanceData();
                } else {
                    alert('Ошибка: ' + (data.error || 'Неизвестная ошибка'));
                }
            } catch (e) { alert('Ошибка сети: ' + e.message); }
        }

        async function devHardDeleteProduction() {
            const batchId = prompt("Введите ID партии для удаления (Hard Delete):");
            if (!batchId) return;
            if (!confirm(`ВНИМАНИЕ! Вы удаляете ПАРТИЮ с полным откатом сырья и наработки из БД. Восстановление невозможно. Продолжить?`)) return;
            
            try {
                const res = await fetch(`/api/dev/production/${batchId}`, { method: 'DELETE' });
                const data = await res.json();
                if (res.ok) {
                    alert('Готово. Данные вычищены.');
                    if (typeof initProduction === 'function') initProduction();
                } else {
                    alert('Ошибка: ' + (data.error || 'Неизвестная ошибка'));
                }
            } catch (e) { alert('Ошибка сети: ' + e.message); }
        }
    </script>
<% } %>
</body>
</html>