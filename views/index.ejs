<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <title>Плиттекс ERP - Управление предприятием</title>
    <link rel="icon" href="data:,">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/ru.js"></script>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <div id="toast-container"></div>

    <div id="app-modal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <span id="app-modal-title">Внимание</span>
                <button style="background:none; border:none; font-size:20px; cursor:pointer; color:var(--text-muted);"
                    onclick="UI.closeModal()">×</button>
            </div>
            <div class="modal-body" id="app-modal-body">Текст...</div>
            <div class="modal-footer" id="app-modal-footer"></div>
        </div>
    </div>

    <div id="login-screen">
        <div class="login-box">
            <h2 style="border:none;">ERP Плиттекс</h2>
            <input type="text" id="login-user" placeholder="Логин">
            <input type="password" id="login-pass" placeholder="Пароль">
            <button class="btn btn-blue" id="login-btn" style="width: 100%; margin-top: 15px;">Войти в систему</button>
        </div>
    </div>

    <div id="app-screen">

        <div class="sidebar">
            <div class="sidebar-header">ПЛИТТЕКС</div>
            <div class="nav-menu">
                <div class="nav-item active" onclick="switchModule('dashboard-mod', this)">📊 Дашборд</div>
                <div class="nav-item" onclick="switchModule('fin-mod', this); initFinance();">💰 Финансы и Касса</div>
                <div class="nav-item" onclick="switchModule('prod-mod', this)">🔨 Формовка (Производство)</div>
                <div class="nav-item" onclick="switchModule('stock-mod', this)">📦 Склады и Сушилка</div>
                <div class="nav-item" onclick="switchModule('purchase-mod', this)">🚚 Закупки (Склад №1)</div>
                <div class="nav-item" onclick="switchModule('sales-mod', this)">🛒 Продажи</div>
                <div class="nav-item" onclick="switchModule('salary-mod', this)">👷‍♂️ Кадры и Зарплата</div>
                <div class="nav-item" id="nav-ref" onclick="switchModule('ref-mod', this)">📁 Справочники</div>
                <div class="nav-item" id="nav-recipe" onclick="switchModule('recipe-mod', this)">🧪 Рецептуры</div>
                <div class="nav-item" onclick="switchModule('equipment-mod', this)">⚙️ Оборудование</div>
            </div>
        </div>

        <div class="main-wrapper">
            <div class="topbar">
                <div class="user-info" id="topbar-user">Пользователь: Загрузка...</div>
                <button class="btn btn-red" onclick="location.reload()">Выйти</button>
            </div>

            <div class="content-area">
                <%- include('modules/dashboard') %>
                    <%- include('modules/production') %>
                        <%- include('modules/inventory') %>
                            <%- include('modules/purchase') %>
                                <%- include('modules/sales') %>
                                    <%- include('modules/finance') %>
                                        <%- include('modules/salary') %>
                                            <%- include('modules/references') %>
                                                <%- include('modules/recipes') %>
                                                    <%- include('modules/equipment') %>
            </div>

        </div>
    </div>

    <button id="scroll-top-btn"
        onclick="document.querySelector('.content-area').scrollTo({top: 0, behavior: 'smooth'})">↑</button>

    <script src="/js/references.js"></script>
    <script src="/js/recipes.js"></script>
    <script src="/js/purchases.js"></script>
    <script src="/js/production.js"></script>
    <script src="/js/inventory.js"></script>
    <script src="/js/sales.js"></script>
    <script src="/js/finance.js"></script>
    <script src="/js/salary.js"></script>
    <script src="/js/dashboard.js"></script>
    <script src="/js/equipment.js"></script>

    <script>
        // === 1. ГЛОБАЛЬНЫЙ ПЕРЕХВАТЧИК ЗАПРОСОВ (МАГИЯ АВТОРИЗАЦИИ) ===
        const originalFetch = window.fetch;
        window.fetch = async function (resource, config = {}) {
            if (typeof resource === 'string' && resource.startsWith('/api') && resource !== '/api/login') {
                const token = localStorage.getItem('jwtToken');
                if (token) {
                    config.headers = { ...config.headers, 'Authorization': `Bearer ${token}` };
                }
            }

            const response = await originalFetch(resource, config);

            // 🚀 ИСПРАВЛЕНИЕ: Перехватываем 401 ТОЛЬКО если это не попытка входа!
            // Если это логин, пропускаем ответ дальше, чтобы показать alert('Неверный пароль')
            if ((response.status === 401 || response.status === 403) && typeof resource === 'string' && resource.startsWith('/api') && resource !== '/api/login') {
                localStorage.removeItem('jwtToken');
                localStorage.removeItem('userName');
                document.getElementById('app-screen').style.display = 'none';
                document.getElementById('login-screen').style.display = 'flex';
                if (typeof UI !== 'undefined') UI.toast('Сессия истекла. Пожалуйста, войдите заново.', 'error');

                return Promise.reject(new Error('Требуется авторизация (401)'));
            }

            return response;
        };

        // === ГЛОБАЛЬНОЕ УПРАВЛЕНИЕ ИНТЕРФЕЙСОМ И ПАМЯТЬЮ ===
        function switchModule(moduleId, navElement) {
            // 1. Переключаем визуал (вкладки)
            document.querySelectorAll('.module').forEach(mod => mod.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));

            const target = document.getElementById(moduleId);
            if (target) {
                target.classList.add('active');
                if (navElement) navElement.classList.add('active');
            }

            // === 2. 🧹 УМНАЯ ОЧИСТКА ПАМЯТИ (GARBAGE COLLECTOR) ===
            // Очищаем тяжелые массивы данных тех модулей, которые сейчас скрыты с экрана.
            // Используем .length = 0, чтобы гарантированно очистить ОЗУ, не сломав привязки переменных в других файлах.

            if (moduleId !== 'finance-mod') {
                if (typeof allTransactions !== 'undefined') allTransactions.length = 0;
                if (typeof financeInvoices !== 'undefined') financeInvoices.length = 0;
            }

            if (moduleId !== 'sales-mod') {
                if (typeof salesOrders !== 'undefined') salesOrders.length = 0;
                // Не трогаем справочник клиентов (clients), он нужен для отрисовки имен везде
            }

            if (moduleId !== 'stock-mod') {
                if (typeof allInventory !== 'undefined') allInventory.length = 0;
            }

            // ВАЖНО: Мы НЕ очищаем корзину покупок и сессию производства (sessionProducts), 
            // чтобы бригадир или менеджер мог переключиться на вкладку Склада (проверить остатки), 
            // вернуться обратно в свой модуль и продолжить оформление без потери введенных данных.


            // === 3. 🔄 АВТО-ВОССТАНОВЛЕНИЕ ДАННЫХ ПРИ ВХОДЕ В МОДУЛЬ ===
            // Так как мы стерли данные из памяти при уходе, их нужно запросить у базы заново при возвращении
            if (moduleId === 'stock-mod' && typeof loadTable === 'function') loadTable();
            if (moduleId === 'salary-mod' && typeof loadMonthlyTimesheet === 'function') loadMonthlyTimesheet();
            if (moduleId === 'equipment-mod' && typeof loadEquipment === 'function') loadEquipment();

            // Добавляем авто-обновление для главных тяжелых модулей
            if (moduleId === 'finance-mod' && typeof loadFinanceData === 'function') loadFinanceData();
            if (moduleId === 'sales-mod' && typeof loadSalesData === 'function') loadSalesData();
        }

        // === 3. ГЛОБАЛЬНЫЙ ДВИЖОК КРАСИВЫХ УВЕДОМЛЕНИЙ (UI) ===
        const UI = {
            toast: (msg, type = 'success') => {
                const container = document.getElementById('toast-container');
                const toast = document.createElement('div');
                toast.className = `toast ${type}`;
                const icon = type === 'success' ? '✅' : type === 'error' ? '❌' : 'ℹ️';
                toast.innerHTML = `<span>${icon}</span> <div>${msg}</div>`;
                container.appendChild(toast);
                setTimeout(() => {
                    toast.style.animation = 'fadeOut 0.3s forwards';
                    setTimeout(() => toast.remove(), 300);
                }, 4000);
            },
            showModal: (title, htmlBody, buttonsHtml) => {
                document.getElementById('app-modal-title').innerHTML = title;
                document.getElementById('app-modal-body').innerHTML = htmlBody;
                document.getElementById('app-modal-footer').innerHTML = buttonsHtml;
                document.getElementById('app-modal').classList.add('active');
            },
            closeModal: () => document.getElementById('app-modal').classList.remove('active')
        };

        // === 4. ЦЕНТРАЛИЗОВАННЫЙ ЗАПУСК СИСТЕМЫ ===
        function startApp(userFullName) {
            document.getElementById('login-screen').style.display = 'none';
            document.getElementById('app-screen').style.display = 'flex';
            if (userFullName) document.getElementById('topbar-user').innerText = `👤 ${userFullName}`;

            // Запускаем подгрузку всех данных ТОЛЬКО после того, как мы точно внутри
            if (typeof initProduction === 'function') initProduction();
            if (typeof initSales === 'function') initSales();
            if (typeof initFinance === 'function') initFinance();
            if (typeof initSalary === 'function') initSalary();
            if (typeof loadTable === 'function') loadTable();
            if (typeof loadReferences === 'function') loadReferences();
            if (typeof loadRecipeModuleData === 'function') loadRecipeModuleData();
            if (typeof loadPurchaseMaterials === 'function') loadPurchaseMaterials();
        }

        // === 5. ВХОД В СИСТЕМУ ПО КНОПКЕ ===
        document.getElementById('login-btn').addEventListener('click', () => {
            const user = document.getElementById('login-user').value;
            const pass = document.getElementById('login-pass').value;

            fetch('/api/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username: user, password: pass })
            }).then(async res => {
                if (res.ok) {
                    const data = await res.json();
                    localStorage.setItem('jwtToken', data.token);
                    localStorage.setItem('userName', data.user.full_name);

                    startApp(data.user.full_name);
                } else {
                    alert('Ошибка входа: Неверный логин или пароль');
                }
            }).catch(err => console.error("Ошибка сети при логине:", err));
        });

        // 🚀 НОВОЕ: АВТОВХОД ПРИ ПЕРЕЗАГРУЗКЕ СТРАНИЦЫ
        window.addEventListener('DOMContentLoaded', () => {
            const token = localStorage.getItem('jwtToken');
            const userName = localStorage.getItem('userName');

            if (token) {
                // Если пропуск уже лежит в кармане (в памяти), запускаем приложение без экрана логина
                startApp(userName);
            } else {
                // Если пропуска нет, принудительно показываем экран входа
                document.getElementById('app-screen').style.display = 'none';
                document.getElementById('login-screen').style.display = 'flex';
            }
        });

        // === 6. КНОПКА СКРОЛЛА ===
        document.querySelector('.content-area').addEventListener('scroll', function () {
            const btn = document.getElementById('scroll-top-btn');
            if (btn) btn.style.display = this.scrollTop > 300 ? 'block' : 'none';
        });
    </script>
</body>

</html>