    <script src="/socket.io/socket.io.js"></script>

    <script>
        // Функция выхода (используется при ошибках 401)
        window.logout = function () {
            localStorage.clear();
            window.location.href = '/login.html';
        };
        // Алиас для кнопки выхода
        window.handleLogout = window.logout;

        // Редирект на логин, если нет токена (старый способ)
        const token = localStorage.getItem('token') || localStorage.getItem('jwtToken');
        if (!token) {
            window.location.href = '/login.html';
        } else {
            // Быстрая проверка на валидность JWT (базовый формат)
            if (token.split('.').length !== 3) {
                window.logout();
            }
        }
    </script>
</head>

