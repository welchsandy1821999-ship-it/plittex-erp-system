<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Спецификация</title>
    <style>
        body { font-family: 'Times New Roman', Times, serif; padding: 40px; color: #000; max-width: 850px; margin: auto; font-size: 11pt; line-height: 1.15; }
        .right-header { text-align: right; margin-bottom: 20px; font-size: 11pt; }
        h3 { text-align: center; font-size: 12pt; margin-bottom: 15px; font-weight: bold; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 11pt; }
        th, td { border: 1px solid #000; padding: 6px; text-align: left; }
        th { font-weight: bold; text-align: center; }
        .text-right { text-align: right; }
        .text-center { text-align: center; }
        .bold { font-weight: bold; }
        .req-table { width: 100%; border-collapse: collapse; margin-top: 40px; font-size: 10pt; }
        .req-table td { border: none; padding: 5px 15px 5px 0; vertical-align: top; width: 50%; }
        
        /* Стили кнопок */
        .action-buttons { display: flex; gap: 10px; justify-content: flex-end; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px dashed #ccc; }
        .btn { padding: 10px 16px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; color: white; font-size: 13px; transition: 0.2s; }
        .btn-green { background: #10b981; } .btn-green:hover { background: #059669; }
        .btn-gray { background: #64748b; } .btn-gray:hover { background: #475569; }
        .btn-blue { background: #3b82f6; } .btn-blue:hover { background: #2563eb; }
        @page { margin: 0; size: A4 portrait; }
        @media print { .no-print { display: none !important; } body { padding: 15mm; background: var(--surface); } }
    </style>
</head>
<body>
    <div class="action-buttons no-print">
        <button class="btn btn-blue" onclick="Export2Word('Спецификация_Плиттекс_№<%= docNum.split('-')[1] %>')">📄 Сохранить в Word</button>
        <button class="btn btn-gray" onclick="saveAndPrint(false, 'Спецификация_<%= docNum.split('-')[1] %>')">🖨️ Сохранить PDF (Без печати)</button>
        <button class="btn btn-green" onclick="saveAndPrint(true, 'Спецификация_<%= docNum.split('-')[1] %>')">🖨️ Сохранить PDF (С печатью)</button>
    </div>

    <div id="doc-content">
        <% 
            let cNum = '_______'; let cDate = '_______';
            if(contractInfo && contractInfo.includes('от')) {
                let parts = contractInfo.split('от');
                cNum = parts[0].replace('Договор №', '').trim();
                cDate = parts[1].trim();
            }
        %>
        <div class="right-header">
            Приложение № 1<br>
            К договору № <%= cNum %> от <%= cDate %><br>
            Бланк заказа № <%= docNum.split('-')[1] %> от <%= date %>
        </div>

        <h3>СПЕЦИФИКАЦИЯ № <%= docNum.split('-')[1] %></h3>
        <p><b>1. Цена товара составляет:</b></p>

        <table>
            <thead>
                <tr>
                    <th style="width: 5%;">№</th>
                    <th style="width: 45%;">Наименование</th>
                    <th style="width: 15%;">Ед. измерения</th>
                    <th style="width: 10%;">Количество</th>
                    <th style="width: 10%;">Цена</th>
                    <th style="width: 15%;">Сумма руб.</th>
                </tr>
            </thead>
            <tbody>
                <% items.forEach(function(item, index) { %>
                    <tr>
                        <td class="text-center"><%= index + 1 %></td>
                        <td><%= item.name %></td>
                        <td class="text-center"><%= item.unit %></td>
                        <td class="text-center"><%= parseFloat(item.qty).toLocaleString('ru-RU') %></td>
                        <td class="text-right"><%= parseFloat(item.price).toLocaleString('ru-RU', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></td>
                        <td class="text-right"><%= (parseFloat(item.qty) * parseFloat(item.price)).toLocaleString('ru-RU', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></td>
                    </tr>
                <% }); %>
                <tr>
                    <td colspan="5" class="bold text-right">ИТОГО</td>
                    <td class="bold text-right"><%= parseFloat(totalAmount).toLocaleString('ru-RU', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></td>
                </tr>
                <tr>
                    <td colspan="5" class="text-right">В том числе НДС <%= vatRate %>%</td>
                    <td class="text-right"><%= (parseFloat(totalAmount) * vatRate / (100 + vatRate)).toLocaleString('ru-RU', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></td>
                </tr>
            </tbody>
        </table>

        <p><b>2. Оплата за товар производится в следующем порядке:</b></p>
        <p>- ________________ рублей в т.ч. НДС <%= vatRate %>%, Покупатель перечисляет Поставщику в качестве аванса в день подписания Договора.</p>
        <p>- оставшуюся сумму от общей стоимости товара в размере ________________ рубля в т.ч. НДС <%= vatRate %>%, Покупатель осуществляет в течение 10 (Десяти) календарных дней с момента приема-передачи Товара, путем перечисления стоимости продукции на расчетный счет Поставщика.</p>

        <table class="req-table">
            <tr>
                <td style="position: relative;">
                    <b>Поставщик</b><br>
                    ООО «ПЛИТТЕКС»<br>
                    Юридический адрес: 352244, РФ, Краснодарский край, г. Новокубанск, ул. Кузнечная, № 1, офис № 2<br>
                    Фактический адрес: 352244, РФ, Краснодарский край, г. Новокубанск, ул. Кузнечная, № 1, офис № 2<br>
                    ИНН 2372029123 КПП 237201001<br>
                    ОГРН 1212300040083<br>
                    Р/с 40702810901500100003<br>
                    Банк: ООО «Банк Точка» г. Москва<br>
                    БИК 044525104<br>
                    Корр. счёт 30101810745374525104<br>
                    E-mail: plittex@bk.ru<br>
                    Тел.: 8 (988) 888-05-06<br><br>
                    Генеральный директор<br><br>
                    _______________________ С.М. Марченко
                    <img src="/img/stamp.png" class="overlay-img" style="position: absolute; bottom: 0px; left: 100px; width: 140px; opacity: 0.85; display: none; z-index: -2;">
                    <img src="/img/sign_dir.png" class="overlay-img" style="position: absolute; bottom: 20px; left: 50px; width: 100px; display: none; z-index: -1;">
                </td>
                <td>
                    <b>Покупатель</b><br>
                    <%= clientName %><br>
                    <br><br><br><br><br><br><br><br><br><br><br><br>
                    Директор<br><br>
                    _______________________ _______________
                </td>
            </tr>
        </table>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        async function saveAndPrint(withStamp, docName) {
            const overlays = document.querySelectorAll('.overlay-img');
            overlays.forEach(el => el.style.display = withStamp ? 'block' : 'none');
            const actionBtns = document.querySelector('.action-buttons');
            if (actionBtns) actionBtns.style.display = 'none';

            const element = document.getElementById('doc-content');
            const opt = { margin: [10, 10, 10, 10], filename: `${docName}_${withStamp ? 'С_печатью' : 'Без_печати'}_${Date.now()}.pdf`, image: { type: 'jpeg', quality: 0.98 }, html2canvas: { scale: 2, useCORS: true }, jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' } };

            try {
                const pdfBase64 = await html2pdf().set(opt).from(element).outputPdf('datauristring');
                await fetch('/api/docs/save-pdf', { method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ filename: opt.filename, fileData: pdfBase64 }) });
            } catch (error) { console.error("Ошибка:", error); }

            window.print();
            if (actionBtns) actionBtns.style.display = 'flex';
        }

        function Export2Word(filename = '') {
            const overlays = document.querySelectorAll('.overlay-img');
            overlays.forEach(el => el.style.display = 'none');
            const actionBtns = document.querySelector('.action-buttons');
            if (actionBtns) actionBtns.style.display = 'none';

            var preHtml = "<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'><head><meta charset='utf-8'><title>Export</title></head><body>";
            var postHtml = "</body></html>";
            var html = preHtml + document.getElementById('doc-content').innerHTML + postHtml;

            var blob = new Blob(['\ufeff', html], { type: 'application/msword' });
            var url = 'data:application/vnd.ms-word;charset=utf-8,' + encodeURIComponent(html);
            var downloadLink = document.createElement("a");
            
            document.body.appendChild(downloadLink);
            if(navigator.msSaveOrOpenBlob ){ navigator.msSaveOrOpenBlob(blob, filename+'.doc'); }
            else{ downloadLink.href = url; downloadLink.download = filename+'.doc'; downloadLink.click(); }
            document.body.removeChild(downloadLink);
            if (actionBtns) actionBtns.style.display = 'flex';
        }
    </script>
</body>
</html>