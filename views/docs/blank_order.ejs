<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Бланк Заказа №<%= order.doc_number %></title>
    <style>
        body { font-family: 'Times New Roman', Times, serif; padding: 40px; color: #000; max-width: 900px; margin: auto; font-size: 11pt; line-height: 1.3; }
        h2 { text-align: center; font-size: 14pt; font-weight: bold; margin-bottom: 25px; letter-spacing: 1px; }
        .info-block { margin-bottom: 25px; }
        .info-row { display: flex; margin-bottom: 6px; align-items: flex-end; }
        .info-label { width: 220px; font-weight: normal; }
        .info-value { flex-grow: 1; border-bottom: 1px solid #000; font-weight: bold; padding-left: 10px; }
        
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 11pt; }
        th, td { border: 1px solid #000; padding: 6px; text-align: center; }
        th { font-weight: normal; }
        .text-left { text-align: left; }
        .text-right { text-align: right; }
        .bold { font-weight: bold; }
        .footer-text { margin-top: 30px; font-size: 11pt; }
        
        /* Стили кнопок */
        .action-buttons { display: flex; gap: 10px; justify-content: flex-end; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px dashed #ccc; }
        .btn { padding: 10px 16px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; color: white; font-size: 13px; transition: 0.2s; }
        .btn-green { background: #10b981; } .btn-green:hover { background: #059669; }
        .btn-gray { background: #64748b; } .btn-gray:hover { background: #475569; }
        .btn-blue { background: #3b82f6; } .btn-blue:hover { background: #2563eb; }
        @media print { .no-print { display: none !important; } body { padding: 0; background: #fff; } }
    </style>
</head>
<body>
    <div class="action-buttons no-print">
        <button class="btn btn-blue" onclick="Export2Word('Бланк_Заказа_Плиттекс_№<%= order.doc_number %>')">📄 Сохранить в Word</button>
        <button class="btn btn-gray" onclick="saveAndPrint(false, 'Бланк_Заказа_<%= order.doc_number %>')">🖨️ Сохранить PDF</button>
    </div>

    <div id="doc-content">
        <h2>БЛАНК ИНДИВИДУАЛЬНОГО ЗАКАЗА</h2>
        
        <div class="info-block">
            <div class="info-row">
                <div class="info-label">Дата</div>
                <div class="info-value"><%= order.date_formatted %></div>
            </div>
            <div class="info-row">
                <div class="info-label">Заказчик:</div>
                <div class="info-value"><%= order.client_name %></div>
            </div>
            <div class="info-row">
                <div class="info-label">Адрес:</div>
                <div class="info-value"><%= order.legal_address || '' %></div>
            </div>
            <div class="info-row">
                <div class="info-label">Телефон:</div>
                <div class="info-value"><%= order.phone || '' %></div>
            </div>
            <div class="info-row">
                <div class="info-label">ИНН заказчика:</div>
                <div class="info-value"><%= order.inn || '' %></div>
            </div>
            <div class="info-row">
                <div class="info-label">ФИО представителя; тел.:</div>
                <div class="info-value"><%= order.director_name || '' %></div>
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th style="width: 5%;">№</th>
                    <th style="width: 48%;">Наименование продукции</th>
                    <th style="width: 10%;">Кол-во</th>
                    <th style="width: 10%;">Ед.изм</th>
                    <th style="width: 12%;">Цена</th>
                    <th style="width: 15%;">Сумма</th>
                </tr>
            </thead>
            <tbody>
                <% let totalAmount = 0; %>
                <% items.forEach(function(item, index) { %>
                    <% 
                        let qty = parseFloat(item.qty || item.quantity || 0);
                        let price = parseFloat(item.price || 0);
                        let sum = qty * price;
                        totalAmount += sum;
                    %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td class="text-left"><%= item.name || item.item_name %></td>
                        <td class="bold"><%= qty.toLocaleString('ru-RU') %></td>
                        <td><%= item.unit || 'шт' %></td>
                        <td class="text-right"><%= price.toLocaleString('ru-RU', {minimumFractionDigits: 2}) %></td>
                        <td class="text-right bold"><%= sum.toLocaleString('ru-RU', {minimumFractionDigits: 2}) %></td>
                    </tr>
                <% }); %>
                
                <% for(let i = items.length + 1; i <= Math.max(15, items.length); i++) { %>
                <tr>
                    <td><%= i %></td><td></td><td></td><td></td><td></td><td></td>
                </tr>
                <% } %>
                
                <% if (typeof discount !== 'undefined' && discount > 0) { %>
                    <% totalAmount = totalAmount * (1 - (discount/100)); %>
                    <tr>
                        <td colspan="5" class="text-right" style="border: none; padding-right: 15px;">Скидка:</td>
                        <td class="text-right"><%= discount %>%</td>
                    </tr>
                <% } %>
                <% if (typeof logistics !== 'undefined' && logistics > 0) { %>
                    <% totalAmount += parseFloat(logistics); %>
                    <tr>
                        <td colspan="5" class="text-right" style="border: none; padding-right: 15px;">Логистика:</td>
                        <td class="text-right"><%= parseFloat(logistics).toLocaleString('ru-RU', {minimumFractionDigits: 2}) %></td>
                    </tr>
                <% } %>

                <tr>
                    <td colspan="5" class="bold text-right" style="border: none; padding-right: 15px;">ИТОГО</td>
                    <td class="bold text-right" style="border: 2px solid #000;"><%= totalAmount.toLocaleString('ru-RU', {minimumFractionDigits: 2}) %></td>
                </tr>
                
                <% let vatAmount = (totalAmount * 22) / 122; %>
                <tr>
                    <td colspan="5" class="text-right" style="border: none; padding-right: 15px;">В том числе НДС 22%:</td>
                    <td class="text-right" style="border: none; font-size: 10pt;"><%= vatAmount.toLocaleString('ru-RU', {minimumFractionDigits: 2}) %></td>
                </tr>
            </tbody>
        </table>

        <div class="footer-text">
            <p>С заказом ознакомлен &nbsp;&nbsp;&nbsp;__________________________________________________________________</p>
            <p>Поддоны-возвратная тара __________________________________________________________________</p>
            <p style="font-size: 9pt; margin-top: 25px; text-align: justify; color: #444;">
                Допускаемые отклонения размеров плит и качества лицевой поверхности от ГОСТ 13330-2016, СП 82.13330.2016. Тон тротуарной плитки из разных партий может отличаться. Допускается потертость при транспортировке, образование "высолов", запыленность не могут являться претензией. Возврат продукции осуществляется при условии целостности заводской упаковки.
            </p>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        async function saveAndPrint(withStamp, docName) {
            const actionBtns = document.querySelector('.action-buttons');
            if (actionBtns) actionBtns.style.display = 'none';

            const element = document.getElementById('doc-content');
            const opt = { margin: [10, 10, 10, 10], filename: `${docName}_${Date.now()}.pdf`, image: { type: 'jpeg', quality: 0.98 }, html2canvas: { scale: 2, useCORS: true }, jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' } };

            try {
                const pdfBase64 = await html2pdf().set(opt).from(element).outputPdf('datauristring');
                await fetch('/api/docs/save-pdf', { method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ filename: opt.filename, fileData: pdfBase64 }) });
            } catch (error) { console.error("Ошибка:", error); }

            window.print();
            if (actionBtns) actionBtns.style.display = 'flex';
        }

        function Export2Word(filename = '') {
            const actionBtns = document.querySelector('.action-buttons');
            if (actionBtns) actionBtns.style.display = 'none';

            var preHtml = "<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'><head><meta charset='utf-8'><title>Export</title></head><body>";
            var postHtml = "</body></html>";
            var html = preHtml + document.getElementById('doc-content').innerHTML + postHtml;

            var blob = new Blob(['\\ufeff', html], { type: 'application/msword' });
            var url = 'data:application/vnd.ms-word;charset=utf-8,' + encodeURIComponent(html);
            var downloadLink = document.createElement("a");
            
            document.body.appendChild(downloadLink);
            if(navigator.msSaveOrOpenBlob ){ navigator.msSaveOrOpenBlob(blob, filename+'.doc'); }
            else{ downloadLink.href = url; downloadLink.download = filename+'.doc'; downloadLink.click(); }
            document.body.removeChild(downloadLink);
            if (actionBtns) actionBtns.style.display = 'flex';
        }
    </script>
</body>
</html>