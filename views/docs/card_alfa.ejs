<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Карточка предприятия - Альфа-Банк - ООО ПЛИТТЕКС</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            color: #1e293b;
            background-color: #e2e8f0;
            margin: 0;
            padding: 40px;
            display: flex;
            justify-content: center;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .page-a4 {
            background: #ffffff;
            width: 210mm;
            min-height: 297mm;
            padding: 20mm;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            box-sizing: border-box;
            position: relative;
        }

        /* Шапка */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 3px solid #3b82f6;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .logo-block {
            display: flex;
            flex-direction: column;
        }

        .logo-title {
            font-size: 32px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.5px;
            margin: 0;
        }

        .logo-subtitle {
            font-size: 13px;
            color: #64748b;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 5px;
        }

        .doc-title {
            text-align: right;
        }

        .doc-title h1 {
            font-size: 24px;
            color: #3b82f6;
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Контакты под шапкой (ОДНА СТРОКА) */
        .contact-bar {
            display: flex;
            gap: 30px;
            background: #f8fafc;
            padding: 15px 20px;
            border-radius: 8px;
            margin-bottom: 30px;
            font-size: 13px;
            font-weight: 500;
            color: #475569;
            border: 1px solid #e2e8f0;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Сетки данных */
        .section-title {
            font-size: 16px;
            font-weight: 700;
            color: #0f172a;
            margin: 0 0 15px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-title::before {
            content: '';
            display: block;
            width: 24px;
            height: 4px;
            background: #3b82f6;
            border-radius: 2px;
        }

        .data-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 40px;
        }

        .data-box {
            background: #ffffff;
        }

        .data-row {
            display: flex;
            padding: 12px 0;
            border-bottom: 1px solid #f1f5f9;
        }

        .data-row:last-child {
            border-bottom: none;
        }

        .data-label {
            width: 40%;
            font-size: 12px;
            color: #64748b;
            font-weight: 500;
        }

        .data-value {
            width: 60%;
            font-size: 13px;
            color: #0f172a;
            font-weight: 600;
        }

        /* 🔥 ФИРМЕННЫЙ КРАСНЫЙ БЛОК ДЛЯ АЛЬФА-БАНКА 🔥 */
        .bank-box {
            background: #fff1f2; /* Легкий красноватый фон */
            border: 1px solid #fecdd3; /* Красная рамка */
            padding: 20px;
            border-radius: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .bank-details {
            flex: 1;
            padding-right: 20px;
        }

        .bank-box .section-title::before {
            background: #e11d48; /* Акцентный красный */
        }

        .bank-box .data-row {
            border-bottom-color: #ffe4e6;
            padding: 10px 0;
        }

        .bank-box .data-label {
            color: #be123c;
            width: 48%; 
            font-size: 11px;
            letter-spacing: -0.2px;
        }

        .bank-box .data-value {
            color: #881337;
            font-size: 13.5px;
            width: 52%;
        }

        .highlight-account {
            font-size: 16px !important;
            font-weight: 800 !important;
            color: #9f1239 !important;
            letter-spacing: 1px;
        }

        /* QR-код в красном стиле */
        .qr-container {
            background: #ffffff;
            padding: 12px;
            border-radius: 8px;
            border: 2px solid #e11d48;
            display: flex;
            flex-direction: column;
            align-items: center;
            box-shadow: 0 4px 6px -1px rgba(225, 29, 72, 0.1);
            min-width: 120px;
        }

        .qr-title {
            font-size: 10px;
            font-weight: 700;
            color: #be123c;
            text-transform: uppercase;
            margin-bottom: 8px;
            text-align: center;
        }

        /* Подвал */
        .footer {
            margin-top: 40px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .signature-block {
            width: 300px;
        }

        .sign-line {
            border-bottom: 1px solid #1e293b;
            margin-bottom: 8px;
            height: 40px;
            position: relative;
        }

        .sign-text {
            font-size: 12px;
            color: #64748b;
            text-align: center;
        }

        /* Скрываем лишнее при печати */
        @media print {
            body { padding: 0; background: none; }
            .page-a4 { box-shadow: none; width: 100%; height: 100%; padding: 10mm; }
        }
    </style>
</head>
<body>

