                                    style="position: absolute; bottom: -8px; width: 100%;">(подпись)</span>
                            </div>
                            <div class="line-cell" style="width: 40%;">Марченко С.М. <span
                                    class="num-right-bracket">[10]</span><span class="sub-center"
                                    style="position: absolute; bottom: -8px; width: 100%;">(ф.и.о.)</span></div>
                        </div>

                        <div style="display: flex; margin-top: 15px;">
                            <div style="width: 140px;">Дата отгрузки, передачи (сдачи)</div>
                            <div class="line-cell text-center" style="flex-grow: 1;">
                                <%= date %> <span class="num-right-bracket">[11]</span>
                            </div>
                        </div>
                        <div style="display: flex; margin-top: 5px;">
                            <div style="width: 150px;">Иные сведения об отгрузке, передаче</div>
                            <div class="line-cell" style="flex-grow: 1;"><span class="num-right-bracket">[12]</span>
                            </div>
                        </div>

                        <div style="margin-top: 10px;">Ответственный за правильность оформления факта хозяйственной
                            жизни</div>
                        <div style="display: flex;">
                            <div class="line-cell" style="width: 30%;">Ген. директор<span class="sub-center"
                                    style="position: absolute; bottom: -8px; width: 100%;">(должность)</span></div>
                            <div class="line-cell" style="width: 30%; margin: 0 5px;">
                                <span class="sub-center"
                                    style="position: absolute; bottom: -8px; width: 100%;">(подпись)</span>
                            </div>
                            <div class="line-cell" style="width: 40%;">Марченко С.М. <span
                                    class="num-right-bracket">[13]</span><span class="sub-center"
                                    style="position: absolute; bottom: -8px; width: 100%;">(ф.и.о.)</span></div>
                        </div>
                        <div style="margin-top: 15px;">Наименование экономического субъекта – составителя документа
                        </div>
                        <div class="line-cell" style="width: 100%;">ООО "ПЛИТТЕКС", ИНН/КПП 2372029123/237201001 <span
                                class="num-right-bracket">[14]</span></div>
                    </td>

                    <td style="width: 4%; border-left: 1px solid #ccc;"></td>

                    <td style="width: 48%; padding-left: 10px;">
                        <div style="margin-bottom: 5px;">Товар (груз) получил / услуги, результаты работ, права принял
                        </div>
                        <div style="display: flex;">
                            <div class="line-cell" style="width: 30%;"><span class="sub-center"
                                    style="position: absolute; bottom: -8px; width: 100%;">(должность)</span></div>
                            <div class="line-cell" style="width: 30%; margin: 0 5px;"><span class="sub-center"
                                    style="position: absolute; bottom: -8px; width: 100%;">(подпись)</span></div>
                            <div class="line-cell" style="width: 40%;"><span class="num-right-bracket">[15]</span><span
                                    class="sub-center"
                                    style="position: absolute; bottom: -8px; width: 100%;">(ф.и.о.)</span></div>
                        </div>

                        <div style="display: flex; margin-top: 15px;">
                            <div style="width: 120px;">Дата получения (приемки)</div>
                            <div class="line-cell" style="flex-grow: 1;"><span class="num-right-bracket">[16]</span>
                            </div>
                        </div>
                        <div style="display: flex; margin-top: 5px;">
                            <div style="width: 150px;">Иные сведения о получении, приемке</div>
                            <div class="line-cell" style="flex-grow: 1;"><span class="num-right-bracket">[17]</span>
                            </div>
                        </div>

                        <div style="margin-top: 10px;">Ответственный за правильность оформления факта хозяйственной
                            жизни</div>
                        <div style="display: flex;">
                            <div class="line-cell" style="width: 30%;"><span class="sub-center"
                                    style="position: absolute; bottom: -8px; width: 100%;">(должность)</span></div>
                            <div class="line-cell" style="width: 30%; margin: 0 5px;"><span class="sub-center"
                                    style="position: absolute; bottom: -8px; width: 100%;">(подпись)</span></div>
                            <div class="line-cell" style="width: 40%;"><span class="num-right-bracket">[18]</span><span
                                    class="sub-center"
                                    style="position: absolute; bottom: -8px; width: 100%;">(ф.и.о.)</span></div>
                        </div>
                        <div style="margin-top: 15px;">Наименование экономического субъекта – составителя документа
                        </div>
                        <div class="line-cell" style="width: 100%;">
                            <%= clientName %>, ИНН/КПП <%= locals.cpInfo ? cpInfo.inn : '' %>/<%= locals.cpInfo ?
                                        cpInfo.kpp : '' %> <span class="num-right-bracket">[19]</span>
                        </div>
                    </td>
                </tr>
            </table>
        </div>

        <div class="pass-page">
            <div
                style="border: 3px solid #000; padding: 30px; border-radius: 10px; text-align: center; height: 100%; box-sizing: border-box;">
                <div style="font-size: 28pt; font-weight: 900; margin-bottom: 20px;">ПРОПУСК № <%=
                        docNum.replace(/[^0-9]/g, '' ) %>
                </div>
                <div style="font-size: 16pt; margin-bottom: 25px;">ООО "ПЛИТТЕКС" (Производственная база)</div>
                <div
                    style="font-size: 16pt; margin: 12px 0; border-bottom: 1px dashed #000; text-align: left; padding-bottom: 3px;">
                    <b>Дата отгрузки:</b>
                    <%= date %>
                </div>
                <div
                    style="font-size: 16pt; margin: 12px 0; border-bottom: 1px dashed #000; text-align: left; padding-bottom: 3px;">
                    <b>Клиент:</b>
                    <%= clientName %>
                </div>
                <div
                    style="font-size: 16pt; margin: 12px 0; border-bottom: 1px dashed #000; text-align: left; padding-bottom: 3px;">
                    <b>Транспорт:</b> <span style="font-size: 22pt; font-weight: bold;">
                        <%= locals.transportInfo || '________________' %>
                    </span></div>
                <div
                    style="font-size: 16pt; margin: 12px 0; border-bottom: 1px dashed #000; text-align: left; padding-bottom: 3px;">
                    <b>Всего мест:</b>
                    <%= totalQty %> <small style="font-size: 12pt; color: gray;">(в т.ч. тара: <%= locals.palletsQty ||
                                0 %> шт.)</small>
                </div>
                <div style="margin-top: 50px; display: flex; justify-content: space-between; font-size: 18pt;">
                    <div>Кладовщик: __________</div>
                    <div>Охрана: __________</div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        // Асинхронная функция генерации и сохранения PDF-документа
        async function saveAndPrint(withStamp, docName) {
            // Включаем или отключаем отображение печатей и подписей
            const overlays = document.querySelectorAll('.overlay-img');
            overlays.forEach(el => el.style.display = withStamp ? 'block' : 'none');

            // Скрываем панель с кнопками, чтобы она не попала в документ
            const actionBtns = document.querySelector('.action-buttons');
            if (actionBtns) actionBtns.style.display = 'none';

            // Задержка 150мс, чтобы браузер успел отрисовать наложенные картинки печатей
            await new Promise(resolve => setTimeout(resolve, 150));

            // Выбираем основной контейнер с документом
            const element = document.getElementById('doc-content');

            // Настройки для библиотеки html2pdf
            const opt = {
                margin: [5, 5, 5, 5],
                filename: `${docName}_${withStamp ? 'С_Печатью' : 'Без_Печати'}_${Date.now()}.pdf`,
                image: { type: 'jpeg', quality: 1.0 },
                html2canvas: { scale: 2, useCORS: true, allowTaint: true },
                // Базовый формат ставим landscape (УПД будет на весь лист)
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'landscape' },
                // Жестко приказываем библиотеке сделать разрыв страницы перед пропуском
                pagebreak: { mode: ['css', 'legacy'], before: '.pass-page' }
            };

            try {
                // Создаем PDF и переводим его в формат base64 для отправки
                const pdfBase64 = await html2pdf().set(opt).from(element).outputPdf('datauristring');

                // Получаем токен из локального хранилища браузера для прохождения авторизации
                const token = localStorage.getItem('token');

                // Отправляем файл на наш бэкенд (роутер docs.js)
                const response = await fetch('/api/docs/save-pdf', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({ filename: opt.filename, fileData: pdfBase64 })
                });

                // Проверяем успешность сохранения файла на сервере
                if (response.ok) {
                    console.log(`✅ Файл ${opt.filename} успешно сохранен в public/saved_docs`);
                } else {
                    const errText = await response.text();
                    console.error('❌ Ошибка сервера при сохранении ПДФ:', errText);
                }
            } catch (e) {
                console.error('❌ Ошибка генерации ПДФ:', e);
            }

            // Вызываем системное окно печати браузера
            window.print();

            // Возвращаем панель с кнопками обратно на экран
            if (actionBtns) actionBtns.style.display = 'flex';
        }

        function Export2Word(filename) {
            const overlays = document.querySelectorAll('.overlay-img');
            overlays.forEach(el => el.style.display = 'none');
            const content = document.getElementById('doc-content').innerHTML;
            const blob = new Blob(['\ufeff', content], { type: 'application/msword' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url; link.download = filename + '.doc'; link.click();
        }
    </script>
</body>

</html>