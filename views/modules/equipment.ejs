<div id="equipment-mod" class="module">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2>⚙️ Оборудование и Матрицы</h2>
        <button class="btn btn-blue" onclick="openEquipmentModal()">➕ Добавить оборудование</button>
    </div>

    <div style="margin-bottom: 20px; display: flex; gap: 10px; overflow-x: auto; padding-bottom: 5px;">
        <button class="btn btn-outline" onclick="filterEquipment('all')" id="filter-eq-all"
            style="background: var(--primary); color: white;">Все</button>
        <button class="btn btn-outline" onclick="filterEquipment('machine')" id="filter-eq-machine">Станки и
            Прессы</button>
        <button class="btn btn-outline" onclick="filterEquipment('mold')" id="filter-eq-mold">Матрицы</button>
        <button class="btn btn-outline" onclick="filterEquipment('pallets')" id="filter-eq-pallets">Поддоны</button>
        <button class="btn btn-outline" onclick="filterEquipment('vehicle')" id="filter-eq-vehicle">Транспорт</button>
    </div>
    <div id="eq-alerts-container" style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px;"></div>
    <div class="card" style="border-top: 4px solid var(--primary);">
        <div class="table-container">
            <table>
                <thead style="background: #f8fafc;">
                    <tr>
                        <th style="width: 50px;">ID</th>
                        <th>Название и Тип</th>
                        <th style="text-align: right;">Стоимость (₽)</th>
                        <th style="text-align: right;">Амортизация</th>
                        <th>Ресурс (Факт / План)</th>
                        <th style="text-align: center;">Статус</th>
                        <th style="text-align: right;">Действия</th>
                    </tr>
                </thead>
                <tbody id="equipment-table">
                    <tr>
                        <td colspan="7" style="text-align: center; color: var(--text-muted); padding: 20px;">Загрузка
                            данных...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div id="equipment-modal"
        style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
        <div
            style="background: #fff; padding: 20px; border-radius: 8px; width: 450px; max-width: 95%; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">

            <h3 id="eq-modal-title"
                style="margin-top: 0; color: var(--text-main); border-bottom: 1px solid var(--border); padding-bottom: 10px;">
                Добавить оборудование
            </h3>

            <input type="hidden" id="eq-id">

            <div class="form-group">
                <label>Название (Например: Матрица Квадрат 200х200):</label>
                <input type="text" id="eq-name" class="input-modern" placeholder="Введите название">
            </div>

            <div class="form-group">
                <label>Категория / Тип:</label>
                <select id="eq-type" class="input-modern">
                    <option value="machine">🏭 Станок / Вибропресс</option>
                    <option value="mold">🗜️ Матрица / Пуансон</option>
                    <option value="pallets">🪵 Технологические поддоны</option>
                    <option value="vehicle">🚜 Транспорт / Спецтехника</option>
                    <option value="tools">🛠️ Ручной инструмент</option>
                </select>
            </div>

            <div class="form-grid" style="grid-template-columns: 1fr 1fr 1fr; gap: 15px;">
                <div class="form-group">
                    <label>Стоимость (₽):</label>
                    <input type="number" id="eq-cost" class="input-modern" placeholder="0" onfocus="this.select()">
                </div>
                <div class="form-group">
                    <label>Плановый ресурс:</label>
                    <input type="number" id="eq-planned-cycles" class="input-modern" placeholder="100000"
                        onfocus="this.select()">
                </div>
                <div class="form-group">
                    <label>Факт (износ):</label>
                    <input type="number" id="eq-current-cycles" class="input-modern" placeholder="0"
                        onfocus="this.select()">
                </div>
            </div>
            <small style="display: block; color: var(--text-muted); margin-bottom: 15px; font-size: 11px;">
                *Ресурс указывается в ударах (циклах) для расчета амортизации.
            </small>

            <div class="form-group" id="eq-qty-group">
                <label>Выход за 1 формовку (м²/шт):</label>
                <input type="number" id="eq-qty-per-cycle" class="input-modern" step="0.001" placeholder="0.8">
            </div>

            <div class="form-group">
                <label>Текущий статус:</label>
                <select id="eq-status" class="input-modern">
                    <option value="active">🟢 В работе</option>
                    <option value="repair">🟠 На ремонте / обслуживании</option>
                    <option value="written_off">🔴 Списано</option>
                </select>
            </div>

            <div
                style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border); padding-top: 15px; margin-top: 10px;">
                <button class="btn btn-outline"
                    onclick="document.getElementById('equipment-modal').style.display='none'">Отмена</button>
                <button class="btn btn-green" onclick="saveEquipment()">💾 Сохранить</button>
            </div>
        </div>
    </div>
    <div id="maintenance-modal"
        style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
        <div
            style="background: #fff; padding: 20px; border-radius: 8px; width: 450px; max-width: 95%; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
            <h3
                style="margin-top: 0; color: var(--text-main); border-bottom: 1px solid var(--border); padding-bottom: 10px;">
                🛠️ Проведение ТО или Ремонта
            </h3>
            <p id="maint-eq-name" style="font-weight: bold; color: var(--primary); margin-bottom: 15px;"></p>
            <input type="hidden" id="maint-eq-id">

            <div class="form-group">
                <label>Описание работ / запчастей:</label>
                <input type="text" id="maint-desc" class="input-modern" placeholder="Например: Замена масла, сварка...">
            </div>
            <div class="form-group">
                <label>Стоимость ремонта (₽):</label>
                <input type="number" id="maint-cost" class="input-modern" placeholder="0">
            </div>
            <div class="form-group">
                <label>Списать средства со счета:</label>
                <select id="maint-account" class="input-modern">
                    <option value="">-- Бесплатно (Без списания) --</option>
                </select>
            </div>
            <div class="form-group"
                style="display: flex; align-items: center; gap: 10px; background: #fef2f2; padding: 10px; border-radius: 6px; border: 1px solid #fecaca;">
                <input type="checkbox" id="maint-reset" style="width: 20px; height: 20px;">
                <label for="maint-reset" style="color: #991b1b; margin: 0; cursor: pointer;">
                    <b>Обнулить счетчик износа</b><br>
                    <small>(Только если проведена полная реставрация матрицы или капремонт)</small>
                </label>
            </div>

            <div
                style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border); padding-top: 15px; margin-top: 15px;">
                <button class="btn btn-outline"
                    onclick="document.getElementById('maintenance-modal').style.display='none'">Отмена</button>
                <button class="btn btn-blue" onclick="saveMaintenance()">✅ Сохранить ТО</button>
            </div>
        </div>
    </div>
</div>