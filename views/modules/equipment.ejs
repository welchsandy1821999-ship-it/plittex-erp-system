<div id="equipment-mod" class="module">
    <div class="flex-between mb-20">
        <h2 class="mt-0">⚙️ Оборудование и Матрицы</h2>
        <button class="btn btn-blue" onclick="openEquipmentModal()">➕ Добавить оборудование</button>
    </div>

    <div class="toolbar-group mb-20">
        <button class="btn btn-outline active" onclick="filterEquipment('all', this)" id="filter-eq-all">Все</button>
        <button class="btn btn-outline" onclick="filterEquipment('machine', this)" id="filter-eq-machine">Станки и Прессы</button>
        <button class="btn btn-outline" onclick="filterEquipment('mold', this)" id="filter-eq-mold">Матрицы</button>
        <button class="btn btn-outline" onclick="filterEquipment('pallets', this)" id="filter-eq-pallets">Поддоны</button>
        <button class="btn btn-outline" onclick="filterEquipment('vehicle', this)" id="filter-eq-vehicle">Транспорт</button>
    </div>

    <div id="eq-alerts-container" class="flex-column gap-10 mb-20"></div>

    <div class="card" style="border-top: 4px solid var(--primary); padding: 0;">
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th style="width: 50px;">ID</th>
                        <th>Название и Тип</th>
                        <th class="text-right">Стоимость (₽)</th>
                        <th class="text-right">Амортизация</th>
                        <th style="width: 220px;">Ресурс (Факт / План)</th>
                        <th class="text-center">Статус</th>
                        <th class="text-right">Действия</th>
                    </tr>
                </thead>
                <tbody id="equipment-table">
                    <tr>
                        <td colspan="7" class="text-center text-muted" style="padding: 30px;">
                            Загрузка данных...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
<!-- Модуль equipment-mod завершен. Далее глобальные модалки оборудования -->

    <div id="equipment-modal" class="modal-overlay d-none">
        <div class="modal-content" style="max-width: 500px;">
            <div class="modal-header">
                <span id="eq-modal-title">Добавить оборудование</span>
                <button class="btn-close" onclick="UI.closeModal('equipment-modal')">×</button>
            </div>
            
            <div class="modal-body">
                <input type="hidden" id="eq-id">

                <div class="form-group mb-15">
                    <label>Название (Например: Матрица Квадрат 200х200):</label>
                    <input type="text" id="eq-name" class="input-modern" placeholder="Введите название">
                </div>

                <div class="form-group mb-15">
                    <label>Категория / Тип:</label>
                    <select id="eq-type" class="input-modern">
                        <option value="machine">🏭 Станок / Вибропресс</option>
                        <option value="mold">🗜️ Матрица / Пуансон</option>
                        <option value="pallets">🪵 Технологические поддоны</option>
                        <option value="vehicle">🚜 Транспорт / Спецтехника</option>
                        <option value="tools">🛠️ Ручной инструмент</option>
                    </select>
                </div>

                <div class="form-grid mb-10" style="grid-template-columns: 1fr 1fr 1fr;">
                    <div class="form-group">
                        <label>Стоимость (₽):</label>
                        <input type="number" id="eq-cost" class="input-modern" placeholder="0" onfocus="this.select()">
                    </div>
                    <div class="form-group">
                        <label>План ресурс:</label>
                        <input type="number" id="eq-planned-cycles" class="input-modern" placeholder="100000" onfocus="this.select()">
                    </div>
                    <div class="form-group">
                        <label>Факт (износ):</label>
                        <input type="number" id="eq-current-cycles" class="input-modern" placeholder="0" onfocus="this.select()">
                    </div>
                </div>
                <p class="text-muted" style="font-size: 11px; margin-bottom: 15px;">*Ресурс в ударах/циклах для расчета амортизации.</p>

                <div class="form-group mb-15" id="eq-qty-group">
                    <label>Выход за 1 формовку (м²/шт):</label>
                    <input type="number" id="eq-qty-per-cycle" class="input-modern" step="0.001" placeholder="0.8">
                </div>

                <div class="form-group">
                    <label>Текущий статус:</label>
                    <select id="eq-status" class="input-modern">
                        <option value="active">🟢 В работе</option>
                        <option value="repair">🟠 На ремонте</option>
                        <option value="written_off">🔴 Списано</option>
                    </select>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-outline" onclick="UI.closeModal('equipment-modal')">Отмена</button>
                <button class="btn btn-blue" onclick="saveEquipment()">💾 Сохранить</button>
            </div>
        </div>
    </div>

    <div id="maintenance-modal" class="modal-overlay d-none">
        <div class="modal-content" style="max-width: 450px;">
            <div class="modal-header">
                <span id="maint-title-header">🛠️ Проведение ТО или Ремонта</span>
                <button class="btn-close" onclick="UI.closeModal('maintenance-modal')">×</button>
            </div>
            
            <div class="modal-body">
                <p id="maint-eq-name" style="font-weight: bold; color: var(--primary); margin-bottom: 15px;"></p>
                <input type="hidden" id="maint-eq-id">

                <div class="form-group mb-15">
                    <label>Описание работ / запчастей:</label>
                    <input type="text" id="maint-desc" class="input-modern" placeholder="Например: Замена масла, сварка...">
                </div>
                <div class="form-group mb-15">
                    <label>Стоимость ремонта (₽):</label>
                    <input type="number" id="maint-cost" class="input-modern" placeholder="0">
                </div>
                <div class="form-group mb-15">
                    <label>Списать средства со счета:</label>
                    <select id="maint-account" class="input-modern">
                        <option value="">-- Бесплатно --</option>
                    </select>
                </div>
                <div class="form-group" style="display: flex; align-items: center; gap: 10px; background: var(--danger-bg); padding: 12px; border-radius: 8px; border: 1px solid var(--danger-border);">
                    <input type="checkbox" id="maint-reset" style="width: 20px; height: 20px; cursor: pointer;">
                    <label for="maint-reset" style="color: var(--danger-text); margin: 0; cursor: pointer; font-size: 13px;">
                        <b>Обнулить счетчик износа</b><br>
                        <small>(Если была реставрация или капремонт)</small>
                    </label>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-outline" onclick="UI.closeModal('maintenance-modal')">Отмена</button>
                <button class="btn btn-blue" onclick="saveEquipmentMaintenance()">✅ Сохранить ТО</button>
            </div>
        </div>
    </div>