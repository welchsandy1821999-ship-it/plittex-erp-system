<div id="fin-mod" class="module">
    <div class="flex-between mb-20" style="align-items: flex-end;">
        <div>
            <h2 class="mt-0 mb-0">💰 Финансы и Касса</h2>
            <p class="text-muted mt-0" style="font-size: 13px;">Учет доходов, расходов и общая аналитика</p>
        </div>

        <div class="finance-toolbar">
            <label style="font-weight: bold; font-size: 13px; color: var(--text-muted);">Период:</label>
            <div style="display: flex; gap: 5px;">
                <button class="btn btn-outline btn-sm" onclick="setFinanceDateRange('today')">Сегодня</button>
                <button class="btn btn-outline btn-sm" onclick="setFinanceDateRange('week')">Неделя</button>
                <button class="btn btn-outline btn-sm" onclick="setFinanceDateRange('month')">Месяц</button>
                <button class="btn btn-outline btn-sm" onclick="setFinanceDateRange('year')">Год</button>
            </div>
            <input type="text" id="finance-date-filter" class="input-modern"
                style="width: 190px; cursor: pointer; font-size: 13px; background: var(--surface-alt);"
                placeholder="Произвольный...">
            <button class="btn btn-outline text-danger" onclick="resetFinanceFilter()">✖ Сброс</button>
        </div>
    </div>

    <div class="account-grid" id="accounts-container"></div>
    <div class="summary-grid mb-20" id="finance-summary-boxes"></div>

    <div id="cashflow-widget" class="mb-20"></div>
    <div id="tax-widget-container" class="mb-20"></div>

    <div class="card mb-20">
        <div class="flex-between mb-15">
            <h3 class="mt-0 mb-0" style="font-size: 16px;">💰 Прибыль по последним отгрузкам</h3>
            <span class="text-muted" style="font-size: 11px;">Маржа = (Выручка - Себестоимость материалов)</span>
        </div>
        <div id="profit-analysis-container"></div>
    </div>

    <div class="form-grid" style="grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 25px;">
        <div class="card mb-0">
            <h4 class="mt-0 mb-15 text-muted" style="font-size: 14px;">Динамика денежных потоков</h4>
            <div style="height: 250px;"><canvas id="chart-finance-flow"></canvas></div>
        </div>
        <div class="card mb-0">
            <h4 class="mt-0 mb-15 text-muted" style="font-size: 14px;">Статьи расходов</h4>
            <div style="height: 250px;"><canvas id="chart-finance-categories"></canvas></div>
        </div>
    </div>

    <div class="flex-between mb-20">
        <div class="toolbar-group">
            <button class="btn btn-blue" onclick="openTransactionModal()">➕ Добавить операцию</button>
            <button class="btn btn-outline btn-outline-primary" onclick="openTransferModal()">🔄 Перевод</button>
            <button class="btn btn-gray" onclick="openBankImportModal()">🏦 Выписка (1С)</button> <button
                class="btn btn-outline btn-outline-success" onclick="exportFinanceToExcel()">📥 в Excel</button>
            <button class="btn btn-outline btn-outline-info" onclick="openPnlReportModal()">📊 Отчет P&L</button>
            <button class="btn btn-outline text-warning" style="font-weight: bold;"
                onclick="openPaymentCalendarModal()">📅 План платежей</button>
            <button class="btn btn-outline text-muted" onclick="openLockModal()">🔒 Закрыть период</button>
        </div>
        <div class="toolbar-group">
            <button class="btn btn-outline" onclick="openCounterpartiesModal()">👥 Контрагенты</button>
            <button class="btn btn-outline" onclick="openCategoriesModal()">⚙️ Статьи ДДС</button>
        </div>
    </div>

    <div id="invoices-container" class="mb-25" style="display: none;">
        <h3 class="mt-0 mb-10 text-main" style="font-size: 16px;">🟡 Ожидаемые платежи (Счета)</h3>
        <div class="table-container invoice-alert-row">
            <table id="invoices-table">
                <thead>
                    <tr>
                        <th width="10%">Дата</th>
                        <th width="10%">№ Счета</th>
                        <th width="25%">Клиент</th>
                        <th width="25%">Назначение</th>
                        <th width="15%" class="text-right">Сумма (₽)</th>
                        <th width="15%" class="text-center">Действие</th>
                    </tr>
                </thead>
                <tbody id="invoices-table-body"></tbody>
            </table>
        </div>
    </div>

    <div id="bulk-actions-panel" class="bulk-panel" style="display: none;">
        <div style="font-weight: bold; color: var(--danger-text);">Выбрано платежей: <span
                id="bulk-selected-count">0</span></div>
        <button class="btn btn-red" onclick="executeBulkDelete()">🗑️ Удалить выбранные</button>
    </div>

    <div class="flex-between mb-15">
        <h3 class="mt-0 mb-0 text-main" style="font-size: 16px;">📋 История операций</h3>
        <input type="text" id="finance-search" class="input-modern" style="width: 350px;" placeholder="🔍 Поиск..."
            oninput="triggerFinanceSearch()">
    </div>

    <div class="toolbar-group mb-15 card-alt" style="padding: 10px;">
        <button id="tab-type-all" class="btn btn-blue type-tab-btn" onclick="setTransTypeFilter('all')">📋 Все
            операции</button>
        <button id="tab-type-income" class="btn btn-outline btn-outline-success type-tab-btn"
            onclick="setTransTypeFilter('income')">🟢 Доходы</button>
        <button id="tab-type-expense" class="btn btn-outline btn-outline-danger type-tab-btn"
            onclick="setTransTypeFilter('expense')">🔴 Расходы</button>
    </div>

    <div class="table-container">
        <table id="transactions-table" style="table-layout: fixed; word-break: break-word;">
            <thead>
                <tr>
                    <th style="width: 4%; text-align: center;"><input type="checkbox" id="selectAllCheckbox"
                            onchange="toggleSelectAll(this)"></th>
                    <th style="width: 12%;">Дата и Время</th>
                    <th style="width: 9%;">Тип</th>
                    <th style="width: 20%;">Контрагент / Категория</th>
                    <th style="width: 25%;">Основание</th>
                    <th style="width: 15%;">Способ оплаты</th>
                    <th style="width: 10%;" class="text-right">Сумма (₽)</th>
                    <th style="width: 8%; text-align: center;">⚙️</th>
                </tr>
            </thead>
            <tbody id="transactions-table-body"></tbody>
        </table>
    </div>

    <div class="flex-between mt-15 card-alt" style="padding: 10px;">
        <button id="finance-btn-prev" class="btn btn-outline btn-sm" onclick="changeFinancePage(-1)">⬅ Назад</button>
        <div class="toolbar-group">
            <span class="text-main" style="font-weight: bold;" id="finance-page-info">Страница 1 из 1</span>
            <div style="display: flex; align-items: center; gap: 5px;">
                <span class="text-muted" style="font-size: 12px;">По:</span>
                <select id="finance-limit" class="input-modern" style="padding: 2px 5px; min-height: 30px; width: 70px;"
                    onchange="changeFinanceLimit()">
                    <option value="20">20</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </div>
        </div>
        <button id="finance-btn-next" class="btn btn-outline btn-sm" onclick="changeFinancePage(1)">Вперед ➡</button>
    </div>
</div>