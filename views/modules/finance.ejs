<div id="fin-mod" class="module">
    <div class="flex-between align-end mb-20">
        <div>
            <h2 class="mt-0 mb-0">💰 Финансы и Касса</h2>
            <div class="flex-row gap-10 mt-10">
                <button id="fin-tab-ops" class="btn btn-blue" onclick="switchFinanceTab('ops')">📊 Операции</button>
                <button id="fin-tab-dict" class="btn btn-outline" onclick="switchFinanceTab('dict')">⚙️ Справочник ДДС</button>
            </div>
        </div>

        <div class="finance-toolbar flex-row align-center">
            <label class="font-bold font-13 text-muted mr-10">Период:</label>
            <div id="global-finance-calendar" class="finance-period-selector flex-row gap-10"></div>
            <button class="btn btn-outline text-danger ml-10" onclick="resetFinanceFilter()">✖ Сброс</button>
        </div>
    </div>

    <div id="fin-view-ops">
    <div class="account-grid" id="accounts-container"></div>
    <div class="summary-grid mb-20" id="finance-summary-boxes"></div>

    <div id="cashflow-widget" class="mb-20"></div>
    <div id="tax-widget-container" class="mb-20"></div>

    <div class="card mb-20 p-0 overflow-hidden">
        <div class="p-15 cursor-pointer flex-between align-center bg-surface-hover"
            onclick="const profitContainer=document.getElementById('profit-analysis-container'); const profitIcon=this.querySelector('.acc-icon'); profitContainer.classList.toggle('d-none'); profitIcon.innerText=profitContainer.classList.contains('d-none')?'▼ РАСКРЫТЬ':'▲ СВЕРНУТЬ';">
            <div>
                <h3 class="m-0 text-main font-16">💰 Прибыль по последним отгрузкам</h3>
                <span class="text-muted font-11">Маржа = (Выручка - Себестоимость материалов)</span>
            </div>
            <div class="text-muted font-11 font-bold acc-icon user-select-none">▼ РАСКРЫТЬ</div>
        </div>
        <div id="profit-analysis-container" class="d-none border-top p-15"></div>
    </div>

    <div class="form-grid finance-charts-grid">
        <div class="card mb-0">
            <h4 class="mt-0 mb-15 text-muted font-14">Динамика денежных потоков</h4>
            <div class="finance-chart-container"><canvas id="chart-finance-flow"></canvas></div>
        </div>
        <div class="card mb-0">
            <h4 class="mt-0 mb-15 text-muted font-14">Статьи расходов</h4>
            <div class="finance-chart-container"><canvas id="chart-finance-categories"></canvas></div>
        </div>
    </div>

    <div class="flex-between mb-20">
        <div class="toolbar-group">
            <button class="btn btn-blue" onclick="openTransactionModal()">➕ Добавить операцию</button>
            <button class="btn btn-outline btn-outline-primary" onclick="openTransferModal()">🔄 Перевод</button>
            <button class="btn btn-gray" onclick="openBankImportModal()">🏦 Выписка (1С)</button>
            <button class="btn btn-outline btn-outline-success" onclick="exportFinanceToExcel()">📥 в Excel</button>
            <button class="btn btn-outline btn-outline-info" onclick="openPnlReportModal()">📊 Отчет P&L</button>
            <button class="btn btn-outline text-warning font-bold" onclick="openPaymentCalendarModal()">📅 План
                платежей</button>
            <button class="btn btn-outline text-muted" onclick="openLockModal()">🔒 Закрыть период</button>
        </div>
        <div class="toolbar-group">
            <button class="btn btn-outline" onclick="openCounterpartiesModal()">👥 Контрагенты</button>
            
        </div>
    </div>

    <div id="invoices-container" class="finance-invoices-wrap card mb-20 p-0 d-none overflow-hidden">
        <div class="p-15 cursor-pointer flex-between align-center bg-surface-hover"
            onclick="const invBody=document.getElementById('invoices-body'); const invIcon=this.querySelector('.acc-icon'); invBody.classList.toggle('d-none'); invIcon.innerText=invBody.classList.contains('d-none')?'▼ РАСКРЫТЬ':'▲ СВЕРНУТЬ';">
            <h3 class="m-0 text-main font-16">🟡 Ожидаемые платежи (Счета и Заказы)</h3>
            <div class="text-muted font-11 font-bold acc-icon user-select-none">▼ РАСКРЫТЬ</div>
        </div>

        <div id="invoices-body" class="d-none p-15 border-top">
            <div class="table-container flat invoice-alert-row m-0">
                <table id="invoices-table" class="w-100">
                    <thead class="bg-surface-alt">
                        <tr>
                            <th class="w-10 p-10 text-left">Дата</th>
                            <th class="w-10 p-10 text-left">№ Документа</th>
                            <th class="w-25 p-10 text-left">Клиент</th>
                            <th class="w-25 p-10 text-left">Назначение</th>
                            <th class="w-15 p-10 text-right">Сумма (₽)</th>
                            <th class="w-15 p-10 text-center">Действие</th>
                        </tr>
                    </thead>
                    <tbody id="invoices-table-body"></tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="bulk-actions-panel" class="bulk-panel d-none">
        <div class="font-bold text-danger">Выбрано платежей: <span id="bulk-selected-count">0</span></div>
        <button class="btn btn-red" onclick="executeBulkDelete()">🗑️ Удалить выбранные</button>
    </div>

    <div class="flex-between mb-15">
        <h3 class="mt-0 mb-0 text-main font-16">📋 История операций</h3>
        <input type="text" id="finance-search" class="input-modern finance-search-input" placeholder="🔍 Поиск..."
            oninput="triggerFinanceSearch()">
    </div>

    <!-- Инфо-панель при активном поиске / фильтрации -->
    <div id="finance-summary-bar" class="mb-15 finance-summary-bar d-none">
        <div class="flex-row gap-15 align-center flex-wrap">
            <span class="font-14 text-main">🔍 Фильтр: <b id="summary-filter-name" class="text-primary"></b></span>
            <div id="summary-date-picker-placeholder" class="finance-period-selector flex-row gap-10"></div>
            <span class="finance-summary-count">Найдено операций: <b id="summary-filter-count"
                    class="text-main">0</b></span>
            <span class="font-14 text-main">Сумма (на стр.): <b id="summary-filter-sum" class="text-main">0 ₽</b></span>
        </div>
        <button class="btn btn-outline btn-sm text-danger finance-btn-reset" onclick="window.resetFinanceSummary()">✖
            Сбросить фильтр</button>
    </div>

    <div class="toolbar-group mb-15 card-alt p-10">
        <button id="tab-type-all" class="btn btn-blue type-tab-btn" onclick="setTransTypeFilter('all')">📋 Все
            операции</button>
        <button id="tab-type-income" class="btn btn-outline btn-outline-success type-tab-btn"
            onclick="setTransTypeFilter('income')">🟢 Доходы</button>
        <button id="tab-type-expense" class="btn btn-outline btn-outline-danger type-tab-btn"
            onclick="setTransTypeFilter('expense')">🔴 Расходы</button>
    </div>

    <div class="table-container">
        <table id="transactions-table" class="finance-table">
            <thead>
                <tr>
                    <th class="w-4 text-center"><input type="checkbox" id="selectAllCheckbox"
                            onchange="toggleSelectAll(this)"></th>
                    <th class="w-12">Дата и Время</th>
                    <th class="w-9">Тип</th>
                    <th class="w-20">Контрагент / Категория</th>
                    <th class="w-25">Основание</th>
                    <th class="w-15">Способ оплаты</th>
                    <th class="w-10 text-right">Сумма (₽)</th>
                    <th class="w-8 text-center">⚙️</th>
                </tr>
            </thead>
            <tbody id="transactions-table-body"></tbody>
        </table>
    </div>

    <div class="flex-between mt-15 card-alt p-10">
        <button id="finance-btn-prev" class="btn btn-outline btn-sm" onclick="changeFinancePage(-1)">⬅ Назад</button>
        <div class="toolbar-group">
            <span class="text-main font-bold" id="finance-page-info">Страница 1 из 1</span>
            <div class="flex-row align-center gap-5">
                <span class="text-muted font-12">По:</span>
                <select id="finance-limit" class="input-modern finance-limit-select" onchange="changeFinanceLimit()">
                    <option value="20">20</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </div>
        </div>
        <button id="finance-btn-next" class="btn btn-outline btn-sm" onclick="changeFinancePage(1)">Вперед ➡</button>
    </div>

    </div> <!-- end of fin-view-ops -->

    <!-- СПРАВОЧНИК ДДС ВИД (DICTIONARY VIEW) -->
    <div id="fin-view-dict" class="d-none">
        <div class="flex-between mb-20">
            <h3 class="m-0">Управление статьями доходов и расходов</h3>
            <div class="toolbar-group">
                <button class="btn btn-outline text-warning" onclick="openCategoryMergeModal()">🖇️ Объединить дубликаты</button>
                <button class="btn btn-outline border-warning text-warning" onclick="openOrphansModal()">⚠️ Обезличенные</button>
                <button class="btn btn-blue" onclick="openCategoryEditModal()">➕ Добавить статью</button>
            </div>
        </div>

        <div class="toolbar-group mb-15 card-alt p-10">
            <button id="dict-tab-type-all" class="btn btn-blue dict-type-btn" onclick="setDictTypeFilter('all')">📋 Все статьи</button>
            <button id="dict-tab-type-income" class="btn btn-outline btn-outline-success dict-type-btn" onclick="setDictTypeFilter('income')">🟢 Доходы</button>
            <button id="dict-tab-type-expense" class="btn btn-outline btn-outline-danger dict-type-btn" onclick="setDictTypeFilter('expense')">🔴 Расходы</button>
        </div>

        <div class="card p-0 overflow-hidden">
            <table class="finance-table w-100" id="fin-dict-table">
                <thead class="bg-surface-alt">
                    <tr>
                        <th class="w-5 text-center"><input type="checkbox" id="finCatSelectAll" onchange="toggleSelectAllCategories(this)"></th>
                        <th class="text-left w-30">Название статьи</th>
                        <th class="text-center w-15">Направление</th>
                        <th class="text-center w-15">Тип затрат</th>
                        <th class="text-right w-15">Лимит (мес)</th>
                        <th class="text-center w-10">Статус</th>
                        <th class="text-center w-10">⚙️</th>
                    </tr>
                </thead>
                <tbody id="fin-dict-tbody">
                    <!-- Загружается через JS -->
                </tbody>
            </table>
        </div>
    </div> <!-- end of fin-view-dict -->
</div>
