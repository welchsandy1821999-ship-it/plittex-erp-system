<div id="stock-mod" class="module">
    <div class="flex-between mb-20">
        <div>
            <h2 class="mt-0 mb-0">📦 Склад и Остатки</h2>
            <p class="text-muted font-14 mt-5 mb-0">Контроль запасов сырья, сушилки и готовой продукции</p>
        </div>
        <div class="flex-row gap-10 align-center">
            <button class="btn btn-green inv-hidden" id="btn-audit-save" onclick="saveAudit()">💾 Сохранить факт</button>
            <button class="btn btn-outline" id="btn-audit-mode" onclick="toggleAuditMode()">📋 Инвентаризация</button>
            <button class="btn btn-blue" onclick="loadTable()">🔄 Обновить остатки</button>
        </div>
    </div>

    <div class="inv-filter-panel">
        <button class="btn btn-outline filter-btn active" onclick="applyWarehouseFilter('all', this)">🌐 Все склады</button>
        <button class="btn btn-outline filter-btn" onclick="applyWarehouseFilter('1', this)">Склад №1 (Сырье)</button>
        <button class="btn btn-outline filter-btn" onclick="applyWarehouseFilter('3', this)">Склад №3 (Сушилка)</button>
        <button class="btn btn-outline filter-btn" onclick="applyWarehouseFilter('4', this)">Склад №4 (Готовая продукция)</button>
        <button class="btn btn-outline filter-btn" onclick="applyWarehouseFilter('5', this)">Склад №5 (Уценка и Брак)</button>
        <button class="btn btn-outline filter-btn" onclick="applyWarehouseFilter('6', this)">Склад №6 (Утиль)</button>
        <button class="btn btn-outline filter-btn inv-reserve-btn" onclick="applyWarehouseFilter('7', this)">🔒 Склад №7 (Резервы)</button>
    </div>

    <div class="card inv-stock-card p-0">
        <div class="table-container">
            <table class="table-modern w-100">
                <thead class="bg-surface-alt" id="inventory-thead">
                    <tr>
                        <th class="inv-col-wh p-10 text-left text-muted font-12" style="text-transform: uppercase;">Склад</th>
                        <th class="inv-col-batch p-10 text-left text-muted font-12" style="text-transform: uppercase;">№ Партии</th>
                        <th class="inv-col-name p-10 text-left text-muted font-12" style="text-transform: uppercase;">Наименование (Сырье / Продукция)</th>
                        <th class="inv-col-qty p-10 text-right text-muted font-12" style="text-transform: uppercase;">Остаток</th>
                        <th class="inv-col-unit p-10 text-left text-muted font-12" style="text-transform: uppercase;">Ед. изм.</th>
                        <th class="inv-col-actions p-10 text-right text-muted font-12" style="text-transform: uppercase;">Действия</th>
                    </tr>
                </thead>
                <tbody id="inventory-table">
                    <tr>
                        <td colspan="6" class="text-center p-20 text-muted" style="font-style: italic;">
                            Загрузка остатков...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>