<div id="stock-mod" class="module">
    <style>
        @media print {
            body { background: white; }
            .sidebar, .top-header, .inv-filter-panel, #inventory-search, .card-header .btn, .inv-actions-cell, .table-container .flex-between { display: none !important; }
            .module { padding: 0; margin: 0; top: 0; left: 0; position: absolute; width: 100%; box-shadow: none; border: none; }
            .inv-stock-card { box-shadow: none; border: none; }
            table, th, td { border: 1px solid #ccc !important; }
            * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        }
    </style>
    <div class="flex-between mb-20 items-end">
        <div>
            <h2 class="mt-0 mb-0">📦 Склад и Остатки</h2>
            <p class="text-muted font-14 mt-5 mb-0">Контроль запасов сырья, сушилки и готовой продукции</p>
        </div>
        
        <div class="flex-row gap-10 items-end flex-wrap justify-end">
            <div class="form-group prod-header-datepicker mb-0 min-w-160">
                <label class="label-sm text-muted">Остатки на дату:</label>
                <input type="text" id="inventory-date-filter" class="input-modern prod-date-input" placeholder="Сегодня">
            </div>
            
            <button class="btn btn-outline" onclick="openSiftingModal()">Просеивание</button>
            <button class="btn btn-outline" id="btn-audit-mode" onclick="toggleAuditMode()">📋 Ревизия</button>
            
                        <div id="audit-controls" class="flex-row gap-10 items-center justify-end flex-wrap inv-hidden">
                <label class="flex-row items-center cursor-pointer gap-5 mb-0 text-main font-13" title="Показать исторические партии с нулевым остатком">
                    <input type="checkbox" id="show-zeros-check" onchange="loadTable()" class="cursor-pointer">
                    Показать нули
                </label>
                <label class="flex-row items-center cursor-pointer gap-5 mb-0 text-main font-13" title="Скрыть партии и списывать по FIFO">
                    <input type="checkbox" id="aggregate-audit-check" onchange="loadTable()" class="cursor-pointer">
                    Свернуть по товарам
                </label>
                <button class="btn btn-outline-primary p-5-10 font-12" onclick="openSurplusModal()">➕ Внести излишки</button>
                <button class="btn btn-blue p-5-10 font-12" id="btn-audit-save" onclick="saveAudit()">💾 Сохранить</button>
            </div>
            
            
            <button class="btn btn-outline" onclick="openPrintModal()">Печать</button>
            
            <div class="dropdown inline-block relative">
                <button class="btn btn-outline" onclick="this.nextElementSibling.classList.toggle('inv-hidden')">📥 Экспорт XLS ▼</button>
                <div class="dropdown-menu inv-hidden absolute top-100 right-0 bg-surface border z-100 radius-md mt-5 shadow-sm">
                    <a href="javascript:void(0)" onclick="executeExport('blind')" class="block p-10 text-main text-decoration-none border-bottom">Слепой бланк</a>
                    <a href="javascript:void(0)" onclick="executeExport('full')" class="block p-10 text-main text-decoration-none">Полный бланк</a>
                </div>
            </div>
            
            <button class="btn btn-outline" onclick="document.getElementById('import-xlsx-file').click()">📤 Загрузить</button>
            <input type="file" id="import-xlsx-file" class="hidden" accept=".xlsx" onchange="handleExcelImport(event)">

            <button class="btn btn-blue" onclick="loadTable()">🔄 Обновить</button>
        </div>
    </div>

    <div class="flex-row gap-10 mb-15 w-100">
        <input type="text" id="inventory-search" class="input-modern flex-grow-1" placeholder="🔍 Умный поиск по наименованию или номеру партии..." oninput="handleInventorySearch()">
    </div>

    <div class="inv-filter-panel mb-10">
        <button class="btn btn-outline filter-btn active" onclick="applyWarehouseFilter('all', this)">🌐 Все склады</button>
        <button class="btn btn-outline filter-btn" onclick="applyWarehouseFilter('1', this)">Склад №1 (Сырье)</button>
        <button class="btn btn-outline filter-btn" onclick="applyWarehouseFilter('3', this)">Склад №3 (Сушилка)</button>
        <button class="btn btn-outline filter-btn" onclick="applyWarehouseFilter('4', this)">Склад №4 (Готовая продукция)</button>
        <button class="btn btn-outline filter-btn" onclick="applyWarehouseFilter('5', this)">Склад №5 (Уценка и Брак)</button>
        <button class="btn btn-outline filter-btn" onclick="applyWarehouseFilter('6', this)">Склад №6 (Утиль)</button>
        <button class="btn btn-outline filter-btn inv-reserve-btn" onclick="applyWarehouseFilter('7', this)">🔒 Склад №7 (Резервы)</button>
    </div>

    <div class="card inv-stock-card p-0">
        <div class="table-container">
            <style>
                /* Компактный режим для склада по требованию пользователя */
                .inv-stock-card table td, .inv-stock-card table th {
                    padding: 4px 8px !important;
                    height: 32px !important;
                    vertical-align: middle;
                }
                .inv-name-cell {
                    max-width: 300px;
                    white-space: nowrap;
                    overflow: hidden;
                    text-overflow: ellipsis;
                }
                .inv-actions-cell button {
                    padding: 2px 8px !important;
                    font-size: 12px !important;
                }
            </style>
            <table class="table-modern w-100 table-fixed">
                <thead class="bg-surface-alt" id="inventory-thead">
                    <tr>
                        <th class="inv-col-wh p-10 text-left text-muted font-12 text-uppercase w-12">Склад</th>
                        <th class="inv-col-batch p-10 text-left text-muted font-12 text-uppercase w-12">№ Партии</th>
                        <th class="inv-col-name p-10 text-left text-muted font-12 text-uppercase w-45">Наименование (Сырье / Продукция)</th>
                        <th class="inv-col-qty p-10 text-right text-muted font-12 text-uppercase w-10">Остаток</th>
                        <th class="inv-col-unit p-10 text-left text-muted font-12 text-uppercase w-5">Ед.</th>
                        <th class="inv-col-actions p-10 text-right text-muted font-12 text-uppercase w-16">Действия</th>
                    </tr>
                </thead>
                <tbody id="inventory-table">
                    <tr>
                        <td colspan="6" class="text-center p-20 text-muted font-italic">
                            Загрузка остатков...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="flex-between p-10 bg-surface-alt align-center border-top">
            <div class="flex-row gap-10 align-center">
                <span class="text-muted font-13">Показывать по:</span>
                <select id="inventory-page-size" class="input-modern p-5 font-13 w-70" onchange="changeItemsPerPage(this.value)">
                    <option value="20">20</option>
                    <option value="50" selected>50</option>
                    <option value="100">100</option>
                </select>
                <span class="text-muted font-13 ml-10" id="inventory-summary-text"></span>
            </div>
            <div class="flex-row gap-5" id="inventory-pagination">
                <!-- Pagination buttons generated via JS -->
            </div>
        </div>
    </div>

    <!-- Блок истории движений сушилки (виден только при выборе Склад №3) -->
    <div id="drying-history-block" class="card border-left-muted mt-20 d-none">
        <div class="flex-between mb-15">
            <h3 class="mt-0 mb-0">📦 История движений сушилки</h3>
            <span id="drying-history-date-badge" class="badge bg-surface-alt text-primary font-13 p-5-10 border-radius-20"></span>
        </div>
        <div class="table-container">
            <table class="table-modern w-100">
                <thead class="bg-surface-alt">
                    <tr>
                        <th class="p-10 text-left text-muted font-12 text-uppercase w-10">Время</th>
                        <th class="p-10 text-left text-muted font-12 text-uppercase w-15">Тип</th>
                        <th class="p-10 text-left text-muted font-12 text-uppercase w-15">№ Партии</th>
                        <th class="p-10 text-left text-muted font-12 text-uppercase w-35">Продукция</th>
                        <th class="p-10 text-right text-muted font-12 text-uppercase w-10">Кол-во</th>
                        <th class="p-10 text-left text-muted font-12 text-uppercase w-5">Ед.</th>
                        <th class="p-10 text-left text-muted font-12 text-uppercase w-10">Описание</th>
                        <th class="p-10 w-5"></th>
                    </tr>
                </thead>
                <tbody id="drying-history-table">
                    <tr><td colspan="8" class="text-center text-muted p-20">Выберите дату в календаре...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

</div>
<!-- Складской модуль завершен. Дальше глобальные модалки склада -->

    <!-- Модальное окно Просеивания -->
    <div id="modal-sifting" class="modal-overlay d-none">
        <div class="modal-content modal-sm">
            <div class="modal-header">
                <h3 id="sifting-modal-title" class="mt-0 mb-0">🔄 Просеивание (Переработка) сырья</h3>
                <button class="btn-close" onclick="closeSiftingModal()">×</button>
            </div>
            
            <div class="modal-body">
                <div class="form-group mb-15">
                    <label class="label-sm text-muted">Дата переработки:</label>
                    <input type="text" id="sifting-date" class="input-modern" placeholder="Выберите дату">
                </div>
                <div class="form-group mb-15">
                    <label>Исходное сырье (к списанию):</label>
                    <select id="sifting-source" class="input-modern w-100">
                        <option value="155" selected>Песок основной</option>
                        <!-- В будущем можно сделать динамическим -->
                    </select>
                </div>
                
                <div class="form-group mb-20">
                    <label>Объем для просеивания (кг):</label>
                    <input type="number" id="sifting-amount" class="input-modern w-100 font-18 text-center" placeholder="Например: 1000" oninput="calculateSifting()">
                </div>

                <div class="bg-surface p-15 border-radius-8">
                    <h4 class="mt-0 mb-10 text-muted">Расчетный выход сырья (Приход):</h4>
                    
                    <div class="flex-row gap-10 mb-10 align-center">
                        <div class="w-75">
                            <label class="font-12 text-muted">Песок лицевой (85%):</label>
                            <select id="sifting-out1-target" class="input-modern w-100 p-5 mt-5">
                                <option value="156" selected>Песок лицевой</option>
                            </select>
                        </div>
                        <div class="w-25">
                            <label class="font-12 text-muted">Кг:</label>
                            <input type="number" id="sifting-out1-qty" class="input-modern w-100 p-5 mt-5 text-right font-bold text-success">
                        </div>
                    </div>

                    <div class="flex-row gap-10 align-center">
                        <div class="w-75">
                            <label class="font-12 text-muted">Гранит (15%):</label>
                            <select id="sifting-out2-target" class="input-modern w-100 p-5 mt-5">
                                <option value="508" selected>Гранит</option>
                            </select>
                        </div>
                        <div class="w-25">
                            <label class="font-12 text-muted">Кг:</label>
                            <input type="number" id="sifting-out2-qty" class="input-modern w-100 p-5 mt-5 text-right font-bold text-success">
                        </div>
                    </div>
                    
                    <p class="font-11 text-muted mt-10 mb-0">*Вы можете скорректировать килограммы, если есть потери влажности или утиль.</p>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-outline" onclick="closeSiftingModal()">Отмена</button>
                <button class="btn btn-blue" onclick="executeSifting()">✔️ Выполнить просев</button>
            </div>
        </div>
    </div>

    <!-- Модальное окно: Карточка движения товара (История) -->
    <div id="modal-item-history" class="modal-overlay d-none">
        <div class="modal-content modal-lg">
            <div class="modal-header">
                <h3 id="history-modal-title" class="mt-0 mb-0">Карточка движения</h3>
                <button class="btn-close" onclick="closeItemHistory()">×</button>
            </div>
            
            <div class="modal-body bg-surface-alt">
                <!-- Элементы управления -->
                <div class="filter-panel">
                    <div class="form-group filter-period">
                        <label>Период:</label>
                        <div id="history-period-selector" class="flex-row gap-5 align-center">
                             <!-- Отвечает JS -->
                        </div>
                    </div>
                    
                    <div class="form-group filter-warehouse">
                        <label>Склад (фильтр):</label>
                        <select id="history-warehouse-filter" class="input-modern input-sm" onchange="fetchItemHistory()">
                            <option value="all">Все склады</option>
                            <option value="1">Склад №1 (Сырье)</option>
                            <option value="3">Склад №3 (Сушилка)</option>
                            <option value="4">Склад №4 (Готов. прод)</option>
                            <option value="5">Склад №5 (Брак)</option>
                            <option value="6">Склад №6 (Утиль)</option>
                            <option value="7">Склад №7 (Резервы)</option>
                        </select>
                    </div>
                    
                    <div class="form-group filter-item">
                        <label>Выбор товара (Другой):</label>
                        <select id="history-item-switch" class="w-100" placeholder="🔍 Введите товар..." onchange="switchHistoryItem()"></select>
                    </div>
                    
                    <div class="form-group filter-search">
                        <label>Фильтр по операциям:</label>
                        <input type="text" id="history-search-input" class="input-modern input-sm w-100" 
                               placeholder="Партия, Заказ..." oninput="debounceHistorySearch()">
                    </div>
                    
                    <div class="form-group filter-btn">
                        <label class="opacity-0 no-pointer">&nbsp;</label>
                        <button class="btn btn-blue btn-sm w-100" onclick="fetchItemHistory()">🔄 Обновить</button>
                    </div>
                </div>

                <!-- Лента Карточек (Event Feed) -->
                <div class="history-feed-container flat bg-surface-alt p-10">
                    <div id="history-table-body">
                        <!-- JS Inject -->
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <div id="history-table-foot" class="w-100">
                    <!-- JS Inject: Сальдо -->
                </div>
                <div class="w-100 flex-row justify-end">
                    <button class="btn btn-outline" onclick="closeItemHistory()">Закрыть</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Модальное окно: Детализация Партии -->
    <div id="modal-batch-stats" class="modal-overlay d-none z-1005">
        <div class="modal-content modal-md">
            <div class="modal-header">
                <h3 id="batch-stats-title" class="mt-0 mb-0">Информация о партии</h3>
                <button class="btn-close" onclick="UI.closeModal('modal-batch-stats')">×</button>
            </div>
            <div class="modal-body p-0 bg-surface-alt" id="batch-stats-body">
                <div class="p-20 text-center text-muted">Загрузка данных партии...</div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" onclick="UI.closeModal('modal-batch-stats')">Закрыть</button>
            </div>
        </div>
    </div>

    <!-- Модальное окно: Досье контрагента -->
    <div id="modal-client-stats" class="modal-overlay d-none z-1005">
        <div class="modal-content modal-lg">
            <div class="modal-header">
                <h3 id="client-stats-title" class="mt-0 mb-0">Досье контрагента</h3>
                <button class="btn-close" onclick="UI.closeModal('modal-client-stats')">×</button>
            </div>
            <div class="modal-body p-0 bg-surface-alt" id="client-stats-body">
                <div class="p-20 text-center text-muted">Загрузка статистики...</div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" onclick="UI.closeModal('modal-client-stats')">Закрыть</button>
            </div>
        </div>
    </div>

    <!-- Модальное окно: Карточка прослеживаемости партии -->
    <div id="modal-batch-card" class="modal-overlay d-none z-1005">
        <div class="modal-content batch-modal">
            <div class="modal-header">
                <div class="batch-header">
                    <h3 id="batch-card-title" class="batch-header-title">Карточка партии</h3>
                    <div class="batch-header-badges" id="batch-card-badges"></div>
                </div>
                <button class="btn-close" onclick="UI.closeModal('modal-batch-card')">×</button>
            </div>
            <div class="modal-body" id="batch-card-body">
                <div class="p-20 text-center text-muted">Загрузка данных...</div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" onclick="UI.closeModal('modal-batch-card')">Закрыть</button>
            </div>
        </div>
    </div>

    <!-- Модальное окно: Редактирование движения -->
    <div id="modal-edit-movement" class="modal-overlay d-none z-1005">
        <div class="modal-content modal-md">
            <div class="modal-header">
                <h3 class="m-0">✏️ Редактирование записи</h3>
                <button class="btn-close" onclick="UI.closeModal('modal-edit-movement')">×</button>
            </div>
            <div class="modal-body">
                <form id="edit-movement-form" onsubmit="event.preventDefault(); saveMovementEdit();">
                    <input type="hidden" id="edit-mov-id">
                    <div class="form-group">
                        <label>Дата операции:</label>
                        <input type="text" id="edit-mov-date" class="form-control input-modern w-100" placeholder="Дата">
                    </div>
                    <div class="form-group">
                        <label>Количество (Изменение запрещено. Используйте Откат):</label>
                        <input type="number" step="0.01" id="edit-mov-qty" class="form-control input-modern w-100 bg-disabled" readonly disabled>
                    </div>
                    <div class="form-group">
                        <label>Комментарий / Описание:</label>
                        <input type="text" id="edit-mov-desc" class="form-control input-modern w-100" placeholder="Комментарий">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" onclick="UI.closeModal('modal-edit-movement')">Отмена</button>
                <button type="button" class="btn btn-blue" onclick="saveMovementEdit()">💾 Сохранить</button>
            </div>
        </div>
    </div>
    <!-- Модальное окно: Внести излишки -->
    <div id="modal-surplus" class="modal-overlay d-none">
        <div class="modal-content modal-sm">
            <div class="modal-header p-15 border-bottom bg-surface flex-between align-center">
                <h3 class="m-0 font-16">➕ Внести неучтенные излишки</h3>
                <span class="modal-close font-24 cursor-pointer text-muted hover-red" onclick="UI.closeModal('modal-surplus')">&times;</span>
            </div>
            <div class="modal-body p-20">
                <div class="text-muted font-13 mb-15">Выберите товар из каталога. Партия 'Излишки инвентаризации' будет сгенерирована автоматически.</div>
                <div class="form-group mb-15">
                    <label class="font-13 text-muted block mb-5">Товар (без партии):</label>
                    <select id="surplus-item-select" class="form-control w-100" placeholder="Поиск товара..."></select>
                </div>
                <div class="form-group">
                    <label class="font-13 text-muted block mb-5">Количество излишка:</label>
                    <input type="number" step="0.01" id="surplus-qty" class="input-modern w-100" placeholder="Например, 10">
                </div>
            </div>
            <div class="modal-footer p-15 border-top bg-surface-alt flex-end gap-10">
                <button type="button" class="btn btn-outline" onclick="UI.closeModal('modal-surplus')">Отмена</button>
                <button type="button" class="btn btn-blue" onclick="submitSurplus()">Внести на баланс</button>
            </div>
        </div>
    </div>
