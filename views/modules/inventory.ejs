<div id="stock-mod" class="module">
    <style>
        @media print {
            body { background: white; }
            .sidebar, .top-header, .inv-filter-panel, #inventory-search, .card-header .btn, .inv-actions-cell, .table-container .flex-between { display: none !important; }
            .module { padding: 0; margin: 0; top: 0; left: 0; position: absolute; width: 100%; box-shadow: none; border: none; }
            .inv-stock-card { box-shadow: none; border: none; }
            table, th, td { border: 1px solid #ccc !important; }
            * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        }
    </style>
    <div class="flex-between mb-20 items-end">
        <div>
            <h2 class="mt-0 mb-0">📦 Склад и Остатки</h2>
            <p class="text-muted font-14 mt-5 mb-0">Контроль запасов сырья, сушилки и готовой продукции</p>
        </div>
        
        <div class="flex-row gap-10 items-end flex-wrap justify-end">
            <div class="form-group prod-header-datepicker mb-0 min-w-160">
                <label class="label-sm text-muted">Остатки на дату:</label>
                <input type="text" id="inventory-date-filter" class="input-modern prod-date-input" placeholder="Сегодня">
            </div>
            
            <button class="btn btn-outline" onclick="openSiftingModal()">⚙️ Переработка</button>
            <button class="btn btn-outline" id="btn-audit-mode" onclick="toggleAuditMode()">📋 Ревизия</button>
            <button class="btn btn-blue inv-hidden" id="btn-audit-save" onclick="saveAudit()">💾 Сохранить</button>
            
            <button class="btn btn-outline" onclick="openPrintModal()">🖨️ Печать</button>
            
            <div class="dropdown inline-block relative">
                <button class="btn btn-outline" onclick="this.nextElementSibling.classList.toggle('inv-hidden')">📥 Экспорт XLS ▼</button>
                <div class="dropdown-menu inv-hidden absolute top-100 right-0 bg-surface border z-100 radius-md mt-5 shadow-sm">
                    <a href="javascript:void(0)" onclick="executeExport('blind')" class="block p-10 text-main text-decoration-none border-bottom">Слепой бланк</a>
                    <a href="javascript:void(0)" onclick="executeExport('full')" class="block p-10 text-main text-decoration-none">Полный бланк</a>
                </div>
            </div>
            
            <button class="btn btn-outline" onclick="document.getElementById('import-xlsx-file').click()">📤 Загрузить</button>
            <input type="file" id="import-xlsx-file" class="hidden" accept=".xlsx" onchange="handleExcelImport(event)">

            <button class="btn btn-blue" onclick="loadTable()">🔄 Обновить</button>
        </div>
    </div>

    <div class="flex-row gap-10 mb-15 w-100">
        <input type="text" id="inventory-search" class="input-modern flex-grow-1" placeholder="🔍 Умный поиск по наименованию или номеру партии..." oninput="handleInventorySearch()">
    </div>

    <div class="inv-filter-panel mb-10">
        <button class="btn btn-outline filter-btn active" onclick="applyWarehouseFilter('all', this)">🌐 Все склады</button>
        <button class="btn btn-outline filter-btn" onclick="applyWarehouseFilter('1', this)">Склад №1 (Сырье)</button>
        <button class="btn btn-outline filter-btn" onclick="applyWarehouseFilter('3', this)">Склад №3 (Сушилка)</button>
        <button class="btn btn-outline filter-btn" onclick="applyWarehouseFilter('4', this)">Склад №4 (Готовая продукция)</button>
        <button class="btn btn-outline filter-btn" onclick="applyWarehouseFilter('5', this)">Склад №5 (Уценка и Брак)</button>
        <button class="btn btn-outline filter-btn" onclick="applyWarehouseFilter('6', this)">Склад №6 (Утиль)</button>
        <button class="btn btn-outline filter-btn inv-reserve-btn" onclick="applyWarehouseFilter('7', this)">🔒 Склад №7 (Резервы)</button>
    </div>

    <div class="card inv-stock-card p-0">
        <div class="table-container">
            <style>
                /* Компактный режим для склада по требованию пользователя */
                .inv-stock-card table td, .inv-stock-card table th {
                    padding: 4px 8px !important;
                    height: 32px !important;
                    vertical-align: middle;
                }
                .inv-name-cell {
                    max-width: 300px;
                    white-space: nowrap;
                    overflow: hidden;
                    text-overflow: ellipsis;
                }
                .inv-actions-cell button {
                    padding: 2px 8px !important;
                    font-size: 12px !important;
                }
            </style>
            <table class="table-modern w-100 table-fixed">
                <thead class="bg-surface-alt" id="inventory-thead">
                    <tr>
                        <th class="inv-col-wh p-10 text-left text-muted font-12 text-uppercase w-12">Склад</th>
                        <th class="inv-col-batch p-10 text-left text-muted font-12 text-uppercase w-12">№ Партии</th>
                        <th class="inv-col-name p-10 text-left text-muted font-12 text-uppercase w-45">Наименование (Сырье / Продукция)</th>
                        <th class="inv-col-qty p-10 text-right text-muted font-12 text-uppercase w-10">Остаток</th>
                        <th class="inv-col-unit p-10 text-left text-muted font-12 text-uppercase w-5">Ед.</th>
                        <th class="inv-col-actions p-10 text-right text-muted font-12 text-uppercase w-16">Действия</th>
                    </tr>
                </thead>
                <tbody id="inventory-table">
                    <tr>
                        <td colspan="6" class="text-center p-20 text-muted font-italic">
                            Загрузка остатков...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="flex-between p-10 bg-surface-alt align-center border-top">
            <div class="flex-row gap-10 align-center">
                <span class="text-muted font-13">Показывать по:</span>
                <select id="inventory-page-size" class="input-modern p-5 font-13 w-70" onchange="changeItemsPerPage(this.value)">
                    <option value="20">20</option>
                    <option value="50" selected>50</option>
                    <option value="100">100</option>
                </select>
                <span class="text-muted font-13 ml-10" id="inventory-summary-text"></span>
            </div>
            <div class="flex-row gap-5" id="inventory-pagination">
                <!-- Pagination buttons generated via JS -->
            </div>
        </div>
    </div>

    <!-- Модальное окно Просеивания -->
    <div id="modal-sifting" class="modal-overlay hidden">
        <div class="modal-content modal-sm">
            <div class="modal-header">
                <h3 id="app-modal-title" class="mt-0 mb-0">🔄 Просеивание (Переработка) сырья</h3>
                <button class="btn-close" onclick="closeSiftingModal()">×</button>
            </div>
            
            <div class="modal-body">
                <div class="form-group mb-15">
                    <label>Исходное сырье (к списанию):</label>
                    <select id="sifting-source" class="input-modern w-100">
                        <option value="155" selected>Песок основной</option>
                        <!-- В будущем можно сделать динамическим -->
                    </select>
                </div>
                
                <div class="form-group mb-20">
                    <label>Объем для просеивания (кг):</label>
                    <input type="number" id="sifting-amount" class="input-modern w-100 font-18 text-center" placeholder="Например: 1000" oninput="calculateSifting()">
                </div>

                <div class="bg-surface p-15 border-radius-8">
                    <h4 class="mt-0 mb-10 text-muted">Расчетный выход сырья (Приход):</h4>
                    
                    <div class="flex-row gap-10 mb-10 align-center">
                        <div class="w-75">
                            <label class="font-12 text-muted">Песок лицевой (85%):</label>
                            <select id="sifting-out1-target" class="input-modern w-100 p-5 mt-5">
                                <option value="156" selected>Песок лицевой</option>
                            </select>
                        </div>
                        <div class="w-25">
                            <label class="font-12 text-muted">Кг:</label>
                            <input type="number" id="sifting-out1-qty" class="input-modern w-100 p-5 mt-5 text-right font-bold text-success">
                        </div>
                    </div>

                    <div class="flex-row gap-10 align-center">
                        <div class="w-75">
                            <label class="font-12 text-muted">Гранит (15%):</label>
                            <select id="sifting-out2-target" class="input-modern w-100 p-5 mt-5">
                                <option value="508" selected>Гранит</option>
                            </select>
                        </div>
                        <div class="w-25">
                            <label class="font-12 text-muted">Кг:</label>
                            <input type="number" id="sifting-out2-qty" class="input-modern w-100 p-5 mt-5 text-right font-bold text-success">
                        </div>
                    </div>
                    
                    <p class="font-11 text-muted mt-10 mb-0">*Вы можете скорректировать килограммы, если есть потери влажности или утиль.</p>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-outline" onclick="closeSiftingModal()">Отмена</button>
                <button class="btn btn-blue" onclick="executeSifting()">✔️ Выполнить просев</button>
            </div>
        </div>
    </div>

    <!-- Модальное окно: Карточка движения товара (История) -->
    <div id="modal-item-history" class="modal-overlay hidden">
        <div class="modal-content modal-lg">
            <div class="modal-header">
                <h3 id="history-modal-title" class="mt-0 mb-0">Карточка движения</h3>
                <button class="btn-close" onclick="closeItemHistory()">×</button>
            </div>
            
            <div class="modal-body bg-surface-alt">
                <!-- Элементы управления -->
                <div class="filter-panel flex-row gap-15 align-center mb-15 p-15 border-radius-8 bg-surface border">
                    <div class="form-group mb-0 min-w-450">
                        <label>Период:</label>
                        <div id="history-period-selector" class="flex-row gap-5 h-32 items-center">
                             <!-- Отвечает JS -->
                        </div>
                    </div>
                    <div class="form-group mb-0 flex-grow-1 min-w-160 max-w-250">
                        <label>Склад (фильтр):</label>
                        <select id="history-warehouse-filter" class="input-modern w-100 h-32 p-5 font-13" onchange="fetchItemHistory()">
                            <option value="all">Все склады</option>
                            <option value="1">Склад №1 (Сырье)</option>
                            <option value="3">Склад №3 (Сушилка)</option>
                            <option value="4">Склад №4 (Готов. прод)</option>
                            <option value="5">Склад №5 (Брак)</option>
                            <option value="6">Склад №6 (Утиль)</option>
                            <option value="7">Склад №7 (Резервы)</option>
                        </select>
                    </div>
                    <div class="form-group mb-0 flex-grow-1 min-w-200">
                        <label>Выбор товара (Другой):</label>
                        <div class="search-input-wrapper w-100">
                            <input type="text" list="history-item-datalist" id="history-item-switch" placeholder="🔍 Введите товар..." 
                                   class="input-modern input-search w-100 h-32 pl-30" onchange="switchHistoryItem()" onfocus="this.select()">
                            <datalist id="history-item-datalist"></datalist>
                        </div>
                    </div>
                    <div class="form-group mb-0 flex-grow-1 min-w-180">
                        <label>Фильтр по операциям:</label>
                        <input type="text" id="history-search-input" class="input-modern w-100 h-32 p-5 font-13" placeholder="Партия, Заказ..." oninput="debounceHistorySearch()">
                    </div>
                    <div class="form-group mb-0 mt-24">
                        <button class="btn btn-blue h-32 px-15" onclick="fetchItemHistory()">🔄 Обновить</button>
                    </div>
                </div>

                <!-- Таблица карточки -->
                <div class="table-container flat">
                    <table class="table-modern w-100">
                        <thead class="bg-surface">
                            <tr>
                                <th class="w-10">Дата</th>
                                <th class="w-35">Смысл операции (Документ)</th>
                                <th class="w-15 text-right">Приход (+)</th>
                                <th class="w-15 text-right">Расход (-)</th>
                                <th class="w-15 text-right">Остаток (Сальдо)</th>
                                <th class="w-10 text-right">Цена / Сумма</th>
                            </tr>
                        </thead>
                        <tbody id="history-table-body">
                            <!-- JS Inject -->
                        </tbody>
                        <tfoot class="bg-surface font-bold" id="history-table-foot">
                            <!-- JS Inject -->
                        </tfoot>
                    </table>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-outline" onclick="closeItemHistory()">Закрыть</button>
            </div>
        </div>
    <!-- Модальное окно: Детализация Партии -->
    <div id="modal-batch-stats" class="modal-overlay hidden z-1005">
        <div class="modal-content modal-md">
            <div class="modal-header">
                <h3 id="batch-stats-title" class="mt-0 mb-0">Информация о партии</h3>
                <button class="btn-close" onclick="UI.closeModalById('modal-batch-stats')">×</button>
            </div>
            <div class="modal-body p-0 bg-surface-alt" id="batch-stats-body">
                <div class="p-20 text-center text-muted">Загрузка данных партии...</div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" onclick="UI.closeModalById('modal-batch-stats')">Закрыть</button>
            </div>
        </div>
    </div>

    <!-- Модальное окно: Досье контрагента -->
    <div id="modal-client-stats" class="modal-overlay hidden z-1005">
        <div class="modal-content modal-lg">
            <div class="modal-header">
                <h3 id="client-stats-title" class="mt-0 mb-0">Досье контрагента</h3>
                <button class="btn-close" onclick="UI.closeModalById('modal-client-stats')">×</button>
            </div>
            <div class="modal-body p-0 bg-surface-alt" id="client-stats-body">
                <div class="p-20 text-center text-muted">Загрузка статистики...</div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" onclick="UI.closeModalById('modal-client-stats')">Закрыть</button>
            </div>
        </div>
    </div>
</div>