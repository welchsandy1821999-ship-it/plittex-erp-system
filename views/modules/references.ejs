<div id="ref-mod" class="module">
    <div class="flex-between mb-20" style="align-items: flex-end;">
        <div>
            <h2 class="mt-0">📁 Справочник номенклатуры</h2>
            <p class="text-muted" style="font-size: 13px; margin: 0;">Управление сырьем, продукцией и рецептурными нормами</p>
        </div>
        <button class="btn btn-blue shadow-md" onclick="openRefForm()">➕ Создать позицию</button>
    </div>

    <div class="card filter-card">
        <div class="form-grid" style="grid-template-columns: 2fr 1fr 1fr; align-items: end;">
            <div class="form-group">
                <label>🔍 Умный поиск (по названию):</label>
                <input type="text" id="ref-search" class="input-modern" placeholder="Начните вводить текст..." oninput="debounceRefLoad()">
            </div>
            <div class="form-group">
                <label>📂 Тип:</label>
                <select id="ref-filter-type" class="input-modern" onchange="loadReferences(1)">
                    <option value="">🌐 Все типы</option>
                    <option value="material">🪨 Сырье</option>
                    <option value="product">📦 Продукция</option>
                </select>
            </div>
            <div class="form-group">
                <label>📑 Категория:</label>
                <select id="ref-filter-category" class="input-modern" onchange="loadReferences(1)">
                    <option value="">🌐 Все категории</option>
                </select>
            </div>
        </div>
    </div>

    <div id="ref-form-container" class="card" style="display: none; border-left: 4px solid var(--primary); position: relative;">
        <button class="btn btn-outline btn-close-abs text-danger" style="border-color: var(--danger);" onclick="closeRefForm()">✖ Закрыть</button>

        <h3 id="ref-form-title" class="mt-0 text-primary">✨ Добавление позиции</h3>
        <p class="text-muted mb-15" style="font-size: 12px;">Заполните данные. Названия сырья должны быть точными.</p>

        <div class="ref-form-grid">
            <div class="form-group">
                <label>Тип:</label>
                <select id="ref-type" class="input-modern">
                    <option value="product">📦 Продукция</option>
                    <option value="material">🪨 Сырье</option>
                </select>
            </div>
            <div class="form-group">
                <label>Название:</label>
                <input type="text" id="ref-name" class="input-modern" placeholder="Точное наименование">
            </div>
            <div class="form-group col-span-2">
                <label class="text-primary" style="font-weight: bold;">Артикул (Код для Excel):</label>
                <input type="text" id="ref-article" class="input-modern" style="border-color: var(--primary); background-color: var(--bg-main);" placeholder="Например: 2P4-GRY">
            </div>
            <div class="form-group">
                <label>Категория:</label>
                <input type="text" id="ref-category" list="dl-categories" class="input-modern" placeholder="Сырье, Плитка...">
            </div>
            <div class="form-group">
                <label>Ед. изм:</label>
                <input type="text" id="ref-unit" list="dl-units" class="input-modern" placeholder="кг, кв.м, шт" value="кг">
            </div>
            <div class="form-group">
                <label>Цена за ед (₽):</label>
                <input type="number" id="ref-price" class="input-modern" step="0.01" value="0">
            </div>
            <div class="form-group">
                <label>Вес 1 ед (кг):</label>
                <input type="number" id="ref-weight" class="input-modern" step="0.001" value="0">
            </div>

            <div class="form-group" id="group-qty-cycle">
                <label>Выход с 1 удара (м²/шт):</label>
                <input type="number" id="ref-qty-cycle" class="input-modern" step="0.001" value="1">
            </div>
            <div class="form-group" id="group-mold-select">
                <label class="text-mold-label">🗜️ Матрица (Оборудование):</label>
                <select id="ref-mold-id" class="input-modern bg-mold-select">
                    <option value="">-- Без матрицы --</option>
                </select>
                <small class="text-muted" style="font-size: 11px; display: block; margin-top: 4px;">Амортизация подтянется автоматически</small>
            </div>
            <div class="form-group col-span-2" id="group-gost">
                <label style="color: var(--text-muted);">📑 Нормативный документ (ТУ / ГОСТ):</label>
                <input type="text" id="ref-gost" class="input-modern" placeholder="Например: ТУ 23.61.11-001-50829991-2023">
                <small class="text-muted" style="font-size: 11px; display: block; margin-top: 4px;">Выводится в Маршрутном листе на производстве</small>
            </div>

            <div class="form-group col-span-2" style="display: flex; align-items: flex-end;">
                <input type="hidden" id="ref-edit-id" value="">
                <button class="btn btn-blue w-100" style="height: 42px;" onclick="saveReference()">💾 Сохранить позицию</button>
            </div>
        </div>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th width="5%">ID</th>
                    <th width="8%">Тип</th>
                    <th width="15%">Категория</th>
                    <th width="12%" class="text-primary">Артикул</th>
                    <th width="30%">Наименование</th>
                    <th width="10%">Ед.</th>
                    <th width="10%">Цена (₽)</th>
                    <th width="10%" style="text-align: right;">Действия</th>
                </tr>
            </thead>
            <tbody id="ref-table-body">
                <tr>
                    <td colspan="8" class="text-center">Загрузка...</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="pagination-bar">
        <button class="btn btn-outline" onclick="changeRefPage(-1)">⬅ Назад</button>
        <span id="ref-page-info" class="text-muted" style="font-size: 14px; font-weight: 600;"></span>
        <button class="btn btn-outline" onclick="changeRefPage(1)">Вперед ➡</button>
    </div>

    <datalist id="dl-categories"></datalist>
    <datalist id="dl-units">
        <option value="кг"></option>
        <option value="т"></option>
        <option value="кв.м"></option>
        <option value="шт"></option>
        <option value="л"></option>
    </datalist>
</div>