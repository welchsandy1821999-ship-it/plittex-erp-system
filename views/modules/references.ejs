<div id="ref-mod" class="module">
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px;">
        <div>
            <h2>📁 Справочник номенклатуры</h2>
            <p style="font-size: 13px; color: var(--text-muted); margin: 0;">Управление сырьем,
                продукцией и рецептурными нормами</p>
        </div>
        <button class="btn btn-blue" onclick="openRefForm()"
            style="box-shadow: 0 4px 6px -1px rgba(59, 130, 246, 0.3);">➕ Создать позицию</button>
    </div>

    <div class="card" style="padding: 15px; background: #f8fafc; border: 1px solid var(--border); margin-bottom: 20px;">
        <div class="form-grid" style="grid-template-columns: 2fr 1fr 1fr; align-items: end;">
            <div class="form-group">
                <label>🔍 Умный поиск (по названию):</label>
                <input type="text" id="ref-search" class="input-modern" placeholder="Начните вводить текст..."
                    oninput="debounceRefLoad()">
            </div>
            <div class="form-group">
                <label>📂 Тип:</label>
                <select id="ref-filter-type" class="input-modern" onchange="loadReferences(1)">
                    <option value="">🌐 Все типы</option>
                    <option value="material">🪨 Сырье</option>
                    <option value="product">📦 Продукция</option>
                </select>
            </div>
            <div class="form-group">
                <label>📑 Категория:</label>
                <select id="ref-filter-category" class="input-modern" onchange="loadReferences(1)">
                    <option value="">🌐 Все категории</option>
                </select>
            </div>
        </div>
    </div>

    <div id="ref-form-container" class="card"
        style="display: none; border-left: 4px solid var(--primary); background: #fff; position: relative;">
        <button class="btn btn-outline"
            style="position: absolute; top: 15px; right: 15px; padding: 4px 8px; font-size: 12px; color: var(--danger); border-color: var(--danger);"
            onclick="closeRefForm()">✖ Закрыть</button>

        <h3 id="ref-form-title" style="margin-top: 0; color: var(--primary);">✨ Добавление позиции</h3>
        <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 15px;">Заполните данные.
            Названия сырья должны быть точными (например: Диоксид титана, Пигмент Красный).</p>

        <div class="form-grid" style="grid-template-columns: 1fr 2fr 1fr 1fr;">
            <div class="form-group">
                <label>Тип:</label>
                <select id="ref-type" class="input-modern">
                    <option value="product">📦 Продукция</option>
                    <option value="material">🪨 Сырье</option>
                </select>
            </div>
            <div class="form-group">
                <label>Название:</label>
                <input type="text" id="ref-name" class="input-modern" placeholder="Точное наименование">
            </div>
            <div class="form-group">
                <label>Категория:</label>
                <input type="text" id="ref-category" list="dl-categories" class="input-modern"
                    placeholder="Сырье, Плитка...">
            </div>
            <div class="form-group">
                <label>Ед. изм:</label>
                <input type="text" id="ref-unit" list="dl-units" class="input-modern" placeholder="кг, кв.м, шт"
                    value="кг">
            </div>
            <div class="form-group">
                <label>Цена за ед (₽):</label>
                <input type="number" id="ref-price" class="input-modern" step="0.01" value="0">
            </div>
            <div class="form-group">
                <label>Вес 1 ед (кг):</label>
                <input type="number" id="ref-weight" class="input-modern" step="0.001" value="0">
            </div>
            <div class="form-group" style="grid-column: span 2; display: flex; align-items: flex-end;">
                <input type="hidden" id="ref-edit-id" value="">
                <button class="btn btn-blue" style="width: 100%; height: 42px;" onclick="saveReference()">💾 Сохранить
                    позицию</button>
            </div>
        </div>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th width="5%">ID</th>
                    <th width="10%">Тип</th>
                    <th width="20%">Категория</th>
                    <th width="35%">Наименование</th>
                    <th width="10%">Ед.</th>
                    <th width="10%">Цена (₽)</th>
                    <th width="10%" style="text-align: right;">Действия</th>
                </tr>
            </thead>
            <tbody id="ref-table-body">
                <tr>
                    <td colspan="7" style="text-align: center;">Загрузка...</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 15px;">
        <button class="btn btn-outline" onclick="changeRefPage(-1)">⬅ Назад</button>
        <span id="ref-page-info" style="font-size: 14px; color: var(--text-muted); font-weight: 600;"></span>
        <button class="btn btn-outline" onclick="changeRefPage(1)">Вперед ➡</button>
    </div>

    <datalist id="dl-categories"></datalist>
    <datalist id="dl-units">
        <option value="кг">
        <option value="т">
        <option value="кв.м">
        <option value="шт">
        <option value="л">
    </datalist>
</div>