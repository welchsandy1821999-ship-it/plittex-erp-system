<div id="ref-mod" class="module">
    <div class="flex-between mb-20 align-end">
        <div>
            <h2 class="mt-0">📁 Справочник номенклатуры</h2>
            <p class="text-muted font-13 m-0">Управление сырьем, продукцией и рецептурными
                нормами</p>
        </div>
        <button class="btn btn-blue shadow-md" onclick="openRefForm()">➕ Создать позицию</button>
    </div>

    <div class="card filter-card">
        <div class="form-grid dict-filter-grid">
            <div class="form-group">
                <label>🔍 Умный поиск (по названию):</label>
                <input type="text" id="ref-search" class="input-modern" placeholder="Начните вводить текст..."
                    oninput="debounceRefLoad()">
            </div>
            <div class="form-group">
                <label>📂 Тип:</label>
                <select id="ref-filter-type" class="input-modern" onchange="loadReferences(1)">
                    <option value="">🌐 Все типы</option>
                    <option value="material">🪨 Сырье</option>
                    <option value="product">📦 Продукция</option>
                </select>
            </div>
            <div class="form-group">
                <label>📑 Категория:</label>
                <select id="ref-filter-category" class="input-modern" onchange="loadReferences(1)">
                    <option value="">🌐 Все категории</option>
                </select>
            </div>
        </div>
    </div>

    <div id="ref-form-container" class="card dict-form-panel">
        <button class="btn btn-outline btn-close-abs text-danger border-danger"
            onclick="closeRefForm()">✖ Закрыть</button>

        <h3 id="ref-form-title" class="mt-0 text-primary">✨ Добавление позиции</h3>
        <p class="text-muted mb-15 font-12">Заполните данные. Названия сырья должны быть точными.</p>

        <div class="ref-form-grid">
            <div class="form-group">
                <label>Тип:</label>
                <select id="ref-type" class="input-modern">
                    <option value="product">📦 Продукция</option>
                    <option value="material">🪨 Сырье</option>
                </select>
            </div>
            <div class="form-group">
                <label>Название:</label>
                <input type="text" id="ref-name" class="input-modern" placeholder="Точное наименование">
            </div>
            <div class="form-group col-span-2">
                <label class="text-primary font-bold">Артикул (Код для Excel):</label>
                <input type="text" id="ref-article" class="input-modern dict-article-input"
                    placeholder="Например: 2P4-GRY">
            </div>
            <div class="form-group">
                <label>Категория:</label>
                <div class="dict-datalist-wrap">
                    <input type="text" id="ref-category" list="dl-categories" class="input-modern w-100"
                        placeholder="Сырье, Плитка..."
                        onfocus="this.select(); if(typeof this.showPicker === 'function') this.showPicker();">
                    <span class="dict-datalist-arrow"
                        onclick="this.previousElementSibling.focus();">▼</span>
                </div>
            </div>
            <div class="form-group">
                <label>Ед. изм:</label>
                <div class="dict-datalist-wrap">
                    <input type="text" id="ref-unit" list="dl-units" class="input-modern w-100"
                        placeholder="кг, кв.м, шт" value="кг"
                        onfocus="this.select(); if(typeof this.showPicker === 'function') this.showPicker();">
                    <span class="dict-datalist-arrow"
                        onclick="this.previousElementSibling.focus();">▼</span>
                </div>
            </div>
            <div class="form-group">
                <label>Цена за ед (₽):</label>
                <input type="number" id="ref-price" class="input-modern" step="0.01" value="0">
            </div>
            <div class="form-group">
                <label>Вес 1 ед (кг):</label>
                <input type="number" id="ref-weight" class="input-modern" step="0.001" value="0">
            </div>

            <div class="form-group" id="group-qty-cycle">
                <label>Выход с 1 удара (м²/шт):</label>
                <input type="number" id="ref-qty-cycle" class="input-modern" step="0.001" value="1">
            </div>
            <div class="form-group" id="group-mold-select">
                <label class="text-mold-label">🗜️ Матрица (Оборудование):</label>
                <select id="ref-mold-id" class="input-modern bg-mold-select">
                    <option value="">-- Без матрицы --</option>
                </select>
                <small class="text-muted font-11 d-block mt-4">Амортизация
                    подтянется автоматически</small>
            </div>
            <div class="form-group col-span-2" id="group-gost">
                <label class="text-muted">📑 Нормативный документ (ТУ / ГОСТ):</label>
                <input type="text" id="ref-gost" class="input-modern"
                    placeholder="Например: ТУ 23.61.11-001-50829991-2023">
                <small class="text-muted font-11 d-block mt-4">Выводится в
                    Маршрутном листе на производстве</small>
            </div>
            <div class="form-group dict-piece-rate-block" id="group-piece-rate">
                <label class="text-success font-bold">💰 Сдельная З/П (Ставка за 1 шт.):</label>
                <div class="font-11 text-muted mb-5 line-height-12">
                    Сумма, которая будет автоматически начисляться рабочим за формовку 1 единицы этой продукции.
                </div>
                <input type="number" id="ref-piece-rate" class="input-modern" value="0" step="0.5" min="0">
            </div>

            <div class="form-group col-span-2 group-mix-templates dict-mix-block">
                <h4 class="m-0 mb-10 font-13 text-primary">🧪 Архитектура составов (Для Формовки)</h4>
                <div class="dict-mix-grid">
                    <div>
                        <label class="font-12">Шаблон основного слоя:</label>
                        <select id="ref-mix-main" class="input-modern mb-0">
                            <option value="">-- Не задан --</option>
                            <option value="main_block">Блок</option>
                            <option value="main_bor_dor">Бордюр Дорожный</option>
                            <option value="main_bor_mag">Бордюр Магистральный</option>
                            <option value="main_por">Поребрик</option>
                            <option value="main_tile_40">Плитка 40 мм</option>
                            <option value="main_tile_60">Плитка 60 мм</option>
                            <option value="main_tile_80">Плитка 80 мм</option>
                        </select>
                    </div>
                    <div>
                        <label class="font-12">Шаблон лицевого слоя:</label>
                        <select id="ref-mix-face" class="input-modern mb-0">
                            <option value="">-- Не задан --</option>
                            <optgroup label="Гладкая фактура">
                                <option value="face_smooth_grey">Гладкая Серая</option>
                                <option value="face_smooth_white">Гладкая Белая</option>
                                <option value="face_smooth_black">Гладкая Черная</option>
                                <option value="face_smooth_red">Гладкая Красная</option>
                                <option value="face_smooth_yellow">Гладкая Желтая</option>
                                <option value="face_smooth_brown">Гладкая Коричневая</option>
                                <option value="face_smooth_orange">Гладкая Оранжевая</option>
                            </optgroup>
                            <optgroup label="Фактура Гранит">
                                <option value="face_granite_grey">Гранит Серая</option>
                                <option value="face_granite_white">Гранит Белая</option>
                                <option value="face_granite_black">Гранит Черная</option>
                                <option value="face_granite_red">Гранит Красная</option>
                                <option value="face_granite_yellow">Гранит Желтая</option>
                                <option value="face_granite_brown">Гранит Коричневая</option>
                                <option value="face_granite_orange">Гранит Оранжевая</option>
                            </optgroup>
                            <optgroup label="Меланж Гладкий">
                                <option value="face_mel_sm_onyx">Меланж Гладкая Оникс</option>
                                <option value="face_mel_sm_autumn">Меланж Гладкая Осень</option>
                                <option value="face_mel_sm_amber">Меланж Гладкая Янтарь</option>
                                <option value="face_mel_sm_jasper">Меланж Гладкая Яшма</option>
                                <option value="face_mel_sm_ruby">Меланж Гладкая Рубин</option>
                            </optgroup>
                            <optgroup label="Меланж Гранит">
                                <option value="face_mel_gr_onyx">Меланж Гранит Оникс</option>
                                <option value="face_mel_gr_autumn">Меланж Гранит Осень</option>
                                <option value="face_mel_gr_amber">Меланж Гранит Янтарь</option>
                                <option value="face_mel_gr_jasper">Меланж Гранит Яшма</option>
                                <option value="face_mel_gr_ruby">Меланж Гранит Рубин</option>
                            </optgroup>
                        </select>
                    </div>
                </div>
            </div>

            <div class="form-group col-span-2 flex-row align-end">
                <input type="hidden" id="ref-edit-id" value="">
                <button class="btn btn-blue w-100 dict-save-btn" onclick="saveReference()">💾 Сохранить
                    позицию</button>
            </div>
        </div>
    </div>



    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th class="dict-col-id">ID</th>
                    <th class="dict-col-type">Тип</th>
                    <th class="dict-col-cat">Категория</th>
                    <th class="dict-col-article text-primary">Артикул</th>
                    <th class="dict-col-name">Наименование</th>
                    <th class="dict-col-unit">Ед.</th>
                    <th class="dict-col-price">Цена (₽)</th>
                    <th class="dict-col-actions text-right">Действия</th>
                </tr>
            </thead>
            <tbody id="ref-table-body">
                <tr>
                    <td colspan="8" class="text-center">Загрузка...</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="pagination-bar">
        <button class="btn btn-outline" onclick="changeRefPage(-1)">⬅ Назад</button>
        <span id="ref-page-info" class="text-muted font-14 font-600"></span>
        <button class="btn btn-outline" onclick="changeRefPage(1)">Вперед ➡</button>
    </div>

    <datalist id="dl-categories"></datalist>
    <datalist id="dl-units">
        <option value="кг"></option>
        <option value="т"></option>
        <option value="кв.м"></option>
        <option value="шт"></option>
        <option value="л"></option>
    </datalist>

</div>