<div id="docs-registry-mod" class="module">
    <div class="flex-between mb-20 align-end">
        <div class="w-100">
            <h2 class="mt-0">📄 Реестр финансовых документов</h2>
            <p class="text-muted font-13 m-0">Архив выписанных счетов на оплату и система
                подготовки файлов для 1С Бухгалтерии.</p>
        </div>
    </div>

    <div class="flex-between mb-15 card-alt docs-filter-panel">
        <!-- Панель фильтров -->
        <div class="toolbar-group d-flex align-items-center flex-wrap docs-filter-group">
            
            <!-- Фильтр по клиенту -->
            <select id="clientFilter" class="input-modern docs-client-select">
                <option value="">Все контрагенты</option>
                <!-- Опции будут добавлены через JS -->
            </select>
            
            <!-- Фильтр по дате (От и До) -->
            <input type="date" id="dateStart" class="input-modern" title="Начало периода">
            <span class="text-muted">–</span>
            <input type="date" id="dateEnd" class="input-modern" title="Конец периода">
            
            <!-- Кнопка обновления реестра с сервера -->
            <button class="btn btn-blue docs-apply-btn" onclick="loadDocsRegistry()">🔍 Применить</button>

            <div class="form-group docs-option-wrap">
                <label class="docs-option-label">
                    <input type="checkbox" id="toggle-cancelled-docs" onchange="renderRegistryTable(allRegistryDocs)"> 
                    👁️ Показывать аннулированные
                </label>
            </div>
        </div>

        <!-- Кнопка выгрузки в 1С -->
        <div class="toolbar-group">
            <button class="btn btn-blue" id="btn-export-1c" disabled onclick="exportTo1C()">📥 Выгрузить выбранное (XML)</button>
        </div>
    </div>

    <div class="table-container">
        <table class="table">
            <thead>
                <tr>
                    <th class="docs-col-check">
                        <input type="checkbox" id="reg-check-all" onchange="toggleAllRegistryChecks(this)">
                    </th>
                    <th class="docs-col-date">Дата выписки</th>
                    <th class="docs-col-docnum">Документ №</th>
                    <th>Контрагент</th>
                    <th class="text-right docs-col-total">Итого к оплате</th>
                    <th class="docs-col-author">Автор (Менеджер)</th>
                    <th class="text-center docs-col-status">Статус 1С</th>
                    <th class="docs-col-actions"></th>
                </tr>
            </thead>
            <tbody id="unique-registry-tbody">
                <tr>
                    <td colspan="7" class="text-center text-muted">Загрузка данных...</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>