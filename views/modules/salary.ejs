<div id="salary-mod" class="module">
    <div class="flex-between mb-20 align-end">
        <div class="w-100">
            <h2 class="mt-0">👷‍♂️ Кадры, Табель и Зарплата</h2>
            <div class="summary-grid" id="salary-summary-boxes"></div>
            <p class="text-muted font-13 m-0">Управление сотрудниками, окладами и рабочим временем</p>
        </div>
    </div>

    <div class="accordion-header hr-accordion-success" onclick="toggleAccordion('acc-employees', this)">
        <div>👥 База сотрудников и оклады</div>
        <div class="icon">▼</div>
    </div>
    <div id="acc-employees" class="accordion-body">
        <div class="flex-between mb-15 card-alt hr-toolbar-panel">
            <div class="toolbar-group flex-grow-1 hr-toolbar-filters">
                <input type="text" id="emp-search-input" class="input-modern flex-grow-1" placeholder="🔍 Поиск по ФИО..." oninput="filterEmployees()">
                <select id="emp-dep-filter" class="input-modern hr-dep-select" onchange="filterEmployees()">
                    <option value="all">Все отделы</option>
                    <option value="Офис">Офис</option>
                    <option value="Цех">Цех</option>
                    <option value="Охрана">Охрана</option>
                </select>
            </div>
            <button class="btn btn-blue" onclick="openEmployeeForm()">➕ Добавить сотрудника</button>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>ФИО</th>
                        <th>Должность</th>
                        <th>Отдел / График</th>
                        <th class="text-right">Оклад (Нал)</th>
                        <th class="text-right">Офиц. ЗП</th>
                        <th class="text-right">Налог</th>
                        <th class="text-right">Текущий остаток</th>
                        <th class="text-center hr-action-col">Действие</th>
                    </tr>
                </thead>
                <tbody id="employees-table-body"></tbody>
            </table>
        </div>

        <div class="accordion-header mt-20 hr-accordion-danger" onclick="toggleAccordion('acc-fired-employees', this)">
            <div>🗑️ Архив (Уволенные сотрудники)</div>
            <div class="icon">▼</div>
        </div>
        <div id="acc-fired-employees" class="accordion-body hr-fired-section">
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>ФИО</th>
                            <th>Должность</th>
                            <th>Последний отдел</th>
                            <th class="text-right">Финальный долг</th>
                            <th class="text-center hr-action-col">Действие</th>
                        </tr>
                    </thead>
                    <tbody id="fired-employees-table-body"></tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="accordion-header mt-20 hr-accordion-primary" onclick="toggleAccordion('acc-timesheet', this)">
        <div>📅 Электронный табель учета времени</div>
        <div class="icon">▼</div>
    </div>
    <div id="acc-timesheet" class="accordion-body">
        <div class="flex-between mb-15 card-alt hr-toolbar-panel">
            <div class="toolbar-group flex-grow-1">
                <input type="month" id="ts-month-picker" class="input-modern hr-month-picker" onchange="syncSalaryMonth(this.value)">
                <input type="text" id="ts-search-input" class="input-modern flex-grow-1 hr-ts-search" placeholder="🔍 Поиск в табеле..." oninput="reRenderTimesheet()">
                <select id="ts-dep-filter" class="input-modern hr-dep-select" onchange="reRenderTimesheet()">
                    <option value="all">Все отделы</option>
                    <option value="Офис">Офис</option>
                    <option value="Цех">Цех</option>
                    <option value="Охрана">Охрана</option>
                </select>
                <button class="btn btn-outline btn-outline-success" onclick="fillTodayBySchedule()" title="Заполнить явку всем сотрудникам 5/2 за текущий день">⚡ Заполнить 5/2 (Сегодня)</button>
            </div>

            <div class="toolbar-group">
                <span class="text-muted hr-hint-text">* Клик на ячейку для смены статуса</span>
                <button class="btn btn-outline" onclick="printTimesheet()">🖨️ Печать</button>
            </div>
        </div>
        <div id="timesheet-container" class="table-container timesheet-container hr-timesheet-wrapper">
            <table class="hr-timesheet-table">
                <thead id="monthly-ts-head"></thead>
                <tbody id="monthly-ts-body">
                    <tr>
                        <td class="text-center text-muted hr-loading-cell">Загрузка табеля...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="admin-only">
        <div class="accordion-header mt-20 hr-accordion-warning" onclick="toggleAccordion('acc-payouts', this)">
            <div>💰 Расчет выплат и выдача ЗП</div>
            <div class="icon">▼</div>
        </div>
        <div id="acc-payouts" class="accordion-body">
            <div id="salary-summary-boxes" class="summary-grid"></div>

            <p class="payroll-header-formula text-muted" id="payout-month-title">Расчетный лист</p>

            <div class="payroll-mega-toolbar">
                <input type="month" id="payroll-period-select" class="input-modern payroll-month-input" onchange="syncSalaryMonth(this.value)">
                <button class="btn btn-outline admin-only payroll-reopen-btn" id="reopen-month-btn-payroll" onclick="reopenSalaryMonth()">🔓 Отменить закрытие</button>
                <div class="payroll-divider"></div>
                <input type="text" id="pay-search-input" class="input-modern payroll-search-input" placeholder="🔍 Поиск сотрудника..." oninput="reRenderTimesheet()">
                <select id="pay-dep-filter" class="input-modern payroll-dep-select" onchange="reRenderTimesheet()">
                    <option value="all">Все отделы</option>
                    <option value="Офис">Офис</option>
                    <option value="Цех">Цех</option>
                    <option value="Охрана">Охрана</option>
                </select>
                <div class="payroll-divider"></div>
                <button class="btn btn-outline btn-outline-info" onclick="openPieceRateModal()">🏭 Сдельная ЗП</button>
                <button class="btn btn-outline" onclick="printAdvancesSheet()">🖨️ Авансы</button>
                <button class="btn btn-outline btn-outline-success" onclick="exportAdvancesToCSV()">📊 Excel (Авансы)</button>
                <div class="payroll-divider"></div>
                <button class="btn btn-outline" onclick="printSalarySheet()">🖨️ ЗП</button>
                <button class="btn btn-outline btn-outline-primary" onclick="exportSalaryToCSV()">📊 Excel (ЗП)</button>
            </div>
            
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th class="hr-employee-col">Сотрудник</th>
                            <th class="text-right">Заработал</th>
                            <th class="text-right text-primary">± Остаток</th>
                            <th class="text-right text-danger">Налоги</th>
                            <th class="text-right text-muted">Авансы</th>
                            <th class="text-right text-warning">Доп. операции</th>
                            <th class="text-right status-work">К ВЫДАЧЕ</th>
                            <th class="text-center">Действие</th>
                        </tr>
                    </thead>
                    <tbody id="payouts-table-body">
                        <tr>
                            <td colspan="8" class="text-center text-muted hr-loading-cell">Загрузка расчетов...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>