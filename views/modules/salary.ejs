<div id="salary-mod" class="module">
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px;">
        <div>
            <h2>👷‍♂️ Кадры, Табель и Зарплата</h2>
            <div class="form-grid" style="grid-template-columns: repeat(4, 1fr); margin-bottom: 20px;"
                id="salary-summary-boxes">
            </div>
            <p style="font-size: 13px; color: var(--text-muted); margin: 0;">Управление сотрудниками, окладами и рабочим
                временем</p>
        </div>
    </div>

    <div class="accordion-header" onclick="toggleAccordion('acc-employees', this)"
        style="border-left: 4px solid var(--success);">
        <div>👥 База сотрудников и оклады</div>
        <div class="icon">▼</div>
    </div>
    <div id="acc-employees" class="accordion-body">
        <div
            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; background: #f8fafc; padding: 10px; border-radius: 8px; border: 1px solid var(--border);">
            <div style="display: flex; gap: 10px;">
                <input type="text" id="emp-search-input" class="input-modern"
                    placeholder="🔍 Поиск по ФИО или должности..." oninput="renderEmployeesTable()"
                    style="width: 250px;">
                <select id="emp-dep-filter" class="input-modern" onchange="renderEmployeesTable()">
                    <option value="all">🌐 Все отделы</option>
                    <option value="Офис">Офис</option>
                    <option value="Цех">Цех</option>
                    <option value="Охрана">Охрана</option>
                </select>
            </div>
            <button class="btn btn-outline" style="border-color: var(--success); color: var(--success);"
                onclick="openEmployeeModal()">➕ Добавить сотрудника</button>
        </div>
        <div class="table-container">
            <table>
                <thead style="background: #f8fafc;">
                    <tr>
                        <th>ФИО</th>
                        <th>Должность</th>
                        <th>Отдел (График)</th>
                        <th style="text-align: right;">Оклад (Нал)</th>
                        <th style="text-align: right;">Офиц. ЗП</th>
                        <th style="text-align: right; color: var(--danger);">Удержание (Нал)</th>
                        <th style="text-align: right; color: var(--primary);">± Остаток</th>
                        <th style="text-align: center;">Действия</th>
                    </tr>
                </thead>
                <tbody id="employees-table-body">
                    <tr>
                        <td colspan="8" style="text-align: center;">Загрузка...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="accordion-header open" onclick="toggleAccordion('acc-timesheet', this)"
        style="border-left: 4px solid var(--primary);">
        <div>📅 Матричный табель рабочего времени</div>
        <div class="icon">▼</div>
    </div>
    <div id="acc-timesheet" class="accordion-body active">
        <div
            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; background: #f8fafc; padding: 15px; border-radius: 8px; border: 1px solid var(--border);">
            <div style="display: flex; gap: 10px; align-items: center;">
                <span style="font-weight: bold;">Архив табелей:</span>
                <input type="month" id="ts-month-picker" class="input-modern"
                    style="width: 150px; display: inline-block;" onchange="loadMonthlyTimesheet()">
                <button class="btn btn-outline"
                    style="border-color: var(--primary); color: var(--primary); padding: 6px 12px; margin-left: 10px;"
                    onclick="openPieceRateModal()">
                    🏭 Начислить сделку (Цех)
                </button>
                <button class="btn btn-green" style="padding: 6px 12px; font-size: 13px;"
                    onclick="fillTodayBySchedule()">
                    ✅ Заполнить по графику (Сегодня)
                </button>
            </div>
            <div style="display: flex; gap: 10px; font-size: 12px; font-weight: 600;">
                <span style="display:flex; align-items:center; gap:5px;">
                    <div class="ts-cell status-present" style="width:16px; height:16px;"></div> Был
                </span>
                <span style="display:flex; align-items:center; gap:5px;">
                    <div class="ts-cell status-absent" style="width:16px; height:16px;"></div> Прогул
                </span>
                <span style="display:flex; align-items:center; gap:5px;">
                    <div class="ts-cell status-sick" style="width:16px; height:16px;"></div> Болел
                </span>
                <span style="display:flex; align-items:center; gap:5px;">
                    <div class="ts-cell status-vacation" style="width:16px; height:16px;"></div> Отпуск
                </span>
            </div>
        </div>

        <div class="table-container" style="overflow-x: auto;">
            <table id="monthly-ts-table" style="min-width: 1000px;">
                <thead id="monthly-ts-head"></thead>
                <tbody id="monthly-ts-body">
                    <tr>
                        <td style="text-align: center; padding: 30px;">Загрузка матрицы...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="accordion-header" onclick="toggleAccordion('acc-payouts', this)"
        style="border-left: 4px solid var(--danger);">
        <div>💳 Выдача Авансов и Зарплаты (Касса)</div>
        <div class="icon">▼</div>
    </div>
    <div id="acc-payouts" class="accordion-body">
        <p style="font-size: 13px; color: var(--text-muted); margin-top: 0;">Расчет: Заработано на сегодня - Налоги (13%
            с офиц. ЗП) ± Долг с прошлого месяца - Выданные авансы = К получению.</p>

        <div class="table-container">
            <table>
                <thead style="background: #f8fafc;">
                    <tr>
                        <th width="20%">Сотрудник</th>
                        <th style="text-align: right; font-weight: bold;">Заработал на сегодня</th>
                        <th style="text-align: right; color: var(--primary);">± Остаток</th>
                        <th style="text-align: right; color: var(--danger);">Удержание (Налоги)</th>
                        <th style="text-align: right; color: var(--text-muted);">Авансы (тек. мес)</th>
                        <th style="text-align: right; color: #d97706;">Доп. операции</th>
                        <th style="text-align: right; background: #dcfce3; color: var(--success); font-size: 14px;">К
                            ВЫДАЧЕ</th>
                        <th style="text-align: center;">Действие</th>
                    </tr>
                </thead>
                <tbody id="payouts-table-body">
                    <tr>
                        <td colspan="7" style="text-align: center;">Загрузка расчетов...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>