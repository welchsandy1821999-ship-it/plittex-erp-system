<div id="salary-mod" class="module">
    <div class="flex-between mb-20" style="align-items: flex-end;">
        <div class="w-100">
            <h2 class="mt-0">👷‍♂️ Кадры, Табель и Зарплата</h2>
            <div class="summary-grid" id="salary-summary-boxes"></div>
            <p class="text-muted" style="font-size: 13px; margin: 0;">Управление сотрудниками, окладами и рабочим временем</p>
        </div>
    </div>

    <div class="accordion-header" onclick="toggleAccordion('acc-employees', this)" style="border-left: 4px solid var(--success);">
        <div>👥 База сотрудников и оклады</div>
        <div class="icon">▼</div>
    </div>
    <div id="acc-employees" class="accordion-body">
        <div class="flex-between mb-15 card-alt" style="padding: 10px; border-radius: 8px;">
            <div class="toolbar-group flex-grow-1" style="max-width: 600px;">
                <input type="text" id="emp-search-input" class="input-modern flex-grow-1" placeholder="🔍 Поиск по ФИО..." oninput="filterEmployees()">
                <select id="emp-dep-filter" class="input-modern" style="width: 180px;" onchange="filterEmployees()">
                    <option value="all">Все отделы</option>
                    <option value="Офис">Офис</option>
                    <option value="Цех">Цех</option>
                    <option value="Охрана">Охрана</option>
                </select>
            </div>
            <button class="btn btn-blue" onclick="openEmployeeForm()">➕ Добавить сотрудника</button>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>ФИО</th>
                        <th>Должность</th>
                        <th>Отдел / График</th>
                        <th class="text-right">Оклад (Нал)</th>
                        <th class="text-right">Офиц. ЗП</th>
                        <th class="text-right">Налог</th>
                        <th class="text-right">Текущий остаток</th>
                        <th class="text-center" style="width: 80px;">Действие</th>
                    </tr>
                </thead>
                <tbody id="employees-table-body"></tbody>
            </table>
        </div>

        <div class="accordion-header mt-20" onclick="toggleAccordion('acc-fired-employees', this)" style="border-left: 4px solid var(--danger);">
            <div>🗑️ Архив (Уволенные сотрудники)</div>
            <div class="icon">▼</div>
        </div>
        <div id="acc-fired-employees" class="accordion-body" style="background: var(--danger-bg);">
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>ФИО</th>
                            <th>Должность</th>
                            <th>Последний отдел</th>
                            <th class="text-right">Финальный долг</th>
                            <th class="text-center" style="width: 80px;">Действие</th>
                        </tr>
                    </thead>
                    <tbody id="fired-employees-table-body"></tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="accordion-header mt-20" onclick="toggleAccordion('acc-timesheet', this)" style="border-left: 4px solid var(--primary);">
        <div>📅 Электронный табель учета времени</div>
        <div class="icon">▼</div>
    </div>
    <div id="acc-timesheet" class="accordion-body">
        <div class="flex-between mb-15 card-alt" style="padding: 10px; border-radius: 8px;">
            <div class="toolbar-group flex-grow-1">
                <input type="month" id="ts-month-picker" class="input-modern" style="width: 160px; font-weight: bold;" onchange="loadMonthlyTimesheet()">
                <input type="text" id="ts-search-input" class="input-modern flex-grow-1" style="max-width: 250px;" placeholder="🔍 Поиск в табеле..." oninput="reRenderTimesheet()">
                <select id="ts-dep-filter" class="input-modern" style="width: 150px;" onchange="reRenderTimesheet()">
                    <option value="all">Все отделы</option>
                    <option value="Офис">Офис</option>
                    <option value="Цех">Цех</option>
                    <option value="Охрана">Охрана</option>
                </select>
                <button class="btn btn-outline btn-outline-success" onclick="fillTodayBySchedule()" title="Заполнить явку всем сотрудникам 5/2 за текущий день">⚡ Заполнить 5/2 (Сегодня)</button>
            </div>

            <div class="toolbar-group">
                <span class="text-muted" style="font-size: 11px; max-width: 120px; line-height: 1.2;">* Клик на ячейку для смены статуса</span>
                <button class="btn btn-outline" onclick="printTimesheet()">🖨️ Печать</button>
            </div>
        </div>
        <div id="timesheet-container" class="table-container timesheet-container" style="overflow-x: auto;">
            <table style="min-width: 1200px;">
                <thead id="monthly-ts-head"></thead>
                <tbody id="monthly-ts-body">
                    <tr>
                        <td class="text-center text-muted" style="padding: 20px;">Загрузка табеля...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="admin-only">
        <div class="accordion-header mt-20" onclick="toggleAccordion('acc-payouts', this)" style="border-left: 4px solid var(--warning);">
            <div>💰 Расчет выплат и выдача ЗП</div>
            <div class="icon">▼</div>
        </div>
        <div id="acc-payouts" class="accordion-body">
            <div id="salary-summary-boxes" class="summary-grid"></div>

            <div class="flex-between mb-15">
                <h3 class="mt-0" style="font-size: 16px;" id="payout-month-title">Расчетный лист за период</h3>
                <p class="text-muted mb-0" style="font-size: 12px;">Формула: Начислено ± Остаток - Налоги - Авансы ± Доп. операции = К выдаче</p>
            </div>

            <div class="flex-between mb-15 card-alt" style="padding: 10px; border-radius: 8px; flex-wrap: wrap; gap: 15px;">
                <div class="toolbar-group flex-grow-1" style="min-width: 300px;">
                    <input type="text" id="pay-search-input" class="input-modern flex-grow-1" placeholder="🔍 Поиск сотрудника..." oninput="reRenderTimesheet()">
                    <select id="pay-dep-filter" class="input-modern" style="width: 150px;" onchange="reRenderTimesheet()">
                        <option value="all">Все отделы</option>
                        <option value="Офис">Офис</option>
                        <option value="Цех">Цех</option>
                        <option value="Охрана">Охрана</option>
                    </select>
                </div>

                <div class="toolbar-group">
                    <button class="btn btn-outline btn-outline-info" onclick="openPieceRateModal()">🏭 Сдельная ЗП</button>
                    <div class="v-divider"></div>
                    <button class="btn btn-outline" onclick="printAdvancesSheet()">🖨️ Авансы</button>
                    <button class="btn btn-outline btn-outline-success" onclick="exportAdvancesToCSV()">📊 Excel (Авансы)</button>
                    <div class="v-divider"></div>
                    <button class="btn btn-outline" onclick="printSalarySheet()">🖨️ ЗП</button>
                    <button class="btn btn-outline btn-outline-primary" onclick="exportSalaryToCSV()">📊 Excel (ЗП)</button>
                </div>
            </div>
            
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th width="20%">Сотрудник</th>
                            <th class="text-right">Заработал</th>
                            <th class="text-right text-primary">± Остаток</th>
                            <th class="text-right text-danger">Налоги</th>
                            <th class="text-right text-muted">Авансы</th>
                            <th class="text-right text-warning">Доп. операции</th>
                            <th class="text-right status-work">К ВЫДАЧЕ</th>
                            <th class="text-center">Действие</th>
                        </tr>
                    </thead>
                    <tbody id="payouts-table-body">
                        <tr>
                            <td colspan="8" class="text-center text-muted" style="padding: 20px;">Загрузка расчетов...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>