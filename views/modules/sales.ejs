<style>
    /* Стили для вкладок (Табов) */
    .sales-tabs {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        border-bottom: 2px solid var(--border);
        padding-bottom: 15px;
    }

    .sales-tab-btn {
        padding: 10px 20px;
        cursor: pointer;
        border-radius: 6px;
        background: #f8fafc;
        border: 1px solid var(--border);
        font-weight: bold;
        color: var(--text-muted);
        transition: 0.2s;
    }

    .sales-tab-btn:hover {
        background: #e2e8f0;
    }

    .sales-tab-btn.active {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
    }

    .sales-tab-content {
        display: none;
        animation: fadeIn 0.3s ease-in-out;
    }

    .sales-tab-content.active {
        display: block;
    }

    .action-dropdown {
        position: relative;
        display: inline-block;
        /* Создаем невидимый мостик для мышки, чтобы она не проваливалась */
        padding-bottom: 10px;
        margin-bottom: -10px;
    }

    .action-dropdown-content {
        display: none;
        position: absolute;
        right: 0;
        top: 100%;
        background-color: #fff;
        min-width: 230px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        /* Чуть усилили тень для красоты */
        border-radius: 8px;
        border: 1px solid var(--border);
        z-index: 100;
        overflow: hidden;
        /* Убрали margin-top, который создавал обрыв для мышки */
        animation: fadeIn 0.2s ease-in-out;
    }

    .action-dropdown-content button {
        width: 100%;
        text-align: left;
        padding: 12px 15px;
        background: none;
        border: none;
        border-bottom: 1px solid #f1f5f9;
        cursor: pointer;
        color: #475569;
        font-size: 13px;
        transition: 0.2s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .action-dropdown-content button:hover {
        background-color: #f8fafc;
        color: var(--primary);
        padding-left: 20px;
    }

    .action-dropdown-content button:last-child {
        border-bottom: none;
    }

    .action-dropdown:hover .action-dropdown-content {
        display: block;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(5px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div id="sales-mod" class="module">
    <div
        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 15px;">
        <div>
            <h2 style="margin: 0 0 5px 0;">🛒 Отгрузка и Продажи</h2>
            <p style="font-size: 13px; color: var(--text-muted); margin: 0;">Управление заказами (OMS) и реализация</p>
        </div>

        <div style="display: flex; gap: 10px; align-items: center;">

            <button class="btn btn-outline" onclick="openClientDocsModal()"
                style="padding: 8px 16px; border-color: #0ea5e9; color: #0ea5e9;">
                🖨️ Документы клиенту
            </button>
            <button class="btn btn-outline" onclick="openReturnModal()"
                style="padding: 8px 16px; border-color: #f59e0b; color: #f59e0b;">
                🔙 Возврат
            </button>

            <div class="action-dropdown">
                <button class="btn btn-outline"
                    style="padding: 8px 15px; display: flex; align-items: center; gap: 8px; font-weight: bold; background: #f8fafc;">
                    ⚙️ Инструменты и Отчеты <span style="font-size: 10px;">▼</span>
                </button>
                <div class="action-dropdown-content">
                    <button onclick="openSalesDashboard()">📊 Дашборд продаж</button>
                    <button onclick="openLogisticsCalendar()">🚚 Календарь логиста</button>
                    <button onclick="openPalletsReport()">📦 Отчет по таре</button>
                    <button onclick="openPriceListModal()">📋 Установка Прайс-листа</button>
                    <button style="color: #10b981; font-weight: bold; background: #ecfdf5;"
                        onclick="openExport1CModal()">📥 Выгрузить в 1С (Excel)</button>
                </div>
            </div>

        </div>
    </div>

    <div class="sales-tabs">
        <div class="sales-tab-btn active" onclick="switchSalesTab('tab-new-order', this)">➕ Новый заказ / Отгрузка</div>
        <div class="sales-tab-btn" onclick="switchSalesTab('tab-active-orders', this)">📦 Управление заказами</div>
        <div class="sales-tab-btn" onclick="switchSalesTab('tab-history', this)">📜 Архив отгрузок</div>
    </div>

    <div id="tab-new-order" class="sales-tab-content active">
        <div class="form-grid" style="grid-template-columns: 1fr 2fr; gap: 20px; align-items: start;">

            <div class="card" style="margin: 0; border-top: 4px solid var(--primary);">
                <h3 style="margin-top: 0;">1. Контрагент и продукция</h3>

                <div class="form-group">
                    <label>Клиент (Контрагент):</label>
                    <select id="sale-client" class="input-modern" onchange="onClientChange()"></select>

                    <div id="sale-client-info"
                        style="display: none; margin-top: 10px; padding: 10px; background: #fdf2f8; border: 1px dashed #f472b6; border-radius: 6px; font-size: 13px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                            <span style="color: #831843;">Текущий долг:</span>
                            <strong id="sale-client-debt" style="color: #e11d48;">0 ₽</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                            <span style="color: #831843;">Долг по поддонам:</span>
                            <strong id="sale-client-pallets" style="color: #d97706;">0 шт.</strong>
                        </div>
                        <button class="btn btn-outline" onclick="printClientAct()"
                            style="width: 100%; margin-top: 5px; padding: 4px; font-size: 12px; border-color: #f472b6; color: #db2777;">
                            🖨️ Распечатать Акт сверки
                        </button>
                    </div>
                </div>

                <div class="form-group" id="sale-contract-group"
                    style="display: none; margin-top: 15px; padding: 10px; background: #f8fafc; border-radius: 6px; border: 1px solid #e2e8f0;">
                    <label style="color: #475569; font-size: 12px;">Основание (Договор / Спецификация):</label>
                    <div style="display: flex; gap: 5px;">
                        <select id="sale-contract" class="input-modern"
                            style="flex-grow: 1; border-color: #cbd5e1;"></select>
                        <button class="btn btn-outline" onclick="printSelectedContract()"
                            title="Распечатать этот договор"
                            style="padding: 0 12px; border-color: #0ea5e9; color: #0ea5e9;">🖨️</button>
                        <button class="btn btn-outline" onclick="openContractManager()" title="Управление договорами"
                            style="padding: 0 12px; border-color: #cbd5e1;">⚙️</button>
                    </div>
                </div>

                <div class="form-group"
                    style="margin-top: 20px; padding-top: 15px; border-top: 1px dashed var(--border);">
                    <label style="color: #d97706; font-weight: bold;">Режим поиска и распределения:</label>
                    <select id="sale-warehouse" class="input-modern" onchange="changeSaleWarehouse()">
                        <option value="all" selected>🌐 Весь справочник (Авто: Резерв + Производство)</option>
                        <option value="4">🟢 Склад №4 (Строго из наличия 1-го сорта)</option>
                        <option value="5">🟡 Склад №5 (Строго из наличия Уценки)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Поиск (Весь справочник):</label>
                    <input type="text" id="sale-product-input" class="input-modern" list="sale-products-datalist"
                        placeholder="Например: Прямоугольник..." autocomplete="off" oninput="updateSaleMaxQty()">
                    <datalist id="sale-products-datalist"></datalist>
                </div>

                <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 15px; align-items: start;">
                    <div class="form-group" style="margin: 0;">
                        <label>Кол-во <span id="sale-unit-label"
                                style="color: var(--primary); font-weight: bold;"></span>:</label>
                        <input type="number" id="sale-qty" class="input-modern" placeholder="1" min="0.1" step="0.1">
                        <div style="min-height: 16px; margin-top: 4px;">
                            <small id="sale-max-qty" style="color: var(--text-muted); font-size: 11px;">Остаток:
                                0</small>
                        </div>
                    </div>
                    <div class="form-group" style="margin: 0;">
                        <label>Цена за ед (₽):</label>
                        <input type="number" id="sale-price" class="input-modern" placeholder="0"
                            onfocus="this.select()">
                    </div>
                </div>
                <button class="btn btn-outline" onclick="addToCart()"
                    style="width: 100%; border-color: var(--primary); color: var(--primary); margin-top: 10px;">
                    ⬇️ Добавить в спецификацию заказа
                </button>
            </div>

            <div class="card" style="margin: 0; display: flex; flex-direction: column; min-height: 100%;">
                <h3 style="margin-top: 0;">2. Состав заказа</h3>
                <div
                    style="flex-grow: 1; border: 1px solid var(--border); border-radius: 6px; overflow: hidden; margin-bottom: 15px;">
                    <table style="margin: 0; width: 100%;">
                        <thead style="background: #f1f5f9;">
                            <tr>
                                <th style="padding: 10px;">Сорт</th>
                                <th style="padding: 10px;">Наименование</th>
                                <th style="padding: 10px; text-align: center;">Кол-во</th>
                                <th style="padding: 10px; text-align: center;">Цена (₽)</th>
                                <th style="padding: 10px; text-align: center; color: var(--danger);">Скидка (%)</th>
                                <th style="padding: 10px; text-align: right;">Сумма</th>
                                <th style="padding: 10px; text-align: center;">✖</th>
                            </tr>
                        </thead>
                        <tbody id="cart-table">
                            <tr>
                                <td colspan="5" style="text-align: center; color: var(--text-muted); padding: 20px;">
                                    Корзина пуста</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div
                    style="background: #f8fafc; padding: 15px; border-radius: 6px; border: 1px solid var(--border); margin-bottom: 15px;">
                    <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 10px;">
                        <div>
                            <span style="font-size: 13px; color: var(--text-muted);">Скидка на чек (%):</span>
                            <input type="number" id="sale-discount" class="input-modern" style="padding: 6px;"
                                placeholder="0" min="0" max="100" oninput="renderCart()">
                        </div>
                        <div>
                            <span style="font-size: 13px; color: var(--text-muted);">Стоимость доставки (₽):</span>
                            <input type="number" id="sale-logistics-cost" class="input-modern" style="padding: 6px;"
                                value="0" min="0" oninput="renderCart()">
                        </div>
                    </div>

                    <div style="display: flex; justify-content: space-between; font-size: 14px; margin-bottom: 5px;">
                        <span>Общий вес продукции:</span>
                        <strong><span id="cart-total-weight">0</span> кг</strong>
                    </div>
                    <div
                        style="display: flex; justify-content: space-between; font-size: 18px; color: var(--primary); margin-top: 10px; border-top: 1px solid #e2e8f0; padding-top: 10px;">
                        <span>Итого к оплате (с доставкой):</span>
                        <div>
                            <s id="cart-original-sum"
                                style="color: #94a3b8; font-size: 14px; display: none; margin-right: 10px;">0 ₽</s>
                            <strong><span id="cart-total-sum">0</span> ₽</strong>
                        </div>
                    </div>
                </div>

                <div style="margin-bottom: 15px; border-bottom: 1px dashed var(--border); padding-bottom: 15px;">
                    <h4 style="margin: 0 0 10px 0; color: #475569;">📍 Детали доставки и тара</h4>
                    <div class="form-group" style="margin-bottom: 10px;">
                        <label>Адрес объекта (доставки):</label>
                        <input type="text" id="sale-delivery-address" class="input-modern"
                            placeholder="г. Армавир, ул. Ленина 1">
                    </div>
                    <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 10px;">
                        <div class="form-group" style="margin: 0;">
                            <label>Желаемая дата отгрузки:</label>
                            <input type="date" id="sale-planned-date" class="input-modern">
                        </div>
                        <div class="form-group" style="margin: 0;">
                            <label>Поддоны (в долг), шт:</label>
                            <input type="number" id="sale-pallets" class="input-modern" placeholder="Количество"
                                min="0">
                        </div>
                    </div>
                </div>

                <div style="margin-bottom: 15px; border-bottom: 1px dashed var(--border); padding-bottom: 15px;">
                    <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px;">
                        <div class="form-group" style="margin: 0;">
                            <label>ФИО Водителя:</label>
                            <input type="text" id="sale-driver" class="input-modern" placeholder="Иванов И.И.">
                        </div>
                        <div class="form-group" style="margin: 0;">
                            <label>Автомобиль:</label>
                            <input type="text" id="sale-auto" class="input-modern" placeholder="Гос. номер (Е123КХ)">
                        </div>
                    </div>

                    <div style="background: #fef2f2; padding: 10px; border-radius: 6px; border: 1px solid #fecaca;">
                        <div
                            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                            <label style="font-weight: bold; color: #991b1b; font-size: 13px;">Юридическое основание
                                (Доверенность):</label>
                            <label
                                style="font-size: 12px; display: flex; align-items: center; gap: 5px; cursor: pointer; color: #ef4444; font-weight: bold;">
                                <input type="checkbox" id="sale-no-poa" onchange="togglePoaMode()"> Отгрузка без
                                доверенности
                            </label>
                        </div>
                        <div id="poa-select-group" style="display: flex; gap: 5px;">
                            <select id="sale-poa" class="input-modern"
                                style="flex-grow: 1; border-color: #fca5a5;"></select>
                            <button class="btn btn-outline" onclick="openPoaManager()" title="Добавить доверенность"
                                style="padding: 0 12px; border-color: #fca5a5;">➕</button>
                        </div>
                        <div id="poa-comment-group" style="display: none; margin-top: 10px;">
                            <input type="text" id="sale-poa-comment" class="input-modern"
                                placeholder="Укажите, кто разрешил отгрузку без доверенности"
                                style="border-color: #ef4444; background: #fff;">
                        </div>
                    </div>
                </div>

                <div style="margin-bottom: 15px;">
                    <div class="form-group" style="margin-bottom: 10px;">
                        <label>Оплата:</label>
                        <select id="sale-payment-method" class="input-modern" onchange="toggleSalePayment()">
                            <option value="debt">⏳ В долг (Счет на оплату / Ожидаем)</option>
                            <option value="paid">💰 Оплачено полностью</option>
                            <option value="partial">🌗 Частичная оплата (Аванс)</option>
                        </select>
                    </div>

                    <div class="form-group" id="sale-advance-group" style="display: none; margin-bottom: 10px;">
                        <label style="color: #d97706; font-weight: bold;">Сумма внесенного аванса (₽):</label>
                        <input type="number" id="sale-advance-amount" class="input-modern" placeholder="Например: 50000"
                            style="border-color: #f59e0b; background: #fffbeb;">
                    </div>

                    <div class="form-group" id="sale-account-group" style="display: none; margin-bottom: 0;">
                        <label>В какую кассу/счет поступили деньги?</label>
                        <select id="sale-account" class="input-modern"></select>
                    </div>
                </div>

                <div style="display: flex; gap: 10px; margin-top: auto;">
                    <button class="btn btn-outline" onclick="generateKP()"
                        style="flex: 1; padding: 12px; font-size: 14px; border-color: #8b5cf6; color: #8b5cf6;"
                        title="Создать печатную форму КП без сохранения в базу">
                        🖨️ Печать Бланк-заказа
                    </button>
                    <button class="btn btn-blue" onclick="processCheckout()"
                        style="flex: 2; padding: 12px; font-size: 16px;">
                        💾 Оформить заказ
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="tab-active-orders" class="sales-tab-content">
        <div class="card" style="margin: 0; min-height: 400px;">

            <div
                style="background: #f8fafc; padding: 15px; border-radius: 8px; border: 1px solid var(--border); margin-bottom: 15px;">
                <div class="form-grid"
                    style="grid-template-columns: 2fr 1.5fr 1.5fr 1.5fr auto; gap: 10px; align-items: end;">
                    <div class="form-group" style="margin: 0;">
                        <label>🔍 Текст (Номер, Адрес):</label>
                        <input type="text" id="bo-search" class="input-modern" placeholder="Поиск..."
                            oninput="applyOrderFilters()">
                    </div>
                    <div class="form-group" style="margin: 0;">
                        <label>👤 Клиент:</label>
                        <select id="bo-client-filter" class="input-modern" onchange="applyOrderFilters()">
                            <option value="">🌐 Все клиенты</option>
                        </select>
                    </div>
                    <div class="form-group" style="margin: 0;">
                        <label>📦 В составе есть (Товар):</label>
                        <input type="text" id="bo-product-filter" class="input-modern" placeholder="Название..."
                            oninput="applyOrderFilters()">
                    </div>
                    <div class="form-group" style="margin: 0;">
                        <label>🚦 Статус оплаты:</label>
                        <select id="bo-status-filter" class="input-modern" onchange="applyOrderFilters()">
                            <option value="">Все статусы</option>
                            <option value="debt">🔴 Есть долг</option>
                            <option value="paid">🟢 Оплачено 100%</option>
                        </select>
                    </div>
                    <button class="btn btn-outline" onclick="resetOrderFilters()" title="Сбросить фильтры"
                        style="padding: 8px 12px; height: 38px;">🔄</button>
                </div>
            </div>
            <div class="table-container" style="margin: 0;">
                <table style="width: 100%;">
                    <thead style="background: #f1f5f9;">
                        <tr>
                            <th style="width: 15%;">Дата / Дедлайн</th>
                            <th style="width: 15%;">Документ</th>
                            <th style="width: 25%;">Клиент и Адрес</th>
                            <th style="width: 20%;">Состав (Товары)</th>
                            <th style="width: 10%; text-align: center;">Статус</th>
                            <th style="width: 15%; text-align: right;">Действия</th>
                        </tr>
                    </thead>
                    <tbody id="blank-orders-table">
                        <tr>
                            <td colspan="6" style="text-align: center; color: var(--text-muted); padding: 20px;">
                                Загрузка...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div
                style="display: flex; justify-content: space-between; align-items: center; margin-top: 15px; padding: 10px; background: #f8fafc; border-radius: 8px; border: 1px solid var(--border);">
                <button class="btn btn-outline" onclick="changeBlankOrderPage(-1)">⬅ Назад</button>
                <span style="font-size: 13px; color: var(--text-muted);" id="bo-page-info">Страница 1 из 1</span>
                <button class="btn btn-outline" onclick="changeBlankOrderPage(1)">Вперед ➡</button>
            </div>
        </div>
    </div>

    <div id="tab-history" class="sales-tab-content">
        <div class="card" style="margin: 0; min-height: 400px;">

            <div
                style="background: #f8fafc; padding: 15px; border-radius: 8px; border: 1px solid var(--border); margin-bottom: 15px;">
                <div class="form-grid"
                    style="grid-template-columns: 2fr 1.5fr 2.5fr auto; gap: 10px; align-items: end;">
                    <div class="form-group" style="margin: 0;">
                        <label>🔍 Номер документа:</label>
                        <input type="text" id="hist-search" class="input-modern" placeholder="Поиск..."
                            oninput="applyHistoryFilters()">
                    </div>
                    <div class="form-group" style="margin: 0;">
                        <label>👤 Клиент:</label>
                        <select id="hist-client-filter" class="input-modern" onchange="applyHistoryFilters()">
                            <option value="">🌐 Все клиенты</option>
                        </select>
                    </div>

                    <div class="form-group" style="margin: 0;">
                        <label style="display: flex; justify-content: space-between; align-items: baseline;">
                            <span>📅 Период отгрузки:</span>
                            <span style="font-size: 11px;">
                                <a href="#" onclick="event.preventDefault(); setHistoryDateRange('today')"
                                    style="color: var(--primary); text-decoration: none; padding: 0 3px;">Сегодня</a> |
                                <a href="#" onclick="event.preventDefault(); setHistoryDateRange('week')"
                                    style="color: var(--primary); text-decoration: none; padding: 0 3px;">Неделя</a> |
                                <a href="#" onclick="event.preventDefault(); setHistoryDateRange('month')"
                                    style="color: var(--primary); text-decoration: none; padding: 0 3px;">Месяц</a> |
                                <a href="#" onclick="event.preventDefault(); setHistoryDateRange('quarter')"
                                    style="color: var(--primary); text-decoration: none; padding: 0 3px;">Квартал</a> |
                                <a href="#" onclick="event.preventDefault(); setHistoryDateRange('year')"
                                    style="color: var(--primary); text-decoration: none; padding: 0 3px;">Год</a>
                            </span>
                        </label>
                        <input type="text" id="hist-date-filter" class="input-modern"
                            placeholder="Выберите 1 день или период..." style="background: #fff; cursor: pointer;">
                    </div>

                    <button class="btn btn-outline" onclick="resetHistoryFilters()" title="Сбросить фильтры"
                        style="padding: 8px 12px; height: 38px;">🔄</button>
                </div>
            </div>
            <div class="table-container" style="margin: 0;">
                <table style="width: 100%;">
                    <thead style="background: #f1f5f9;">
                        <tr>
                            <th style="width: 15%;">Дата</th>
                            <th style="width: 15%;">Документ</th>
                            <th style="width: 25%;">Клиент</th>
                            <th style="width: 15%; text-align: center;">Объем (ед.)</th>
                            <th style="width: 15%; text-align: right;">Сумма</th>
                            <th style="width: 15%; text-align: right;">Действия</th>
                        </tr>
                    </thead>
                    <tbody id="sales-history-table">
                        <tr>
                            <td colspan="6" style="text-align: center; color: var(--text-muted); padding: 20px;">
                                Загрузка...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div
                style="display: flex; justify-content: space-between; align-items: center; margin-top: 15px; padding: 10px; background: #f8fafc; border-radius: 8px; border: 1px solid var(--border);">
                <button class="btn btn-outline" onclick="changeHistoryPage(-1)">⬅ Назад</button>
                <span style="font-size: 13px; color: var(--text-muted);" id="hist-page-info">Страница 1 из 1</span>
                <button class="btn btn-outline" onclick="changeHistoryPage(1)">Вперед ➡</button>
            </div>
        </div>
    </div>

</div>

<script>
    function switchSalesTab(tabId, btnElement) {
        // Убираем active у всех вкладок
        document.querySelectorAll('.sales-tab-content').forEach(tab => tab.classList.remove('active'));
        // Убираем active у всех кнопок
        document.querySelectorAll('.sales-tab-btn').forEach(btn => btn.classList.remove('active'));

        // Добавляем active нужным
        document.getElementById(tabId).classList.add('active');
        btnElement.classList.add('active');

        // Авто-обновление списков при переходе на вкладки
        if (tabId === 'tab-active-orders') loadActiveOrders();
        if (tabId === 'tab-history') loadSalesHistory();
    }
</script>