<div id="sales-mod" class="module">
    <div class="flex-between mb-20">
        <div>
            <h2 class="mt-0 mb-0">🛒 Отгрузка и Продажи</h2>
            <p class="text-muted font-14 mt-5 mb-0">Управление заказами (OMS) и реализация</p>
        </div>

        <div class="flex-row gap-10 align-center">
            <button class="btn btn-outline" onclick="openClientDocsModal()">
                🖨️ Документы клиенту
            </button>
            <button class="btn btn-outline" onclick="openReturnModal()">
                🔙 Возврат
            </button>

            <div class="sales-dropdown">
                <button class="btn btn-outline">
                    ⚙️ Инструменты и Отчеты <span class="font-10 ml-5">▼</span>
                </button>
                <div class="sales-dropdown-content">
                    <button onclick="openSalesDashboard()">📊 Дашборд продаж</button>
                    <button onclick="openLogisticsCalendar()">🚚 Календарь логиста</button>
                    <button onclick="openPalletsReport()">📦 Отчет по таре</button>
                    <button onclick="openPriceListModal()">📋 Установка Прайс-листа</button>
                    <button class="text-primary font-bold" onclick="openExport1CModal()">📥 Выгрузить в 1С (Excel)</button>
                </div>
            </div>
        </div>
    </div>

    <div class="sales-tabs">
        <div class="sales-tab-btn active" onclick="switchSalesTab('tab-new-order', this)">➕ Новый заказ / Отгрузка</div>
        <div class="sales-tab-btn" onclick="switchSalesTab('tab-active-orders', this)">📦 Управление заказами</div>
        <div class="sales-tab-btn" onclick="switchSalesTab('tab-history', this)">📜 Архив отгрузок</div>
    </div>

    <div id="tab-new-order" class="sales-tab-content active">

        <!-- ════ БЛОК 1: КЛИЕНТ + ПОИСК ТОВАРА ════ -->
        <div class="card p-20 m-0 mb-15">
            <div class="flex-between m-0 mb-15">
                <h3 class="font-18 mt-0 mb-0 text-main">1. Клиент и подбор товара</h3>
                <div class="flex-row gap-5 align-center">
                    <label class="font-12 text-muted m-0">Дата заказа:</label>
                    <input type="date" id="sale-order-date" class="input-modern" style="width: 130px; height: 32px; padding: 4px 6px;">
                </div>
            </div>

            <!-- Выбор клиента -->
            <div class="form-group mb-10">
                <label>Клиент (Контрагент):</label>
                <div class="flex-row gap-10 align-stretch">
                    <select id="sale-client" class="input-modern flex-grow-1" onchange="onClientChange()"></select>
                    <button type="button" class="btn btn-outline p-10" onclick="openMiniClientModal()">➕</button>
                </div>
                <div id="sale-client-info" class="sales-hidden mt-10 w-100"></div>
            </div>

            <!-- Договор -->
            <div class="form-group mb-10 sales-hidden" id="sale-contract-group">
                <label class="font-12 text-muted">Основание (Договор / Спецификация):</label>
                <div class="flex-row gap-10 align-center w-100">
                    <select id="sale-contract" class="input-modern flex-grow-1"></select>
                    <button type="button" class="btn btn-outline p-10" onclick="openMiniContractModal()" title="Новый договор">➕</button>
                    <button type="button" class="btn btn-outline p-10" onclick="printSelectedContract()" title="Распечатать договор">🖨️</button>
                    <button type="button" class="btn btn-outline p-10 text-muted" onclick="openContractManager()" title="Управление договорами">⚙️</button>
                </div>
            </div>

            <!-- Режим склада -->
            <div class="form-group mb-10">
                <label class="font-12 text-warning font-bold">Режим поиска и распределения:</label>
                <select id="sale-warehouse" class="input-modern" onchange="changeSaleWarehouse()">
                    <option value="all" selected>🌐 Авто: Резерв + Производство</option>
                    <option value="4">🟢 Склад №4 (1-й сорт)</option>
                    <option value="5">🟡 Склад №5 (Уценка)</option>
                </select>
            </div>

            <!-- Поиск товара -->
            <div class="form-group mb-0">
                <label class="font-12 font-bold text-main">Поиск продукции:</label>
                <select id="sale-product-select" class="input-modern w-100" placeholder="Начните вводить название..."></select>
            </div>

            <!-- Кол-во / Цена / В заказ (появляется после выбора товара) -->
            <div id="sale-spec-actions" class="sales-hidden mt-15 pt-15 border-top">
                <div class="sales-qty-bar">
                    <div class="sales-qty-fields">
                        <div class="sales-qty-group">
                            <label class="sales-qty-label">Кол-во:</label>
                            <input type="number" id="sale-qty" class="sales-qty-input"
                                placeholder="1" min="0.1" step="0.1"
                                onfocus="this.select()" oninput="updateLivePreview()">
                            <div class="sales-qty-meta">
                                <span id="sale-unit-label" class="sales-qty-unit"></span>
                                <small id="sale-max-qty" class="sales-qty-stock">Ост: 0</small>
                            </div>
                        </div>

                        <div class="sales-qty-group">
                            <label class="sales-qty-label">Цена:</label>
                            <input type="number" id="sale-price" class="sales-price-input"
                                placeholder="0" onfocus="this.select()" oninput="updateLivePreview()">
                            <span class="sales-qty-currency">₽</span>
                        </div>

                        <div id="sale-live-preview" class="sales-live-preview-pill">
                            <span id="sale-live-cost" class="sales-live-cost">0 ₽</span>
                        </div>
                    </div>

                    <div class="sales-qty-separator"></div>

                    <div class="sales-qty-actions">
                        <button type="button" class="btn btn-outline sales-btn-calc sales-hidden"
                            onclick="openCostAnalysisModal()" id="btn-calc-sales-cost">
                            📊 Калькулятор себестоимости
                        </button>
                        <button type="button" class="btn btn-blue sales-btn-add" onclick="addToCart()">
                            ➕ В заказ
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ════ БЛОК 2: КОРЗИНА ════ -->
        <div class="card p-0 m-0 mb-15 overflow-hidden">
            <div class="p-15 border-bottom bg-surface-alt flex-between align-center">
                <h3 class="font-16 m-0 text-main">2. Состав заказа (Корзина)</h3>
            </div>
            <div class="overflow-auto">
                <table class="table-modern w-100">
                    <thead class="bg-surface-alt">
                        <tr>
                            <th class="p-10 text-left font-12 text-muted">Сорт</th>
                            <th class="p-10 text-left font-12 text-muted">Наименование</th>
                            <th class="p-10 text-center font-12 text-muted">Кол-во</th>
                            <th class="p-10 text-center font-12 text-muted">Цена (₽)</th>
                            <th class="p-10 text-center font-12 text-muted" style="width:80px;">Скидка (%)</th>
                            <th class="p-10 text-right font-12 text-muted">Сумма</th>
                            <th class="p-10 text-center font-12 text-muted">✖</th>
                        </tr>
                    </thead>
                    <tbody id="cart-table">
                        <tr><td colspan="7" class="text-center p-30 text-muted" style="font-style:italic;">Корзина пуста. Добавьте товары через поиск выше.</td></tr>
                    </tbody>
                </table>
            </div>

            <div class="bg-surface-alt p-20 border-top">
                <div class="flex-row gap-20 flex-wrap mb-15">
                    <div class="form-group m-0 flex-grow-1">
                        <span class="font-13 font-bold text-muted d-block mb-5">Скидка на весь чек (%):</span>
                        <input type="number" id="sale-discount" class="input-modern m-0" placeholder="0" min="0" max="100" oninput="renderCart()">
                    </div>
                    <div class="form-group m-0 flex-grow-1">
                        <span class="font-13 font-bold text-muted d-block mb-5">Стоимость доставки (₽):</span>
                        <input type="number" id="sale-logistics-cost" class="input-modern m-0" value="0" min="0" oninput="renderCart()">
                    </div>
                </div>
                <p class="font-12 text-muted m-0 mb-5">💡 Индивидуальная скидка на каждую позицию задаётся в колонке «Скидка (%)» таблицы корзины. Глобальная скидка применяется поверх позиционных.</p>
                <div class="flex-between mb-5 font-14 mt-10">
                    <span>Общий вес продукции:</span>
                    <strong><span id="cart-total-weight">0</span> кг</strong>
                </div>
                <div class="flex-between font-18">
                    <span>Итого к оплате (с доставкой):</span>
                    <div class="text-right">
                        <s id="cart-original-sum" class="text-muted font-14 mr-10">0 ₽</s>
                        <strong class="text-primary"><span id="cart-total-sum">0</span> ₽</strong>
                    </div>
                </div>
                <!-- 🚀 Блок себестоимости -->
                <div class="mt-15 pt-15 border-top" id="top-cart-cost-block">
                    <div class="flex-between font-14 text-muted mb-0">
                        <span>Общая себестоимость продукции:</span>
                        <strong><span id="cart-total-cost">0</span> ₽</strong>
                    </div>
                </div>
            </div>
        </div>

        <!-- ════ БЛОК 3: ЛОГИСТИКА ════ -->
        <div class="card p-0 m-0 mb-15 overflow-hidden">
            <div class="p-15 border-bottom bg-surface-alt">
                <h3 class="font-16 m-0 text-main">3. 🚚 Логистика</h3>
            </div>
            <div class="p-20">
                <div class="form-group mb-15">
                    <label>Способ получения:</label>
                    <div style="display: flex; gap: 20px; align-items: center; margin-bottom: 15px; margin-top: 5px;">
                        <label style="cursor: pointer; display: flex; align-items: center; font-size: 14px;">
                            <input type="radio" name="sale_delivery_type" value="pickup" onchange="toggleSaleDelivery()" style="margin-right: 8px;"> Самовывоз
                        </label>
                        <label style="cursor: pointer; display: flex; align-items: center; font-size: 14px;">
                            <input type="radio" name="sale_delivery_type" value="delivery" onchange="toggleSaleDelivery()" checked style="margin-right: 8px;"> Доставка (Наш/наемный транспорт)
                        </label>
                    </div>
                </div>
                <div class="form-group mb-15" id="sale-delivery-address-group">
                    <label>Адрес объекта (доставки):</label>
                    <input type="text" id="sale-delivery-address" class="input-modern" placeholder="г. Армавир, ул. Ленина 1">
                </div>
                <div class="flex-row gap-15 flex-wrap">
                    <div class="form-group m-0 flex-grow-1">
                        <label>Желаемая дата отгрузки:</label>
                        <input type="date" id="sale-planned-date" class="input-modern">
                    </div>
                    <div class="form-group m-0 flex-grow-1">
                        <label>Поддоны (в долг), шт:</label>
                        <input type="number" id="sale-pallets" class="input-modern" placeholder="Количество" min="0">
                    </div>
                </div>
            </div>
        </div>

        <!-- ════ БЛОК 4: ОПЛАТА ════ -->
        <div class="card p-0 m-0 mb-15 overflow-hidden">
            <div class="p-15 border-bottom bg-surface-alt">
                <h3 class="font-16 m-0 text-main">4. 💳 Оплата</h3>
            </div>
            <div class="p-20">
                <!-- 🚀 ВЗАИМОЗАЧЕТ (появляется если есть аванс) -->
                <div class="bg-success-lt border-success p-15 border-radius-8 mb-15 sales-hidden" id="sale-offset-group">
                    <div class="flex-between mb-10">
                        <div>
                            <h4 class="m-0 text-success">💰 Доступен аванс (Переплата)</h4>
                            <div class="font-12 text-success mt-5">На балансе клиента: <b id="sale-offset-max" class="font-14">0 ₽</b></div>
                        </div>
                        <label class="font-14 d-flex align-center cursor-pointer m-0">
                            <input type="checkbox" id="sale-offset-check" onchange="toggleOffsetInput()" class="mr-10" style="width:18px; height:18px;"> 
                            <b class="text-success">Использовать в зачет</b>
                        </label>
                    </div>
                    <div id="sale-offset-input-wrap" class="sales-hidden mt-10">
                        <label class="font-12 text-success mb-5 d-block">Сумма к зачету из баланса:</label>
                        <input type="number" id="sale-offset-amount" class="input-modern border-success font-16 font-bold text-success" 
                               placeholder="Сумма" max="0" min="0" oninput="updateOffsetSummary()">
                        <div class="font-12 text-muted mt-5">Остаток к доплате после зачета: <b id="sale-offset-remainder">0 ₽</b></div>
                    </div>
                </div>

                <div class="form-group mb-15" id="sale-payment-method-group">
                    <label>Метод оплаты:</label>
                    <select id="sale-payment-method" class="input-modern" onchange="toggleSalePayment()">
                        <option value="debt">⏳ В долг (Счет на оплату / Ожидаем)</option>
                        <option value="paid">💰 Оплачено полностью</option>
                        <option value="partial">🌗 Частичная оплата (Аванс)</option>
                    </select>
                </div>
                <div class="form-group mb-15 sales-hidden" id="sale-advance-group">
                    <label class="text-warning font-bold">Сумма внесенного аванса (₽):</label>
                    <input type="number" id="sale-advance-amount" class="input-modern font-18 font-bold text-main" placeholder="Например: 50000">
                </div>
                <div class="form-group m-0 sales-hidden" id="sale-account-group">
                    <label>В какую кассу/счет поступили деньги?</label>
                    <select id="sale-account" class="input-modern"></select>
                </div>
            </div>
        </div>

        <!-- ════ БЛОК 5: ДЕЙСТВИЯ ════ -->
        <div class="card p-20 m-0 mb-15">
            <div class="flex-row gap-10 flex-wrap">
                <button class="btn btn-outline flex-grow-1" onclick="generateKP()">📄 Печать КП</button>
                <button class="btn btn-outline flex-grow-1" onclick="generateBlankOrder()">🖨️ Печать Бланк-заказа</button>
            </div>
            <button class="btn btn-blue font-bold font-15 w-100 mt-10" onclick="processCheckout()">
                💾 Оформить заказ
            </button>
        </div>

    </div>




    <!-- === ВКЛАДКА 2: УПРАВЛЕНИЕ ЗАКАЗАМИ === -->
    <div id="tab-active-orders" class="sales-tab-content">
        <div class="card p-0 overflow-hidden border-0">
            <div class="p-20 border-bottom bg-surface flex-between align-center">
                <div class="flex-row gap-10">
                    <button id="view-btn-list" class="btn btn-blue" onclick="toggleSalesView('list')">📄 Списком</button>
                    <button id="view-btn-kanban" class="btn btn-outline" onclick="toggleSalesView('kanban')">📊 CRM Воронка</button>
                </div>
            </div>

            <div id="sales-table-wrapper">
                <div class="bg-surface-alt p-15 border-bottom">
                    <div class="form-grid gap-15 align-end" style="grid-template-columns: 2fr 2fr 2fr 2fr auto;">
                        <div class="form-group m-0">
                            <label class="font-12 text-muted">🔍 Текст (Номер, Адрес):</label>
                            <input type="text" id="bo-search" class="input-modern m-0" placeholder="Поиск..." oninput="applyOrderFilters()">
                        </div>
                        <div class="form-group m-0">
                            <label class="font-12 text-muted">👤 Клиент:</label>
                            <select id="bo-client-filter" class="input-modern m-0" onchange="applyOrderFilters()">
                                <option value="">🌐 Все клиенты</option>
                            </select>
                        </div>
                        <div class="form-group m-0">
                            <label class="font-12 text-muted">📦 В составе (Товар):</label>
                            <input type="text" id="bo-product-filter" class="input-modern m-0" placeholder="Название..." oninput="applyOrderFilters()">
                        </div>
                        <div class="form-group m-0">
                            <label class="font-12 text-muted">🚦 Статус оплаты:</label>
                            <select id="bo-status-filter" class="input-modern m-0" onchange="applyOrderFilters()">
                                <option value="">Все статусы</option>
                                <option value="debt">🔴 Есть долг</option>
                                <option value="paid">🟢 Оплачено 100%</option>
                            </select>
                        </div>
                        <button class="btn btn-outline p-10 h-100" onclick="resetOrderFilters()" title="Сбросить фильтры">🔄</button>
                    </div>
                </div>

                <div class="table-container m-0">
                    <table class="table-modern w-100">
                        <thead class="bg-surface-alt">
                            <tr>
                                <th class="p-10 font-12 text-muted text-left" style="width: 12%;">Дата / Дедлайн</th>
                                <th class="p-10 font-12 text-muted text-left" style="width: 15%;">Документ</th>
                                <th class="p-10 font-12 text-muted text-left" style="width: 25%;">Клиент и Адрес</th>
                                <th class="p-10 font-12 text-muted text-left" style="width: 20%;">Состав (Товары)</th>
                                <th class="p-10 font-12 text-muted text-center" style="width: 13%;">Статус</th>
                                <th class="p-10 font-12 text-muted text-right" style="width: 15%;">Действия</th>
                            </tr>
                        </thead>
                        <tbody id="blank-orders-table">
                            <tr><td colspan="6" class="text-center p-20 text-muted" style="font-style: italic;">Загрузка...</td></tr>
                        </tbody>
                    </table>
                </div>

                <div class="flex-between p-15 border-top bg-surface">
                    <button class="btn btn-outline" onclick="changeBlankOrderPage(-1)">⬅ Назад</button>
                    <span class="font-bold text-muted" id="bo-page-info">Страница 1 из 1</span>
                    <button class="btn btn-outline" onclick="changeBlankOrderPage(1)">Вперед ➡</button>
                </div>
            </div>

            <div id="sales-kanban-board" class="sales-kanban-board" style="display: none;">
                <div class="kanban-column" data-status="pending">
                    <h3 class="kanban-column-title">
                        <span>🆕 Новые заказы</span>
                        <span class="column-count kanban-count">0</span>
                    </h3>
                    <div class="kanban-items-container"></div>
                </div>

                <div class="kanban-column kanban-column-processing" data-status="processing">
                    <h3 class="kanban-column-title kanban-title-processing">
                        <span>⚙️ В работе</span>
                        <span class="column-count kanban-count-processing">0</span>
                    </h3>
                    <div class="kanban-items-container"></div>
                </div>
            </div>

        </div>
    </div>

    <!-- === ВКЛАДКА 3: АРХИВ ОТГРУЗОК === -->
    <div id="tab-history" class="sales-tab-content">
        <div class="card p-0 overflow-hidden border-0">
            <div class="bg-surface-alt p-15 border-bottom">
                <div class="form-grid gap-15 align-end" style="grid-template-columns: 2fr 2fr 4fr auto;">
                    <div class="form-group m-0">
                        <label class="font-12 text-muted">🔍 Номер документа:</label>
                        <input type="text" id="hist-search" class="input-modern m-0" placeholder="Поиск..." oninput="applyHistoryFilters()">
                    </div>
                    <div class="form-group m-0">
                        <label class="font-12 text-muted">👤 Клиент:</label>
                        <select id="hist-client-filter" class="input-modern m-0" onchange="applyHistoryFilters()">
                            <option value="">🌐 Все клиенты</option>
                        </select>
                    </div>
                    <div class="form-group m-0">
                        <div class="flex-between mb-5">
                            <label class="font-12 text-muted m-0">📅 Период отгрузки:</label>
                        </div>
                        <div id="hist-date-filter-container" class="history-period-selector flex-row gap-10"></div>
                    </div>
                    <button class="btn btn-outline p-10 h-100" onclick="resetHistoryFilters()" title="Сбросить фильтры">🔄</button>
                </div>
            </div>

            <div class="table-container m-0">
                <table class="table-modern w-100">
                    <thead class="bg-surface-alt">
                        <tr>
                            <th class="p-10 font-12 text-muted text-left" style="width: 12%;">Дата</th>
                            <th class="p-10 font-12 text-muted text-left" style="width: 15%;">Документ</th>
                            <th class="p-10 font-12 text-muted text-left" style="width: 25%;">Клиент</th>
                            <th class="p-10 font-12 text-muted text-right" style="width: 15%;">Объем (ед.)</th>
                            <th class="p-10 font-12 text-muted text-right" style="width: 15%;">Сумма</th>
                            <th class="p-10 font-12 text-muted text-right" style="width: 18%;">Действия</th>
                        </tr>
                    </thead>
                    <tbody id="sales-history-table">
                        <tr><td colspan="6" class="text-center p-20 text-muted" style="font-style: italic;">Загрузка...</td></tr>
                    </tbody>
                </table>
            </div>
            <div class="flex-between p-15 border-top bg-surface">
                <button class="btn btn-outline" onclick="changeHistoryPage(-1)">⬅ Назад</button>
                <span class="font-bold text-muted" id="hist-page-info">Страница 1 из 1</span>
                <button class="btn btn-outline" onclick="changeHistoryPage(1)">Вперед ➡</button>
            </div>
        </div>
    </div>

</div>

<script>
    function switchSalesTab(tabId, btnElement) {
        document.querySelectorAll('.sales-tab-content').forEach(tab => tab.classList.remove('active'));
        document.querySelectorAll('.sales-tab-btn').forEach(btn => btn.classList.remove('active'));
        document.getElementById(tabId).classList.add('active');
        btnElement.classList.add('active');
        if (tabId === 'tab-active-orders') loadActiveOrders();
        if (tabId === 'tab-history') loadSalesHistory();
    }
</script>