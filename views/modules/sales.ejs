<div id="sales-mod" class="module">
    <div class="sales-header">
        <div>
            <h2>🛒 Отгрузка и Продажи</h2>
            <p class="sales-subtitle">Управление заказами (OMS) и реализация</p>
        </div>

        <div class="sales-header-actions">
            <button class="btn btn-outline sales-btn-docs" onclick="openClientDocsModal()">
                🖨️ Документы клиенту
            </button>
            <button class="btn btn-outline sales-btn-return" onclick="openReturnModal()">
                🔙 Возврат
            </button>

            <div class="action-dropdown">
                <button class="btn btn-outline sales-btn-tools">
                    ⚙️ Инструменты и Отчеты <span class="sales-dropdown-arrow">▼</span>
                </button>
                <div class="action-dropdown-content">
                    <button onclick="openSalesDashboard()">📊 Дашборд продаж</button>
                    <button onclick="openLogisticsCalendar()">🚚 Календарь логиста</button>
                    <button onclick="openPalletsReport()">📦 Отчет по таре</button>
                    <button onclick="openPriceListModal()">📋 Установка Прайс-листа</button>
                    <button class="sales-btn-1c" onclick="openExport1CModal()">📥 Выгрузить в 1С (Excel)</button>
                </div>
            </div>
        </div>
    </div>

    <div class="sales-tabs">
        <div class="sales-tab-btn active" onclick="switchSalesTab('tab-new-order', this)">➕ Новый заказ / Отгрузка</div>
        <div class="sales-tab-btn" onclick="switchSalesTab('tab-active-orders', this)">📦 Управление заказами</div>
        <div class="sales-tab-btn" onclick="switchSalesTab('tab-history', this)">📜 Архив отгрузок</div>
    </div>

    <!-- === ВКЛАДКА 1: НОВЫЙ ЗАКАЗ === -->
    <div id="tab-new-order" class="sales-tab-content active">
        <div class="sales-checkout-grid">

            <div class="card sales-panel-left">
                <h3 class="sales-section-title">1. Контрагент и продукция</h3>

                <div class="form-group">
                    <label>Клиент (Контрагент):</label>
                    <div class="sales-input-row">
                        <select id="sale-client" class="input-modern" onchange="onClientChange()"></select>
                        <button type="button" class="btn btn-outline sales-btn-icon" onclick="openMiniClientModal()">➕</button>
                    </div>
                    <div id="sale-client-info" class="sales-client-info">
                        <div class="sales-client-row">
                            <span class="sales-label-danger">Текущий долг:</span>
                            <strong id="sale-client-debt" class="sales-debt-value">0 ₽</strong>
                        </div>
                        <div class="sales-client-row">
                            <span class="sales-label-danger">Долг по поддонам:</span>
                            <strong id="sale-client-pallets" class="sales-pallets-value">0 шт.</strong>
                        </div>
                        <button class="btn btn-outline sales-btn-act" onclick="printClientAct()">
                            🖨️ Распечатать Акт сверки
                        </button>
                    </div>
                </div>

                <div class="form-group sales-contract-group" id="sale-contract-group">
                    <label class="sales-label-muted">Основание (Договор / Спецификация):</label>
                    <div class="sales-input-row">
                        <select id="sale-contract" class="input-modern sales-flex-grow"></select>
                        <button type="button" class="btn btn-outline sales-btn-icon" onclick="openMiniContractModal()">➕</button>
                        <button class="btn btn-outline sales-btn-info-icon" onclick="printSelectedContract()" title="Распечатать этот договор">🖨️</button>
                        <button class="btn btn-outline sales-btn-icon" onclick="openContractManager()" title="Управление договорами">⚙️</button>
                    </div>
                </div>

                <div class="form-group sales-separator-top">
                    <label class="sales-label-warning-bold">Режим поиска и распределения:</label>
                    <select id="sale-warehouse" class="input-modern" onchange="changeSaleWarehouse()">
                        <option value="all" selected>🌐 Весь справочник (Авто: Резерв + Производство)</option>
                        <option value="4">🟢 Склад №4 (Строго из наличия 1-го сорта)</option>
                        <option value="5">🟡 Склад №5 (Строго из наличия Уценки)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Поиск продукции:</label>
                    <select id="sale-product-select" class="input-modern" placeholder="Начните вводить название..."></select>
                </div>

                <div class="form-grid sales-two-cols">
                    <div class="form-group m-0">
                        <label>Кол-во <span id="sale-unit-label" class="sales-unit-hint"></span>:</label>
                        <input type="number" id="sale-qty" class="input-modern" placeholder="1" min="0.1" step="0.1">
                        <div class="sales-stock-hint-wrapper">
                            <small id="sale-max-qty" class="sales-stock-hint">Остаток: 0</small>
                        </div>
                    </div>
                    <div class="form-group m-0">
                        <label>Цена за ед (₽):</label>
                        <input type="number" id="sale-price" class="input-modern" placeholder="0" onfocus="this.select()">
                    </div>
                </div>
                <div class="sales-cost-btn-wrap">
                    <button type="button" class="btn btn-outline w-100 sales-btn-cost" id="btn-calc-sales-cost" onclick="openCostAnalysisModal()">
                        📊 Рассчитать себестоимость
                    </button>
                </div>
                <button class="btn btn-outline sales-btn-add-to-cart" onclick="addToCart()">
                    ⬇️ Добавить в спецификацию заказа
                </button>
            </div>

            <div class="card sales-panel-right">
                <h3 class="sales-section-title">2. Состав заказа</h3>
                <div class="sales-cart-wrapper">
                    <table class="sales-cart-table">
                        <thead class="bg-surface-alt">
                            <tr>
                                <th>Сорт</th>
                                <th>Наименование</th>
                                <th class="text-center">Кол-во</th>
                                <th class="text-center">Цена (₽)</th>
                                <th class="text-center sales-th-discount">Скидка (%)</th>
                                <th class="text-right">Сумма</th>
                                <th class="text-center">✖</th>
                            </tr>
                        </thead>
                        <tbody id="cart-table">
                            <tr><td colspan="7" class="sales-empty-cell">Корзина пуста</td></tr>
                        </tbody>
                    </table>
                </div>

                <div class="sales-totals-block">
                    <div class="form-grid sales-two-cols sales-mb-sm">
                        <div>
                            <span class="sales-totals-label">Скидка на чек (%):</span>
                            <input type="number" id="sale-discount" class="input-modern sales-input-sm" placeholder="0" min="0" max="100" oninput="renderCart()">
                        </div>
                        <div>
                            <span class="sales-totals-label">Стоимость доставки (₽):</span>
                            <input type="number" id="sale-logistics-cost" class="input-modern sales-input-sm" value="0" min="0" oninput="renderCart()">
                        </div>
                    </div>

                    <div class="sales-summary-row">
                        <span>Общий вес продукции:</span>
                        <strong><span id="cart-total-weight">0</span> кг</strong>
                    </div>
                    <div class="sales-grand-total">
                        <span>Итого к оплате (с доставкой):</span>
                        <div>
                            <s id="cart-original-sum" class="sales-original-sum">0 ₽</s>
                            <strong><span id="cart-total-sum">0</span> ₽</strong>
                        </div>
                    </div>
                </div>

                <div class="sales-section-dashed">
                    <h4 class="sales-section-sub-title">📍 Детали доставки и тара</h4>
                    <div class="form-group sales-mb-sm">
                        <label>Адрес объекта (доставки):</label>
                        <input type="text" id="sale-delivery-address" class="input-modern" placeholder="г. Армавир, ул. Ленина 1">
                    </div>
                    <div class="form-grid sales-two-cols">
                        <div class="form-group m-0">
                            <label>Желаемая дата отгрузки:</label>
                            <input type="date" id="sale-planned-date" class="input-modern">
                        </div>
                        <div class="form-group m-0">
                            <label>Поддоны (в долг), шт:</label>
                            <input type="number" id="sale-pallets" class="input-modern" placeholder="Количество" min="0">
                        </div>
                    </div>
                </div>

                <div class="sales-section-dashed">
                    <div class="form-grid sales-two-cols sales-mb-sm">
                        <div class="form-group m-0">
                            <label>ФИО Водителя:</label>
                            <input type="text" id="sale-driver" class="input-modern" placeholder="Иванов И.И.">
                        </div>
                        <div class="form-group m-0">
                            <label>Автомобиль:</label>
                            <input type="text" id="sale-auto" class="input-modern" placeholder="Гос. номер (Е123КХ)">
                        </div>
                    </div>

                    <div class="sales-poa-block">
                        <div class="sales-poa-header">
                            <label class="sales-poa-title">Юридическое основание (Доверенность):</label>
                            <label class="sales-poa-checkbox-label">
                                <input type="checkbox" id="sale-no-poa" onchange="togglePoaMode()"> Отгрузка без доверенности
                            </label>
                        </div>
                        <div id="poa-select-group" class="sales-input-row">
                            <select id="sale-poa" class="input-modern sales-flex-grow sales-poa-select"></select>
                            <button class="btn btn-outline sales-btn-poa-add" onclick="openPoaManager()" title="Добавить доверенность">➕</button>
                        </div>
                        <div id="poa-comment-group" class="sales-poa-comment">
                            <input type="text" id="sale-poa-comment" class="input-modern sales-poa-comment-input"
                                placeholder="Укажите, кто разрешил отгрузку без доверенности">
                        </div>
                    </div>
                </div>

                <div class="sales-payment-block">
                    <div class="form-group sales-mb-sm">
                        <label>Оплата:</label>
                        <select id="sale-payment-method" class="input-modern" onchange="toggleSalePayment()">
                            <option value="debt">⏳ В долг (Счет на оплату / Ожидаем)</option>
                            <option value="paid">💰 Оплачено полностью</option>
                            <option value="partial">🌗 Частичная оплата (Аванс)</option>
                        </select>
                    </div>

                    <div class="form-group sales-mb-sm" id="sale-advance-group" style="display: none;">
                        <label class="sales-label-warning-bold">Сумма внесенного аванса (₽):</label>
                        <input type="number" id="sale-advance-amount" class="input-modern sales-advance-input" placeholder="Например: 50000">
                    </div>

                    <div class="form-group" id="sale-account-group" style="display: none;">
                        <label>В какую кассу/счет поступили деньги?</label>
                        <select id="sale-account" class="input-modern"></select>
                    </div>
                </div>

                <div class="sales-action-bar">
                    <button class="btn btn-blue" onclick="generateKP()">📄 Печать КП</button>
                    <button class="btn btn-blue" onclick="generateBlankOrder()">🖨️ Печать Бланк-заказа</button>
                    <button class="btn btn-blue sales-btn-checkout" onclick="processCheckout()">
                        💾 Оформить заказ
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- === ВКЛАДКА 2: УПРАВЛЕНИЕ ЗАКАЗАМИ === -->
    <div id="tab-active-orders" class="sales-tab-content">
        <div class="card sales-card-flush">

            <div class="sales-view-toggle">
                <button id="view-btn-list" class="btn btn-blue" onclick="toggleSalesView('list')">📄 Списком</button>
                <button id="view-btn-kanban" class="btn btn-outline" onclick="toggleSalesView('kanban')">📊 CRM Воронка</button>
            </div>

            <div id="sales-table-wrapper">
                <div class="sales-filter-bar">
                    <div class="form-grid sales-orders-filter-grid">
                        <div class="form-group m-0">
                            <label>🔍 Текст (Номер, Адрес):</label>
                            <input type="text" id="bo-search" class="input-modern" placeholder="Поиск..." oninput="applyOrderFilters()">
                        </div>
                        <div class="form-group m-0">
                            <label>👤 Клиент:</label>
                            <select id="bo-client-filter" class="input-modern" onchange="applyOrderFilters()">
                                <option value="">🌐 Все клиенты</option>
                            </select>
                        </div>
                        <div class="form-group m-0">
                            <label>📦 В составе есть (Товар):</label>
                            <input type="text" id="bo-product-filter" class="input-modern" placeholder="Название..." oninput="applyOrderFilters()">
                        </div>
                        <div class="form-group m-0">
                            <label>🚦 Статус оплаты:</label>
                            <select id="bo-status-filter" class="input-modern" onchange="applyOrderFilters()">
                                <option value="">Все статусы</option>
                                <option value="debt">🔴 Есть долг</option>
                                <option value="paid">🟢 Оплачено 100%</option>
                            </select>
                        </div>
                        <button class="btn btn-outline sales-btn-reset" onclick="resetOrderFilters()" title="Сбросить фильтры">🔄</button>
                    </div>
                </div>

                <div class="table-container m-0">
                    <table class="sales-table-full">
                        <thead class="bg-surface-alt">
                            <tr>
                                <th class="sales-col-date">Дата / Дедлайн</th>
                                <th class="sales-col-doc">Документ</th>
                                <th class="sales-col-client">Клиент и Адрес</th>
                                <th class="sales-col-items">Состав (Товары)</th>
                                <th class="sales-col-status">Статус</th>
                                <th class="sales-col-actions">Действия</th>
                            </tr>
                        </thead>
                        <tbody id="blank-orders-table">
                            <tr><td colspan="6" class="sales-empty-cell">Загрузка...</td></tr>
                        </tbody>
                    </table>
                </div>

                <div class="sales-pagination">
                    <button class="btn btn-outline" onclick="changeBlankOrderPage(-1)">⬅ Назад</button>
                    <span class="sales-page-info" id="bo-page-info">Страница 1 из 1</span>
                    <button class="btn btn-outline" onclick="changeBlankOrderPage(1)">Вперед ➡</button>
                </div>
            </div>

            <div id="sales-kanban-board" class="sales-kanban-board">
                <div class="kanban-column" data-status="pending">
                    <h3 class="kanban-column-title">
                        <span>🆕 Новые заказы</span>
                        <span class="column-count kanban-count">0</span>
                    </h3>
                    <div class="kanban-items-container"></div>
                </div>

                <div class="kanban-column kanban-column-processing" data-status="processing">
                    <h3 class="kanban-column-title kanban-title-processing">
                        <span>⚙️ В работе</span>
                        <span class="column-count kanban-count-processing">0</span>
                    </h3>
                    <div class="kanban-items-container"></div>
                </div>
            </div>

        </div>
    </div>

    <!-- === ВКЛАДКА 3: АРХИВ ОТГРУЗОК === -->
    <div id="tab-history" class="sales-tab-content">
        <div class="card sales-card-flush">

            <div class="sales-filter-bar">
                <div class="form-grid sales-history-filter-grid">
                    <div class="form-group m-0">
                        <label>🔍 Номер документа:</label>
                        <input type="text" id="hist-search" class="input-modern" placeholder="Поиск..." oninput="applyHistoryFilters()">
                    </div>
                    <div class="form-group m-0">
                        <label>👤 Клиент:</label>
                        <select id="hist-client-filter" class="input-modern" onchange="applyHistoryFilters()">
                            <option value="">🌐 Все клиенты</option>
                        </select>
                    </div>
                    <div class="form-group m-0">
                        <label class="sales-date-label">
                            <span>📅 Период отгрузки:</span>
                            <span class="sales-date-shortcuts">
                                <a href="#" onclick="event.preventDefault(); setHistoryDateRange('today')">Сегодня</a> |
                                <a href="#" onclick="event.preventDefault(); setHistoryDateRange('week')">Неделя</a> |
                                <a href="#" onclick="event.preventDefault(); setHistoryDateRange('month')">Месяц</a> |
                                <a href="#" onclick="event.preventDefault(); setHistoryDateRange('quarter')">Квартал</a> |
                                <a href="#" onclick="event.preventDefault(); setHistoryDateRange('year')">Год</a>
                            </span>
                        </label>
                        <input type="text" id="hist-date-filter" class="input-modern sales-date-input" placeholder="Выберите 1 день или период...">
                    </div>
                    <button class="btn btn-outline sales-btn-reset" onclick="resetHistoryFilters()" title="Сбросить фильтры">🔄</button>
                </div>
            </div>

            <div class="table-container m-0">
                <table class="sales-table-full">
                    <thead class="bg-surface-alt">
                        <tr>
                            <th class="sales-col-date">Дата</th>
                            <th class="sales-col-doc">Документ</th>
                            <th class="sales-col-client">Клиент</th>
                            <th class="sales-col-vol">Объем (ед.)</th>
                            <th class="sales-col-sum">Сумма</th>
                            <th class="sales-col-actions">Действия</th>
                        </tr>
                    </thead>
                    <tbody id="sales-history-table">
                        <tr><td colspan="6" class="sales-empty-cell">Загрузка...</td></tr>
                    </tbody>
                </table>
            </div>
            <div class="sales-pagination">
                <button class="btn btn-outline" onclick="changeHistoryPage(-1)">⬅ Назад</button>
                <span class="sales-page-info" id="hist-page-info">Страница 1 из 1</span>
                <button class="btn btn-outline" onclick="changeHistoryPage(1)">Вперед ➡</button>
            </div>
        </div>
    </div>

</div>

<script>
    function switchSalesTab(tabId, btnElement) {
        document.querySelectorAll('.sales-tab-content').forEach(tab => tab.classList.remove('active'));
        document.querySelectorAll('.sales-tab-btn').forEach(btn => btn.classList.remove('active'));
        document.getElementById(tabId).classList.add('active');
        btnElement.classList.add('active');
        if (tabId === 'tab-active-orders') loadActiveOrders();
        if (tabId === 'tab-history') loadSalesHistory();
    }
</script>