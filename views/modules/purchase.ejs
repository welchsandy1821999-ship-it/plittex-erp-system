<div id="purchase-mod" class="module">
    <div class="flex-between mb-20">
        <h2 class="m-0">🚚 Закупки и приход ТМЦ</h2>

        <div class="form-group m-0">
            <label class="d-block font-11 mb-2">Дата закупки:</label>
            <input type="text" id="purchase-date" class="input-modern pur-date-input">
        </div>
    </div>

    <div class="card pur-main-panel">
        <div class="form-grid pur-form-grid">
            <div class="form-group col-span-3">
                <label>Закупаемая номенклатура:</label>
                <select id="purchase-material-select" class="input-modern" placeholder="-- Выберите ТМЦ --">
                    <option value="">-- Загрузка... --</option>
                </select>
                <div id="material-informer" class="pur-material-infobox inv-hidden">
                </div>
            </div>

            <div class="form-group col-span-3">
                <label>Поставщик (Поиск по Имени или ИНН):</label>
                <div class="pur-supplier-flex">
                    <div class="flex-1 min-w-0">
                        <select id="purchase-supplier-select" class="input-modern"
                            placeholder="-- Выберите поставщика --">
                            <option value="">-- Загрузка... --</option>
                        </select>
                    </div>
                    <button class="btn btn-outline pur-supplier-btn"
                        onclick="openAddSupplierModal()" title="Добавить нового поставщика">➕</button>
                </div>
            </div>

            <div class="form-group col-span-2">
                <label>Счет оплаты:</label>
                <select id="purchase-account-select" class="input-modern" placeholder="-- Взаиморасчет (в долг) --">
                    <option value="">-- Загрузка... --</option>
                </select>
            </div>

            <div class="form-group">
                <label>Количество:</label>
                <input type="number" id="purchase-qty" class="input-modern" oninput="calculatePurchaseTotal()"
                    placeholder="0.00">
            </div>

            <div class="form-group">
                <label>Цена за ед. (₽):</label>
                <input type="number" id="purchase-price" class="input-modern" oninput="calculatePurchaseTotal()"
                    placeholder="0.00">
            </div>


            <div class="form-group col-span-2 pur-delivery-toggle-wrap">
                <label class="pur-delivery-label">
                    <input type="checkbox" id="purchase-has-delivery" onchange="toggleDeliveryFields()"
                        class="pur-delivery-checkbox">
                    🚚 Учесть расходы на доставку
                </label>
            </div>

            <div id="delivery-fields" class="pur-delivery-fields-grid inv-hidden">
                <div class="form-group m-0">
                    <label>Стоимость доставки (₽):</label>
                    <input type="number" id="purchase-delivery-cost" class="input-modern" placeholder="0.00">
                </div>
                <div class="form-group m-0">
                    <label>Счет оплаты доставки:</label>
                    <select id="purchase-delivery-account" class="input-modern" placeholder="-- В ДОЛГ --">
                        <option value="">-- Загрузка... --</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="pur-summary-box">
            <span class="font-16 font-bold">Итого за ТМЦ:</span>
            <div class="flex-row gap-10 align-center">
                <input type="text" id="purchase-total-cost" class="input-modern pur-total-input"
                    oninput="calculatePriceFromTotal()" onkeyup="calculatePriceFromTotal()" placeholder="0.00">
                <span class="font-18 font-bold">₽</span>
            </div>
        </div>

        <div id="purchase-action-buttons" class="pur-submit-flex">
            <button id="btn-submit-purchase" class="btn btn-blue w-100 pur-btn-ok"
                onclick="submitPurchase()">📥 Оформить приход</button>
            <button id="btn-cancel-edit" class="btn btn-outline pur-btn-cancel inv-hidden"
                onclick="cancelEditMode()">❌ Отменить ред.</button>
        </div>
    </div>

    <div class="card mt-20">
        <div class="pur-history-header">
            <h3 class="m-0">История приходов</h3>

            <div class="pur-search-wrap">
                <span class="pur-search-icon">🔍</span>
                <input type="text" id="purchase-search-input" class="input-modern pur-search-input"
                    placeholder="Поиск по названию, поставщику, ИНН..." oninput="handlePurchaseSearch()">
            </div>
        </div>

        <div class="table-responsive">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th class="cursor-pointer w-25" onclick="sortSearchResults('item_name')"
                            title="Сортировать">Наименование ТМЦ ↕️</th>
                        <th class="cursor-pointer w-25" onclick="sortSearchResults('supplier_name')"
                            title="Сортировать">Поставщик ↕️</th>
                        <th id="th-date" class="cursor-pointer w-10 pur-th-date inv-hidden"
                            onclick="sortSearchResults('purchase_date')" title="Сортировать">Дата ↕️</th>

                        <th class="cursor-pointer text-right w-10"
                            onclick="sortSearchResults('quantity')" title="Сортировать">Кол-во ↕️</th>
                        <th class="cursor-pointer text-right w-10" onclick="sortSearchResults('price')"
                            title="Сортировать">Цена ↕️</th>
                        <th class="cursor-pointer text-right w-10"
                            onclick="sortSearchResults('amount')" title="Сортировать">Сумма ↕️</th>
                        <th class="text-right w-10">Действия</th>
                    </tr>
                </thead>
                <tbody id="daily-purchases-table">
                    <tr>
                        <td colspan="6" class="text-center text-muted">Выберите дату для просмотра истории...</td>
                    </tr>
                </tbody>
                <tfoot id="daily-purchases-summary" class="pur-daily-summary-foot inv-hidden">
                    <tr class="pur-daily-summary-row">
                        <td colspan="2" class="text-right font-900">ИТОГО ЗА ДЕНЬ:
                        </td>
                        <td id="daily-total-qty" class="text-right font-bold">0.00
                        </td>
                        <td></td>
                        <td id="daily-total-amount" class="text-right font-900 text-danger font-16">
                            0.00 ₽</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>