<div id="purchase-mod" class="module">
    <h2 class="mt-0">🚚 Закупки и приход сырья</h2>
    
    <div class="card" style="border-left: 4px solid var(--primary);">
        <div class="form-grid">
            
            <div class="form-group col-span-2">
                <label>Материал (Сырье):</label>
                <select id="purchase-material-select" class="input-modern" onchange="onPurchaseMaterialSelect()">
                    <option value="" disabled selected>-- Выберите материал --</option>
                </select>
            </div>

            <div class="form-group col-span-2">
                <label>Поставщик (Поиск по Имени или ИНН):</label>
                <input type="text" id="purchase-supplier-input" list="supplier-options" class="input-modern" placeholder="Начните вводить для поиска..." autocomplete="off" onclick="this.value=''">
                <datalist id="supplier-options"></datalist>
            </div>

            <div class="form-group col-span-2">
                <label>Счет оплаты (оставьте пустым для закупки в долг):</label>
                <select id="purchase-account-select" class="input-modern">
                    <option value="">-- НЕ ОПЛАЧИВАТЬ (В ДОЛГ) --</option>
                </select>
            </div>

            <div class="form-group">
                <label>Количество:</label>
                <input type="number" id="purchase-qty" class="input-modern" oninput="calculatePurchaseTotal()" placeholder="0.00">
            </div>

            <div class="form-group">
                <label>Цена за ед. (₽):</label>
                <input type="number" id="purchase-price" class="input-modern" oninput="calculatePurchaseTotal()" placeholder="0.00">
            </div>
        </div>

        <div class="summary-box">
            <span class="summary-label">Итоговая сумма:</span>
            <span class="summary-value">
                <span id="purchase-total-cost">0.00</span> ₽
            </span>
        </div>

        <button class="btn btn-blue w-100 mt-20" style="padding: 14px;" onclick="submitPurchase()">
            📥 Оформить приход
        </button>
    </div>
</div>