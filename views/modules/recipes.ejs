<div id="recipe-mod" class="module">
    <div class="flex-between mb-20" style="align-items: flex-end;">
        <div>
            <h2 class="mt-0">🧪 Управление рецептурами</h2>
            
            <div class="mb-20 flex-row gap-10" id="top-panel-mass-apply">
                <button class="btn btn-outline" style="border-color: var(--primary); color: var(--primary);"
                    onclick="showRecipeMassApplyModal()">🎭 Массовое применение шаблона</button>
            </div>

            <!-- ПЕРЕКЛЮЧАТЕЛЬ РЕЖИМОВ (TABS) -->
            <div class="mb-20" style="display: flex; gap: 15px; border-bottom: 2px solid var(--border); padding-bottom: 30px; margin-bottom: 30px;">
                <button id="tab-recipes-bom" class="btn btn-blue shadow-primary" style="font-weight: bold; border-radius: 8px; padding: 12px 24px;" onclick="switchRecipeMode('BOM')">
                    📊 Нормы расхода (1 ед.)
                </button>
                <button id="tab-recipes-mix" class="btn btn-outline" style="font-weight: bold; border-radius: 8px; padding: 12px 24px; border-color: var(--primary); color: var(--primary);" onclick="switchRecipeMode('MIX')">
                    🐘 Шаблоны Замесов
                </button>
            </div>
            
            <p class="text-muted" style="font-size: 13px; margin: 0;">Настройка эталонного расхода сырья на 1 единицу продукции (кв.м, шт)</p>
        </div>
    </div>

    <div class="form-grid" style="grid-template-columns: 1fr 2fr; align-items: start; gap: 24px;">

        <div class="flex-column gap-20">
            <div class="card" style="border-left: 4px solid var(--primary);" id="recipe-left-mode-bom">
                <h3 class="mt-0" style="font-size: 16px;">1. Выбор продукции</h3>
                <div class="form-group">
                    <label>Плитка / Блок / Бордюр:</label>
                    <select id="recipe-product-select" class="input-modern" onchange="loadRecipeDetails()"></select>
                </div>
            </div>

            <div class="card" style="border-left: 4px solid var(--primary); display: none;" id="recipe-left-mode-mix">
                <h3 class="mt-0" style="font-size: 16px;">1. Выбор Шаблона</h3>
                <div class="form-group">
                    <label>Матрица бетономешалки (31 ключ):</label>
                    <select id="mix-template-keys-select" class="input-modern" onchange="loadMixTemplateDetails()">
                        <option value="" disabled selected>-- Выберите шаблон --</option>
                        <optgroup label="ОСНОВНОЙ СЛОЙ">
                            <option value="main_block">Блок стеновой / Полублок</option>
                            <option value="main_bor_dor">Бордюр дорожный</option>
                            <option value="main_bor_mag">Бордюр магистральный</option>
                            <option value="main_por">Поребрик газонный</option>
                            <option value="main_tile_40">Плитка 40 мм</option>
                            <option value="main_tile_60">Плитка 60 мм</option>
                            <option value="main_tile_80">Плитка 80 мм</option>
                        </optgroup>
                        <optgroup label="ЛИЦЕВОЙ СЛОЙ (ГЛАДКАЯ)">
                            <option value="face_smooth_grey">Гладкая Серая</option>
                            <option value="face_smooth_white">Гладкая Белая</option>
                            <option value="face_smooth_black">Гладкая Черная</option>
                            <option value="face_smooth_red">Гладкая Красная</option>
                            <option value="face_smooth_yellow">Гладкая Желтая</option>
                            <option value="face_smooth_brown">Гладкая Коричневая</option>
                            <option value="face_smooth_orange">Гладкая Оранжевая</option>
                        </optgroup>
                        <optgroup label="ЛИЦЕВОЙ СЛОЙ (ГРАНИТ)">
                            <option value="face_granite_grey">Гранит Серая (Чистая)</option>
                            <option value="face_granite_black">Гранит Черная</option>
                            <option value="face_granite_red">Гранит Красная</option>
                            <option value="face_granite_yellow">Гранит Желтая</option>
                            <option value="face_granite_brown">Гранит Коричневая</option>
                            <option value="face_granite_orange">Гранит Оранжевая</option>
                        </optgroup>
                        <optgroup label="ЛИЦЕВОЙ СЛОЙ (МЕЛАНЖ ГЛАДКИЙ)">
                            <option value="face_mel_sm_onyx">Меланж Гладкий Оникс</option>
                            <option value="face_mel_sm_autumn">Меланж Гладкий Осень</option>
                            <option value="face_mel_sm_amber">Меланж Гладкий Янтарь</option>
                            <option value="face_mel_sm_jasper">Меланж Гладкий Яшма</option>
                            <option value="face_mel_sm_ruby">Меланж Гладкий Рубин</option>
                        </optgroup>
                        <optgroup label="ЛИЦЕВОЙ СЛОЙ (МЕЛАНЖ ГРАНИТ)">
                            <option value="face_mel_gr_onyx">Меланж Гранит Оникс</option>
                            <option value="face_mel_gr_autumn">Меланж Гранит Осень</option>
                            <option value="face_mel_gr_amber">Меланж Гранит Янтарь</option>
                            <option value="face_mel_gr_jasper">Меланж Гранит Яшма</option>
                            <option value="face_mel_gr_ruby">Меланж Гранит Рубин</option>
                        </optgroup>
                    </select>
                </div>
            </div>

            <div class="card card-alt" id="recipe-summary-card" style="display: none;">
                <h3 class="mt-0" style="font-size: 16px;">📊 Сводка по рецепту</h3>
                <div class="flex-between mb-15" style="font-size: 15px;">
                    <span class="text-muted">Общий вес сырья:</span>
                    <strong id="recipe-total-weight" class="text-main">0.00 кг</strong>
                </div>
                <div class="flex-between mb-15" style="font-size: 15px;">
                    <span class="text-muted" id="recipe-cost-label">Себестоимость (сырье):</span>
                    <strong id="recipe-total-cost" class="recipe-cost-highlight">0.00 ₽</strong>
                </div>

                <div id="mix-yield-container" style="display: none; background: var(--surface); padding: 12px; border-radius: 8px; border: 1px dashed var(--border); margin-top: 15px;">
                    <div class="form-group mb-10">
                        <label class="text-primary" style="font-weight: 600;">Плановый выход (кв.м, шт):</label>
                        <input type="number" id="mix-yield-input" class="input-modern" style="margin-top: 5px;" value="1" step="any" oninput="recalculateMixUnitCost()">
                    </div>
                    <div class="flex-between text-success" style="font-size: 15px; font-weight: bold; padding-top: 10px; border-top: 1px dashed var(--border);">
                        <span>Себестоимость 1 ед:</span>
                        <strong id="mix-unit-cost">0.00 ₽</strong>
                    </div>
                </div>

                <div class="text-muted" style="font-size: 12px; margin-top: 15px; border-top: 1px dashed var(--border); padding-top: 10px;">
                    <span id="recipe-footer-hint">* Расчет идет строго на 1 единицу измерения (указана в справочнике).</span>
                </div>
            </div>
        </div>

        <div class="card card-recipe-editor" id="recipe-editor-area" style="display: none;">
            <div class="flex-between mb-20" style="align-items: center; padding-bottom: 20px; border-bottom: 1px dashed var(--border);">
                <div style="display: flex; align-items: center; gap: 15px;">
                    <h3 id="recipe-editor-title" class="mt-0 text-main" style="margin-bottom: 0; font-size: 20px;">Рецепт: ...</h3>
                    <span id="recipe-editor-badge" class="badge" style="display: none; padding: 6px 12px; font-size: 13px; font-weight: bold; border-radius: 6px;"></span>
                </div>
                <div style="display: flex; gap: 10px;">
                    <button id="btn-mass-apply-recipe" class="btn btn-outline" style="border-color: var(--primary); color: var(--primary);" onclick="showRecipeMassApplyModal()">🎭 Массовое применение</button>

                    <button class="btn btn-green shadow-success" onclick="saveRecipe(false)">💾 Сохранить</button>
                </div>
            </div>

            <div class="add-component-box" style="margin-top: 15px; margin-bottom: 25px; background: var(--surface-alt); padding: 20px; border-radius: 8px;">
                <h4 class="mt-0 mb-15 text-primary" style="font-size: 15px;">➕ Добавить сырье</h4>
                <div style="display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap;">
                    <div class="form-group" style="flex: 2; min-width: 200px; margin-bottom: 0;">
                        <label>Материал (Сырье):</label>
                        <select id="recipe-material-select" class="input-modern"></select>
                    </div>
                    <div class="form-group" style="flex: 1; min-width: 120px; margin-bottom: 0;">
                        <label>Кол-во (кг/л/шт):</label>
                        <input type="number" id="recipe-material-qty" class="input-modern" step="0.001" placeholder="0.00">
                    </div>
                    <button class="btn btn-blue shadow-primary" onclick="addIngredientToRecipe()" style="height: 42px; padding: 0 25px;">В список</button>
                </div>
            </div>

            <div class="table-container">
                <table>
                    <thead style="background: var(--surface-alt);">
                        <tr>
                            <th style="padding: 12px 15px;">Сырье</th>
                            <th style="text-align: right; padding: 12px 15px;">Кол-во</th>
                            <th style="padding: 12px 15px;">Ед.</th>
                            <th style="text-align: right; padding: 12px 15px;">Сумма (₽)</th>
                            <th class="text-center" style="padding: 12px 15px;">Удалить</th>
                        </tr>
                    </thead>
                    <tbody id="recipe-table-body"></tbody>
                </table>
            </div>

            <div id="recipe-empty-msg" class="text-center text-muted" style="display: none; padding: 20px; font-size: 14px; border: 1px dashed var(--border); border-radius: 6px; margin-top: 15px;">
                В этом рецепте пока нет компонентов. Добавьте сырье выше.
            </div>
        </div>
    </div>
</div>