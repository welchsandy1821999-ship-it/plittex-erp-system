<div id="recipe-mod" class="module">
    <div class="flex-between mb-20 align-end">
        <div>
            <h2 class="mt-0">🧪 Управление рецептурами</h2>
            
            <div class="mb-20 flex-row gap-10" id="top-panel-mass-apply">
                <button class="btn btn-outline rec-primary-outline"
                    onclick="showRecipeMassApplyModal()">🎭 Массовое применение шаблона</button>
            </div>

            <!-- ПЕРЕКЛЮЧАТЕЛЬ РЕЖИМОВ (TABS) -->
            <div class="mb-20 rec-filter-container">
                <button id="tab-recipes-bom" class="btn btn-blue shadow-primary font-bold radius-8 p-12-24" onclick="switchRecipeMode('BOM')">
                    📊 Нормы расхода (1 ед.)
                </button>
                <button id="tab-recipes-mix" class="btn btn-outline rec-action-btn rec-primary-outline" onclick="switchRecipeMode('MIX')">
                    🐘 Шаблоны Замесов
                </button>
            </div>
            
            <p class="text-muted font-13 m-0">Настройка эталонного расхода сырья на 1 единицу продукции (кв.м, шт)</p>
        </div>
    </div>

    <div class="form-grid rec-grid-header">

        <div class="flex-column gap-20">
            <div class="card pl-10 rec-section-title" id="recipe-left-mode-bom">
                <h3 class="mt-0 font-16">1. Выбор продукции</h3>
                <div class="form-group">
                    <label>Плитка / Блок / Бордюр:</label>
                    <select id="recipe-product-select" class="input-modern" onchange="loadRecipeDetails()"></select>
                </div>
            </div>

            <div class="card border-primary-left hidden" id="recipe-left-mode-mix">
                <h3 class="mt-0 font-16">1. Выбор Шаблона</h3>
                <div class="form-group">
                    <label>Матрица бетономешалки (31 ключ):</label>
                    <select id="mix-template-keys-select" class="input-modern" onchange="loadMixTemplateDetails()">
                        <option value="" disabled selected>-- Выберите шаблон --</option>
                        <optgroup label="ОСНОВНОЙ СЛОЙ">
                            <option value="main_block">Блок стеновой / Полублок</option>
                            <option value="main_bor_dor">Бордюр дорожный</option>
                            <option value="main_bor_mag">Бордюр магистральный</option>
                            <option value="main_por">Поребрик газонный</option>
                            <option value="main_tile_40">Плитка 40 мм</option>
                            <option value="main_tile_60">Плитка 60 мм</option>
                            <option value="main_tile_80">Плитка 80 мм</option>
                        </optgroup>
                        <optgroup label="ЛИЦЕВОЙ СЛОЙ (ГЛАДКАЯ)">
                            <option value="face_smooth_grey">Гладкая Серая</option>
                            <option value="face_smooth_white">Гладкая Белая</option>
                            <option value="face_smooth_black">Гладкая Черная</option>
                            <option value="face_smooth_red">Гладкая Красная</option>
                            <option value="face_smooth_yellow">Гладкая Желтая</option>
                            <option value="face_smooth_brown">Гладкая Коричневая</option>
                            <option value="face_smooth_orange">Гладкая Оранжевая</option>
                        </optgroup>
                        <optgroup label="ЛИЦЕВОЙ СЛОЙ (ГРАНИТ)">
                            <option value="face_granite_grey">Гранит Серая (Чистая)</option>
                            <option value="face_granite_black">Гранит Черная</option>
                            <option value="face_granite_red">Гранит Красная</option>
                            <option value="face_granite_yellow">Гранит Желтая</option>
                            <option value="face_granite_brown">Гранит Коричневая</option>
                            <option value="face_granite_orange">Гранит Оранжевая</option>
                        </optgroup>
                        <optgroup label="ЛИЦЕВОЙ СЛОЙ (МЕЛАНЖ ГЛАДКИЙ)">
                            <option value="face_mel_sm_onyx">Меланж Гладкий Оникс</option>
                            <option value="face_mel_sm_autumn">Меланж Гладкий Осень</option>
                            <option value="face_mel_sm_amber">Меланж Гладкий Янтарь</option>
                            <option value="face_mel_sm_jasper">Меланж Гладкий Яшма</option>
                            <option value="face_mel_sm_ruby">Меланж Гладкий Рубин</option>
                        </optgroup>
                        <optgroup label="ЛИЦЕВОЙ СЛОЙ (МЕЛАНЖ ГРАНИТ)">
                            <option value="face_mel_gr_onyx">Меланж Гранит Оникс</option>
                            <option value="face_mel_gr_autumn">Меланж Гранит Осень</option>
                            <option value="face_mel_gr_amber">Меланж Гранит Янтарь</option>
                            <option value="face_mel_gr_jasper">Меланж Гранит Яшма</option>
                            <option value="face_mel_gr_ruby">Меланж Гранит Рубин</option>
                        </optgroup>
                    </select>
                </div>
            </div>

            <div class="card card-alt hidden" id="recipe-summary-card">
                <h3 class="mt-0 font-16">📊 Сводка по рецепту</h3>
                <div class="flex-between mb-15 font-15">
                    <span class="text-muted">Общий вес сырья:</span>
                    <strong id="recipe-total-weight" class="text-main">0.00 кг</strong>
                </div>
                <div class="flex-between mb-15 font-15">
                    <span class="text-muted" id="recipe-cost-label">Себестоимость (сырье):</span>
                    <strong id="recipe-total-cost" class="recipe-cost-highlight">0.00 ₽</strong>
                </div>

                <div id="mix-yield-container" class="hidden bg-surface p-12 radius-8 border-dashed mt-15">
                    <div class="form-group mb-10">
                        <label class="text-primary font-600">Плановый выход (кв.м, шт):</label>
                        <input type="number" id="mix-yield-input" class="input-modern mt-5" value="1" step="any" oninput="recalculateMixUnitCost()">
                    </div>
                    <div class="flex-between text-success rec-step-header">
                        <span>Себестоимость 1 ед:</span>
                        <strong id="mix-unit-cost">0.00 ₽</strong>
                    </div>
                </div>

                <div class="text-muted font-12 mt-15 pt-10 border-top-dashed">
                    <span id="recipe-footer-hint">* Расчет идет строго на 1 единицу измерения (указана в справочнике).</span>
                </div>
            </div>
        </div>

        <div class="card card-recipe-editor hidden" id="recipe-editor-area">
            <div class="flex-between mb-20 align-center pb-20 border-bottom-dashed">
                <div class="flex-row align-center gap-15">
                    <h3 id="recipe-editor-title" class="mt-0 text-main mb-0 font-20">Рецепт: ...</h3>
                    <span id="recipe-editor-badge" class="badge hidden p-6-12 font-13 font-bold radius-6"></span>
                </div>
                <div class="flex-row gap-10">
                    <button id="btn-mass-apply-recipe" class="btn btn-outline rec-primary-outline" onclick="showRecipeMassApplyModal()">🎭 Массовое применение</button>

                    <button class="btn btn-green shadow-success" onclick="saveRecipe(false)">💾 Сохранить</button>
                </div>
            </div>

            <div class="add-component-box rec-cost-panel">
                <h4 class="mt-0 mb-15 text-primary font-15">➕ Добавить сырье</h4>
                <div class="rec-cost-param">
                    <div class="form-group flex-2 min-w-200 m-0">
                        <label>Материал (Сырье):</label>
                        <select id="recipe-material-select" class="input-modern"></select>
                    </div>
                    <div class="form-group flex-1 min-w-120 m-0">
                        <label>Кол-во (кг/л/шт):</label>
                        <input type="number" id="recipe-material-qty" class="input-modern" step="0.001" placeholder="0.00">
                    </div>
                    <button class="btn btn-blue shadow-primary h-42 px-25" onclick="addIngredientToRecipe()">В список</button>
                </div>
            </div>

            <div class="table-container">
                <table>
                    <thead class="bg-surface-alt">
                        <tr>
                            <th class="px-15 py-12">Сырье</th>
                            <th class="text-right px-15 py-12">Кол-во</th>
                            <th class="px-15 py-12">Ед.</th>
                            <th class="text-right px-15 py-12">Сумма (₽)</th>
                            <th class="text-center px-15 py-12">Удалить</th>
                        </tr>
                    </thead>
                    <tbody id="recipe-table-body"></tbody>
                </table>
            </div>

            <div id="recipe-empty-msg" class="text-center text-muted hidden p-20 font-14 border-dashed radius-6 mt-15">
                В этом рецепте пока нет компонентов. Добавьте сырье выше.
            </div>
        </div>
    </div>
</div>