<div id="dashboard-mod" class="module active">
    <div class="flex-between mb-20" style="align-items: flex-end;">
        <div>
            <h2 class="mt-0 mb-0">🧮 Конструктор себестоимости (Unit-экономика)</h2>
            <p class="text-muted mt-0" style="font-size: 13px;">Моделирование реальной себестоимости 1 цикла формовки
            </p>
        </div>
    </div>

    <div class="filter-panel">
        <div class="form-group mb-0">
            <label>Период для расчета:</label>
            <input type="text" id="cc-date-range" class="input-modern" style="width: 250px; cursor: pointer;"
                placeholder="Выберите период...">
        </div>
        <button class="btn btn-blue" onclick="loadCostConstructor()">🔄 Загрузить данные</button>
    </div>

    <div class="summary-grid mb-20">
        <div class="summary-card" style="text-align: center; border-bottom: 4px solid var(--primary);">
            <div class="summary-title">Отработано циклов формовки</div>
            <div id="cc-total-cycles" class="summary-value text-main">0</div>
        </div>
        <div class="summary-card" style="text-align: center; border-bottom: 4px solid var(--warning);">
            <div class="summary-title">Выбрано накладных расходов</div>
            <div id="cc-total-expenses" class="summary-value" style="color: var(--warning);">0 ₽</div>
        </div>
        <div class="summary-card" style="text-align: center; border-bottom: 4px solid var(--danger);">
            <div class="summary-title">Накладные расходы на 1 цикл</div>
            <div id="cc-cost-per-cycle" class="summary-value" style="color: var(--danger);">0.00 ₽</div>
        </div>
    </div>

    <div class="form-grid"
        style="grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 20px; align-items: stretch;">

        <div class="card mb-0 flex-column" style="padding: 0; overflow: hidden;">
            <div class="card-header-flex" style="padding: 20px 20px 0 20px;">
                <div>
                    <h3 class="mt-0 mb-5">База распределения</h3>
                    <p class="text-muted mt-0" style="font-size: 12px; line-height: 1.2;">Исключите расходы, не
                        относящиеся к производству.</p>
                </div>
                <button class="btn btn-outline" onclick="addVirtualExpense()"
                    style="font-size: 12px; padding: 6px 10px;">➕ Добавить</button>
            </div>
            <div id="cc-expenses-list" class="expense-list" style="padding: 0 20px 20px 20px;">
                <div class="text-center text-muted" style="padding: 20px;">Загрузка...</div>
            </div>
        </div>

        <div class="card mb-0 flex-column">
            <div class="card-header-flex">
                <h3 class="mt-0">Структура накладных расходов</h3>
            </div>
            <div class="chart-container">
                <canvas id="cc-structure-chart"></canvas>
            </div>
        </div>

    </div>
</div>