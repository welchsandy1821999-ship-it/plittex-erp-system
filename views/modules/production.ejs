<div id="prod-mod" class="module">
    <div class="flex-between mb-20">
        <h2 class="mt-0" style="margin-bottom: 0;">🔨 Модуль формовки и замесов</h2>

        <button class="btn btn-purple" onclick="openMrpDashboard()">
            📋 Сводный план производства
        </button>

        <div class="form-group" style="margin: 0;">
            <label style="display: block; font-size: 11px; margin-bottom: 2px;">Дата смены:</label>
            <input type="text" id="prod-date-filter" class="input-modern" style="width: 140px; cursor: pointer;">
        </div>
    </div>
    <div class="card" style="border-left: 4px solid var(--primary);">
        <div class="flex-between mb-15">
            <h3 class="mt-0" style="margin-bottom: 0;">🚜 Настройка замесов и формовки</h3>
            <div class="form-group" style="margin: 0; width: 250px;">
                <label>Старший смены / Бригадир:</label>
                <select id="prod-shift-name" class="input-modern">
                    <option value="">-- Выберите сотрудника --</option>
                </select>
            </div>
        </div>

        <div class="form-grid gap-15" style="grid-template-columns: 1fr 1fr 1fr; align-items: stretch;">

            <div class="card-step card-success">
                <h4 class="step-title text-success">🧱 1. Формовка (Циклы)</h4>

                <div class="form-group">
                    <label style="font-weight: bold;">Выбор продукции:</label>
                    <select id="prod-product-select" class="input-modern" style="font-size: 14px; font-weight: bold;"
                        onchange="handleProductSelection()"></select>
                </div>

                <div class="form-grid gap-10 mt-0" style="grid-template-columns: 1fr 1fr; margin-top: 5px;">
                    <div class="form-group">
                        <label>Удары (Циклы):</label>
                        <input type="number" id="prod-cycles-input" class="input-modern text-center" placeholder="0"
                            style="font-size: 16px; font-weight: bold;" oninput="calculateMixesPreview()">
                    </div>
                    <div class="form-group">
                        <label>Итого (м²/шт):</label>
                        <div id="prod-volume-preview" class="text-center text-success"
                            style="font-weight: 900; font-size: 16px; padding: 10px; background: var(--surface); border-radius: 6px; border: 1px solid var(--success-border);">
                            0.00
                        </div>
                    </div>
                </div>

                <div class="flex-grow-1"></div>
                <button class="btn btn-blue w-100" style="margin-top: 15px; height: 40px; font-size: 14px;"
                    onclick="addProdToSession()">➕ Добавить в партию</button>
            </div>

            <div class="card-step card-alt">
                <h4 class="step-title text-main">🐘 2. Основной замес</h4>

                <div class="form-group">
                    <label>Шаблон:</label>
                    <select id="main-template-select" class="input-modern" onchange="renderSelectedTemplates()">
                        <option value="main_40">Плитка 40мм</option>
                        <option value="main_60">Плитка 60мм</option>
                        <option value="main_80">Плитка 80мм</option>
                        <option value="main_por">Поребрик</option>
                        <option value="main_bor">Бордюр Дор./Магистр.</option>
                    </select>
                </div>

                <div class="form-group">
                    <label style="color: var(--primary); font-weight: bold;">Кол-во замесов (Факт):</label>
                    <div style="display: flex; gap: 10px; align-items: center;">
                        <input type="number" id="main-mix-count" class="input-modern text-center"
                            style="font-size: 18px; font-weight: bold;" placeholder="0" onfocus="this.select()">
                        <button class="btn btn-outline" style="padding: 6px 10px;"
                            onclick="editMixTemplate(document.getElementById('main-template-select').value)"
                            title="Настроить шаблон">⚙️</button>
                    </div>
                </div>

                <div id="main-mix-norms" class="text-muted flex-grow-1"
                    style="font-size: 12px; background: var(--surface-alt); padding: 10px; border-radius: 6px;">
                </div>
            </div>

            <div class="card-step card-warning">
                <h4 class="step-title text-warning">🐥 3. Лицевой замес</h4>

                <div class="form-group">
                    <label>Шаблон:</label>
                    <select id="face-template-select" class="input-modern" onchange="renderSelectedTemplates()">
                        <option value="face_gs">Гладкий серый</option>
                        <option value="face_gc">Гладкий цветной</option>
                        <option value="face_grs">Гранитный серый</option>
                        <option value="face_grc">Гранитный цветной</option>
                        <option value="face_mel_g">Меланж гладкий</option>
                        <option value="face_mel_gr">Меланж гранит</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="text-warning" style="font-weight: bold;">Кол-во замесов (Факт):</label>
                    <div style="display: flex; gap: 10px; align-items: center;">
                        <input type="number" id="face-mix-count" class="input-modern text-center"
                            style="font-size: 18px; font-weight: bold;" placeholder="0" onfocus="this.select()">
                        <button class="btn btn-outline"
                            style="padding: 6px 10px; border-color: var(--warning-text); color: var(--warning-text);"
                            onclick="editMixTemplate(document.getElementById('face-template-select').value)"
                            title="Настроить шаблон">⚙️</button>
                    </div>
                </div>

                <div id="face-mix-norms" class="text-warning flex-grow-1"
                    style="font-size: 12px; background: var(--warning-bg); padding: 10px; border-radius: 6px;">
                </div>
            </div>
        </div>
        <h4 style="margin: 20px 0 10px 0;">📋 Список продукции за смену:</h4>
        <div id="session-products-list" class="flex-column mb-20" style="gap: 8px;"></div>

        <button class="btn btn-green w-100 btn-lg shadow-success" onclick="submitDailyProduction()">
            💾 ЗАФИКСИРОВАТЬ СМЕНУ И СПИСАТЬ СЫРЬЕ ИЗ ЗАМЕСОВ
        </button>
    </div>
    <div class="card border-left-muted">
        <h3 class="mt-0">🕒 История формовок за выбранную дату</h3>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>№ Партии</th>
                        <th>Продукция</th>
                        <th>Объем</th>
                        <th>Затраты на сырье</th>
                        <th style="text-align: right;">Действия</th>
                    </tr>
                </thead>
                <tbody id="daily-history-table">
                    <tr>
                        <td colspan="5" class="text-center text-muted">Загрузка истории...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div id="mix-template-modal" class="modal-overlay" style="display: none;">
        <div class="modal-box">
            <h3 id="template-modal-title" class="modal-header">Настройка шаблона</h3>

            <div id="template-items-container" class="modal-body-scroll"></div>

            <div class="modal-footer">
                <div class="mb-15">
                    <button class="btn btn-outline w-100" style="color: var(--primary); border-color: var(--primary);"
                        onclick="addTemplateRow()">
                        ➕ Добавить сырье
                    </button>
                </div>
                <div class="flex-between gap-15">
                    <button class="btn btn-outline flex-grow-1"
                        onclick="document.getElementById('mix-template-modal').style.display='none'">
                        Отмена
                    </button>
                    <button class="btn btn-green flex-grow-1" onclick="saveMixTemplate()">
                        💾 Сохранить шаблон
                    </button>
                </div>
            </div>
        </div>
    </div>

</div>