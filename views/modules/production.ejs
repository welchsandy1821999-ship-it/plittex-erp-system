<div id="prod-mod" class="module">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2>🔨 Модуль формовки и замесов</h2>
        <div class="form-group">
            <label>Дата смены:</label>
            <input type="date" id="prod-date-filter" class="input-modern" onchange="loadDailyHistory()">
        </div>
    </div>


    <div class="card" style="border-left: 4px solid var(--primary);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
            <h3 style="margin: 0;">🚜 Настройка замесов и формовки</h3>
            <div class="form-group" style="margin: 0; width: 250px;">
                <label>Старший смены / Бригадир:</label>
                <select id="prod-shift-name" class="input-modern">
                    <option value="">-- Выберите сотрудника --</option>
                </select>
            </div>
        </div>
        <div class="form-grid" style="grid-template-columns: 1fr 1fr 1fr; gap: 15px; align-items: stretch;">

            <div
                style="padding: 15px; background: #f0fdf4; border-radius: 8px; border: 1px solid #bbf7d0; display: flex; flex-direction: column;">
                <h4 style="margin-top:0; color: #166534; font-size: 16px;">🧱 1. Формовка (Циклы)</h4>

                <div class="form-group">
                    <label style="font-weight: bold;">Выбор продукции:</label>
                    <select id="prod-product-select" class="input-modern" style="font-size: 14px; font-weight: bold;"
                        onchange="handleProductSelection()"></select>
                </div>

                <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 5px;">
                    <div class="form-group">
                        <label>Удары (Циклы):</label>
                        <input type="number" id="prod-cycles-input" class="input-modern" placeholder="0"
                            style="font-size: 16px; font-weight: bold; text-align: center;"
                            oninput="calculateMixesPreview()">
                    </div>
                    <div class="form-group">
                        <label>Итого (м²/шт):</label>
                        <div id="prod-volume-preview"
                            style="font-weight: 900; font-size: 16px; padding: 10px; background: #fff; border-radius: 6px; border: 1px solid #bbf7d0; text-align: center; color: #15803d;">
                            0.00
                        </div>
                    </div>
                </div>

                <div style="flex-grow: 1;"></div>
                <button class="btn btn-blue" style="width: 100%; margin-top: 15px; height: 40px; font-size: 14px;"
                    onclick="addProdToSession()">➕ Добавить в партию</button>
            </div>

            <div
                style="padding: 15px; background: #f1f5f9; border-radius: 8px; border: 1px solid var(--border); display: flex; flex-direction: column;">
                <h4 style="margin-top:0; color: #334155; font-size: 16px;">🐘 2. Основной замес</h4>

                <div class="form-group">
                    <label>Шаблон:</label>
                    <select id="main-template-select" class="input-modern" onchange="renderSelectedTemplates()">
                        <option value="main_40">Плитка 40мм</option>
                        <option value="main_60">Плитка 60мм</option>
                        <option value="main_80">Плитка 80мм</option>
                        <option value="main_por">Поребрик</option>
                        <option value="main_bor">Бордюр Дор./Магистр.</option>
                    </select>
                </div>

                <div class="form-group">
                    <label style="color: var(--primary); font-weight: bold;">Кол-во замесов (Факт):</label>
                    <div style="display: flex; gap: 10px; align-items: center;">
                        <input type="number" id="main-mix-count" class="input-modern"
                            style="font-size: 18px; font-weight: bold; text-align: center;" placeholder="0"
                            onfocus="this.select()">
                        <button class="btn btn-outline" style="padding: 6px 10px;"
                            onclick="editMixTemplate(document.getElementById('main-template-select').value)"
                            title="Настроить шаблон">⚙️</button>
                    </div>
                </div>

                <div id="main-mix-norms"
                    style="font-size: 12px; color: var(--text-muted); background: #e2e8f0; padding: 10px; border-radius: 6px; flex-grow: 1;">
                </div>
            </div>

            <div
                style="padding: 15px; background: #fffbeb; border-radius: 8px; border: 1px solid #fde68a; display: flex; flex-direction: column;">
                <h4 style="margin-top:0; color: #92400e; font-size: 16px;">🐥 3. Лицевой замес</h4>

                <div class="form-group">
                    <label>Шаблон:</label>
                    <select id="face-template-select" class="input-modern" onchange="renderSelectedTemplates()">
                        <option value="face_gs">Гладкий серый</option>
                        <option value="face_gc">Гладкий цветной</option>
                        <option value="face_grs">Гранитный серый</option>
                        <option value="face_grc">Гранитный цветной</option>
                        <option value="face_mel_g">Меланж гладкий</option>
                        <option value="face_mel_gr">Меланж гранит</option>
                    </select>
                </div>

                <div class="form-group">
                    <label style="color: #d97706; font-weight: bold;">Кол-во замесов (Факт):</label>
                    <div style="display: flex; gap: 10px; align-items: center;">
                        <input type="number" id="face-mix-count" class="input-modern"
                            style="font-size: 18px; font-weight: bold; text-align: center;" placeholder="0"
                            onfocus="this.select()">
                        <button class="btn btn-outline"
                            style="padding: 6px 10px; border-color: #d97706; color: #d97706;"
                            onclick="editMixTemplate(document.getElementById('face-template-select').value)"
                            title="Настроить шаблон">⚙️</button>
                    </div>
                </div>

                <div id="face-mix-norms"
                    style="font-size: 12px; color: #92400e; background: #fef3c7; padding: 10px; border-radius: 6px; flex-grow: 1;">
                </div>
            </div>
        </div>

        <h4 style="margin: 20px 0 10px 0;">📋 Список продукции за смену:</h4>
        <div id="session-products-list" style="margin-bottom: 20px; display: flex; flex-direction: column; gap: 8px;">
        </div>

        <button class="btn btn-green"
            style="width: 100%; padding: 15px; font-size: 16px; box-shadow: 0 4px 6px rgba(16,185,129,0.3);"
            onclick="submitDailyProduction()">💾 ЗАФИКСИРОВАТЬ СМЕНУ И СПИСАТЬ СЫРЬЕ ИЗ ЗАМЕСОВ</button>
    </div>

    <div class="card" style="border-left: 4px solid var(--text-muted);">
        <h3>🕒 История формовок за выбранную дату</h3>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>№ Партии</th>
                        <th>Продукция</th>
                        <th>Объем</th>
                        <th>Затраты на сырье</th>
                        <th style="text-align: right;">Действия</th>
                    </tr>
                </thead>
                <tbody id="daily-history-table">
                    <tr>
                        <td colspan="5" style="text-align: center; color: var(--text-muted);">Загрузка
                            истории...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div id="mix-template-modal"
        style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
        <div
            style="background: #fff; padding: 20px; border-radius: 8px; width: 500px; max-width: 95%; box-shadow: 0 4px 15px rgba(0,0,0,0.2);">

            <h3 id="template-modal-title"
                style="margin-top: 0; color: var(--text-main); border-bottom: 1px solid var(--border); padding-bottom: 10px;">
                Настройка шаблона
            </h3>

            <div id="template-items-container"
                style="max-height: 400px; overflow-y: auto; padding-right: 5px; margin-bottom: 15px;">
            </div>

            <div style="border-top: 1px solid var(--border); padding-top: 15px; margin-top: 10px;">
                <div style="margin-bottom: 15px;">
                    <button class="btn btn-outline"
                        style="color: var(--primary); border-color: var(--primary); width: 100%;"
                        onclick="addTemplateRow()">
                        ➕ Добавить сырье
                    </button>
                </div>
                <div style="display: flex; justify-content: space-between; gap: 15px;">
                    <button class="btn btn-outline" style="flex-grow: 1;"
                        onclick="document.getElementById('mix-template-modal').style.display='none'">
                        Отмена
                    </button>
                    <button class="btn btn-green" style="flex-grow: 1;" onclick="saveMixTemplate()">
                        💾 Сохранить шаблон
                    </button>
                </div>
            </div>

        </div>
    </div>

</div>