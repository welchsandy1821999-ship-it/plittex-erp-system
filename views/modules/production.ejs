<div id="prod-mod" class="module">
    <div class="flex-between mb-20">
        <h2 class="mt-0 mb-0">🔨 Модуль формовки и замесов</h2>

        <button class="btn btn-purple" onclick="openMrpDashboard()">
            📋 Сводный план производства
        </button>

        <div class="form-group prod-header-datepicker">
            <label class="label-sm">Дата смены:</label>
            <input type="text" id="prod-date-filter" class="input-modern prod-date-input">
        </div>
    </div>
    <div class="card border-left-primary">
        <div class="flex-between mb-15">
            <h3 class="mt-0 mb-0">🚜 Настройка замесов и формовки</h3>
        </div>

        <div class="form-grid gap-15 prod-steps-grid">

            <div class="card-step card-success">
                <h4 class="step-title text-success">🧱 1. Формовка (Циклы)</h4>

                <div class="step-body">
                    <div class="form-group prod-shift-group">
                        <label class="font-bold">Старший смены / Бригадир:</label>
                        <select id="prod-shift-name" class="input-modern">
                            <option value="">-- Выберите сотрудника --</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="font-bold">Выбор продукции:</label>
                        <select id="prod-product-select" class="input-modern" placeholder="Поиск продукции...">
                            <option value="">Загрузка...</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <div class="flex-row gap-15 align-end">
                            <div class="w-50">
                                <label class="font-bold">Удары (Циклы):</label>
                                <input type="number" id="prod-cycles-input" class="input-modern" placeholder="0" min="1" oninput="calculateMixesPreview()">
                            </div>
                            <div class="w-50">
                                <label class="font-bold text-muted">Итого (ед):</label>
                                <div id="prod-volume-preview" class="font-20 font-bold text-primary pb-10">0.00</div>
                            </div>
                        </div>
                    </div>

                    <button class="btn btn-blue w-100 mt-auto" id="add-to-batch-btn" onclick="addProdToSession()">
                        ➕ Добавить в партию
                    </button>
                </div>
            </div>

            <div class="card-step card-alt">
                <h4 class="step-title text-primary">🐘 2. Основной замес</h4>

                <div class="step-body">
                    <div class="form-group">
                        <label>Шаблон:</label>
                        <select id="main-template-select" class="input-modern" onchange="renderSelectedTemplates()">
                            <optgroup label="ОСНОВНОЙ СЛОЙ">
                                <option value="main_block">Блок стеновой / Полублок</option>
                                <option value="main_bor_dor">Бордюр дорожный</option>
                                <option value="main_bor_mag">Бордюр магистральный</option>
                                <option value="main_por">Поребрик газонный</option>
                                <option value="main_tile_40">Плитка 40 мм</option>
                                <option value="main_tile_60">Плитка 60 мм</option>
                                <option value="main_tile_80">Плитка 80 мм</option>
                            </optgroup>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="text-primary font-bold">Кол-во замесов (Факт):</label>
                        <div class="flex-row gap-10 align-center">
                            <input type="number" id="main-mix-count" class="input-modern text-center font-bold-18"
                                placeholder="0" onfocus="this.select()"
                                oninput="this.dataset.userEdited = 'true'">
                            <button class="btn btn-outline p-10"
                                onclick="editMixTemplate(document.getElementById('main-template-select').value)"
                                title="Настроить шаблон">⚙️</button>
                        </div>
                    </div>

                    <div id="main-mix-norms" class="mix-norms-block text-muted prod-mix-norms-main">
                    </div>
                </div>
            </div>

            <div class="card-step card-warning">
                <h4 class="step-title text-warning">🐥 3. Лицевой замес</h4>

                <div class="step-body">
                    <div class="form-group">
                        <label>Шаблон:</label>
                        <select id="face-template-select" class="input-modern" onchange="renderSelectedTemplates()">
                            <optgroup label="ЛИЦЕВОЙ СЛОЙ (ГЛАДКАЯ)">
                                <option value="face_smooth_grey">Гладкая Серая</option>
                                <option value="face_smooth_white">Гладкая Белая</option>
                                <option value="face_smooth_black">Гладкая Черная</option>
                                <option value="face_smooth_red">Гладкая Красная</option>
                                <option value="face_smooth_yellow">Гладкая Желтая</option>
                                <option value="face_smooth_brown">Гладкая Коричневая</option>
                                <option value="face_smooth_orange">Гладкая Оранжевая</option>
                            </optgroup>
                            <optgroup label="ЛИЦЕВОЙ СЛОЙ (ГРАНИТ)">
                                <option value="face_granite_grey">Гранит Серая (Чистая)</option>
                                <option value="face_granite_black">Гранит Черная</option>
                                <option value="face_granite_red">Гранит Красная</option>
                                <option value="face_granite_yellow">Гранит Желтая</option>
                                <option value="face_granite_brown">Гранит Коричневая</option>
                                <option value="face_granite_orange">Гранит Оранжевая</option>
                            </optgroup>
                            <optgroup label="ЛИЦЕВОЙ СЛОЙ (МЕЛАНЖ ГЛАДКИЙ)">
                                <option value="face_mel_sm_onyx">Меланж Гладкий Оникс</option>
                                <option value="face_mel_sm_autumn">Меланж Гладкий Осень</option>
                                <option value="face_mel_sm_amber">Меланж Гладкий Янтарь</option>
                                <option value="face_mel_sm_jasper">Меланж Гладкий Яшма</option>
                                <option value="face_mel_sm_ruby">Меланж Гладкий Рубин</option>
                            </optgroup>
                            <optgroup label="ЛИЦЕВОЙ СЛОЙ (МЕЛАНЖ ГРАНИТ)">
                                <option value="face_mel_gr_onyx">Меланж Гранит Оникс</option>
                                <option value="face_mel_gr_autumn">Меланж Гранит Осень</option>
                                <option value="face_mel_gr_amber">Меланж Гранит Янтарь</option>
                                <option value="face_mel_gr_jasper">Меланж Гранит Яшма</option>
                                <option value="face_mel_gr_ruby">Меланж Гранит Рубин</option>
                            </optgroup>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="text-warning font-bold">Кол-во замесов (Факт):</label>
                        <div class="flex-row gap-10 align-center">
                            <input type="number" id="face-mix-count" class="input-modern text-center font-bold-18"
                                placeholder="0" onfocus="this.select()"
                                oninput="this.dataset.userEdited = 'true'">
                            <button class="btn btn-outline-warning p-10"
                                onclick="editMixTemplate(document.getElementById('face-template-select').value)"
                                title="Настроить шаблон">⚙️</button>
                        </div>
                    </div>

                    <div id="face-mix-norms" class="mix-norms-block text-warning prod-mix-norms-face">
                    </div>
                </div>
            </div>
        </div>
        <h4 class="mt-20 mb-10">📋 Список продукции за смену:</h4>
        <div id="session-products-list" class="flex-col mb-20 gap-8"></div>

        <div id="shift-errors" class="hidden shift-error-alert"></div>

        <button class="btn btn-green w-100 btn-lg shadow-success" onclick="submitDailyProduction()">
            💾 ЗАФИКСИРОВАТЬ СМЕНУ И СПИСАТЬ СЫРЬЕ ИЗ ЗАМЕСОВ
        </button>
    </div>
    <div class="card border-left-muted prod-history-card">
        <div class="flex-between mb-15">
            <h3 class="mt-0 mb-0">История формовок</h3>

            <div class="prod-search-wrap">
                <span class="prod-search-icon">🔍</span>
                <input type="text" id="prod-search-input" class="input-modern prod-search-input"
                    placeholder="Поиск по № партии, плитке, бригадиру..." oninput="handleProductionSearch()">
            </div>
        </div>

        <div class="table-container">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th class="prod-th-sortable w-15" onclick="sortProductionResults('batch_number')">№
                            Партии ↕️</th>
                        <th class="prod-th-sortable w-30p"  onclick="sortProductionResults('product_name')">
                            Продукция ↕️</th>
                        <th id="th-prod-date" class="prod-th-date d-none w-12"
                            onclick="sortProductionResults('production_date')">Дата ↕️</th>

                        <th class="prod-th-sortable text-right w-13p" 
                            onclick="sortProductionResults('planned_quantity')">Кол-во ↕️</th>
                        <th class="prod-th-sortable text-right w-15p" 
                            onclick="sortProductionResults('mat_cost_total')">Себест. (мат) ↕️</th>
                        <th class="text-right w-15">Действия</th>
                    </tr>
                </thead>
                <tbody id="daily-history-table">
                    <tr>
                        <td colspan="5" class="text-center text-muted">Выберите дату в
                            календаре...</td>
                    </tr>
                </tbody>
                <tfoot id="prod-history-summary" class="prod-tfoot-summary hidden">
                    <tr>
                        <td colspan="2" class="prod-tfoot-label">ИТОГО ЗА СМЕНУ:</td>
                        <td id="prod-total-volume" class="prod-tfoot-volume">0.00</td>
                        <td id="prod-total-cost" class="prod-tfoot-cost">0.00 ₽</td>
                        <td class="prod-tfoot-actions">
                            <button class="btn btn-outline font-12 p-5"
                                onclick="printDailyReport()">
                                📄 Отчет за смену
                            </button>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>


</div>